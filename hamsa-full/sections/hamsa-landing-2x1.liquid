<script>
// ── GUÍA DE TALLAS MODAL — init inmediato ──
(function(){
  var overlay = document.getElementById('hlpSGOverlay');
  var closeBtn = document.getElementById('hlpSGClose');
  var triggerBtn = document.getElementById('hlpSizeGuideBtn');

  if(!overlay || !triggerBtn) return;

  function openSG(){
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    // Asegurar que el modal está por encima del modal de producto
    overlay.style.zIndex = '2147483647';
  }
  function closeSG(){
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  triggerBtn.addEventListener('click', openSG);
  if(closeBtn) closeBtn.addEventListener('click', closeSG);

  // Cerrar con clic fuera del modal
  overlay.addEventListener('click', function(e){
    if(e.target === overlay) closeSG();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && overlay.classList.contains('open')) closeSG();
  });
})();
</script>

<script>
(function(){
  // ── TIMER persistente por session ──
  function pad(n){return String(n).padStart(2,'0');}
  var endTime;
  try{
    var s=sessionStorage.getItem('hlp_te');
    endTime=s?parseInt(s):0;
    if(!endTime||endTime<Date.now()){
      endTime=Date.now()+(5+Math.floor(Math.random()*4))*3600000+Math.floor(Math.random()*60)*60000;
      sessionStorage.setItem('hlp_te',endTime);
    }
  }catch(e){endTime=Date.now()+6*3600000;}
  function tick(){
    var d=Math.max(0,Math.floor((endTime-Date.now())/1000));
    var H=document.getElementById('hlpH'),M=document.getElementById('hlpM'),S=document.getElementById('hlpS');
    if(H)H.textContent=pad(Math.floor(d/3600));
    if(M)M.textContent=pad(Math.floor((d%3600)/60));
    if(S)S.textContent=pad(d%60);
  }
  tick();setInterval(tick,1000);

  // ── STATE ──
  var BUNDLE_PRICE={{ bundle_price }};
  var BUNDLE_QTY=2;
  var selected={};   // {pid: {variantId,price,title,img,color,size}}
  var adding=false;

  // Check existing cart items
  fetch('/cart.js',{headers:{'Accept':'application/json'}})
    .then(function(r){return r.json();})
    .then(function(c){
      if((c.item_count||0)>=1){
        BUNDLE_QTY=1;
        var b=document.getElementById('hlpCartBanner');if(b)b.style.display='flex';
        var t=document.getElementById('hlpNeedTotal');if(t)t.textContent='1';
        var h=document.getElementById('hlpProgressHint');if(h)h.textContent='Elige 1 par mas para activar la oferta';
      }
      renderAll();
    }).catch(function(){renderAll();});

  function fmt(c){return new Intl.NumberFormat('es-CO',{style:'currency',currency:'COP',minimumFractionDigits:0}).format(c/100);}

  // ── VARIANT RESOLVER ──
  function getVariant(card){
    var raw=card.querySelector('.hlp__variants-data');
    if(!raw)return null;
    var vv=JSON.parse(raw.textContent);
    var col=(card.querySelector('.hlp__color-val')||{}).value||'';
    var sz=(card.querySelector('.hlp__size-val')||{}).value||'';
    var v=vv.find(function(v){
      var hc=!col||v.options.indexOf(col)>-1;
      var hs=!sz||v.options.indexOf(sz)>-1;
      return hc&&hs;
    });
    if(!v&&col)v=vv.find(function(v){return v.options.indexOf(col)>-1;});
    return v||vv[0];
  }

  // ── IMAGE SWAP on color change ──
  function swapCardImage(card,colorVal){
    var raw=card.querySelector('.hlp__variants-data');if(!raw)return;
    var vv=JSON.parse(raw.textContent);
    var v=vv.find(function(v){return v.options.indexOf(colorVal)>-1;});
    if(!v||!v.featured_image||!v.featured_image.src)return;
    var img=card.querySelector('.hlp__card-img');if(!img)return;
    var src=v.featured_image.src.split('?')[0].replace(/(\.[a-z]+)$/i,'_400x$1');
    img.style.opacity='0';
    var ni=new Image();
    ni.onload=function(){img.src=src;img.style.opacity='1';};
    ni.onerror=function(){img.style.opacity='1';};
    ni.src=src;
  }

  // ── RENDER SUMMARY ──
  // ── PASOS SLIM: actualiza estado + oculta scroll hint ──
  function updateStepsBar(n){
    var s1=document.getElementById('hlpStep1'),s2=document.getElementById('hlpStep2'),s3=document.getElementById('hlpStep3');
    if(!s1)return;
    function set(el,state){
      el.classList.remove('hlp__step--active','hlp__step--done');
      if(state)el.classList.add(state);
    }
    if(n===0){set(s1,'hlp__step--active');set(s2,'');set(s3,'');}
    else if(n===1){
      set(s1,'hlp__step--done');set(s2,'hlp__step--active');set(s3,'');
      // ocultar scroll hint cuando ya eligió 1 par
      var sh=document.getElementById('hlpScrollHint');if(sh)sh.style.display='none';
    }
    else{set(s1,'hlp__step--done');set(s2,'hlp__step--done');set(s3,'hlp__step--active');}
  }

  // ── URGENCY: poner timer en rojo si quedan < 60 minutos ──
  function checkUrgency(){
    try{
      var endT=parseInt(sessionStorage.getItem('hlp_te'));
      if(!endT)return;
      var remMs=endT-Date.now();
      if(remMs>0&&remMs<3600000){
        document.querySelectorAll('#hlpH,#hlpM,#hlpS').forEach(function(el){
          el.classList.add('urgent');
        });
      }
    }catch(e){}
  }
  setTimeout(checkUrgency,500);

  function renderSummary(){
    var items=Object.values(selected),count=items.length;
    var ce=document.getElementById('hlpCount'),fe=document.getElementById('hlpFill'),he=document.getElementById('hlpProgressHint');
    if(ce)ce.textContent=count;
    if(fe)fe.style.width=(count/BUNDLE_QTY*100)+'%';
    updateStepsBar(count);
    if(he){
      if(count>=BUNDLE_QTY)he.textContent='Listo para confirmar!';
      else if(count===0)he.textContent='Toca una foto para comenzar';
      else{var r=BUNDLE_QTY-count;he.textContent='Falta '+r+' par'+(r>1?'es':'')+' mas!';}
    }
    var ie=document.getElementById('hlpItems'),pe=document.getElementById('hlpPricing'),ce2=document.getElementById('hlpCTA'),ct=document.getElementById('hlpCTAText');
    var orig=items.reduce(function(s,i){return s+(i.price||0);},0);
    if(ie){
      if(count>0){
        ie.innerHTML=items.map(function(i){
          return '<div class="hlp__summary-item"><img src="'+i.img+'" class="hlp__summary-thumb" alt=""><div class="hlp__summary-info"><div class="hlp__summary-name">'+i.title+'</div><div class="hlp__summary-meta">'+[i.color,i.size].filter(Boolean).join(' · ')+'</div></div><div class="hlp__summary-price">'+fmt(i.price)+'</div></div>';
        }).join('');
      }else{ie.innerHTML='<p class="hlp__summary-empty">Selecciona 2 pares para activar el precio especial</p>';}
    }
    if(count>=BUNDLE_QTY){
      if(pe){pe.style.display='flex';var oe=document.getElementById('hlpOrig'),se=document.getElementById('hlpSave');if(oe)oe.textContent=fmt(orig);if(se)se.textContent=orig>BUNDLE_PRICE?'- '+fmt(orig-BUNDLE_PRICE):'Precio especial 2x1';}
      if(ce2)ce2.disabled=false;
      if(ct)ct.textContent='Confirmar pedido — $159.900';
    }else{
      if(pe)pe.style.display='none';
      if(ce2)ce2.disabled=true;
      if(ct){var rem=BUNDLE_QTY-count;ct.textContent='Selecciona '+rem+' par'+(rem>1?'es':'')+' mas';}
    }
  }

  // ── RENDER FLOAT CART ──
  function renderFloat(){
    var items=Object.values(selected),count=items.length;
    var fc=document.getElementById('hlpFloatCart'),fct=document.getElementById('hlpFloatCount');
    var fb=document.getElementById('hlpFloatBtn'),ft=document.getElementById('hlpFloatBtnText');
    var st=document.getElementById('hlpStickyCTA');
    var fcSocial=document.getElementById('hlpFcSocial'),fcSocialTxt=document.getElementById('hlpFcSocialTxt');
    if(fct)fct.textContent=count;
    if(fc){if(count>0){fc.classList.add('hlp--fc-visible');if(st)st.classList.remove('hlp--visible');
      /* Show social proof when floatcart appears */
      if(fcSocial){fcSocial.style.display='flex';
        var proofMsgs=['🔥 '+(Math.floor(Math.random()*8)+3)+' personas están comprando ahora','⚡ Última unidad de este estilo','🛒 '+(Math.floor(Math.random()*15)+20)+' pedidos hoy','✅ Stock limitado — reserva el tuyo'];
        var proofIdx=0;setInterval(function(){fcSocialTxt.textContent=proofMsgs[proofIdx%proofMsgs.length];proofIdx++;},4000);
      }
    }else fc.classList.remove('hlp--fc-visible');}
    for(var i=0;i<2;i++){
      var slot=document.getElementById('hlpSlot'+i);if(!slot)continue;
      if(i>=BUNDLE_QTY){slot.style.display='none';continue;}
      slot.style.display='';
      var item=items[i];
      if(item){
        slot.className='hlp__floatslot hlp__floatslot--filled';
        slot.innerHTML='<img src="'+item.img+'" class="hlp__floatslot-img" alt=""><div class="hlp__floatslot-chk">&#10003;</div><div class="hlp__floatslot-name">'+item.title.split(' ').slice(0,2).join(' ')+'</div>';
      }else{
        slot.className='hlp__floatslot hlp__floatslot--empty';
        slot.innerHTML='<div class="hlp__floatslot-inner"><span class="hlp__floatslot-num">'+(i+1)+'</span><span class="hlp__floatslot-lbl">Par '+(i+1)+'</span></div>';
      }
    }
    if(fb&&ft){
      if(count>=BUNDLE_QTY){fb.disabled=false;fb.classList.add('hlp--fc-ready');ft.textContent='Confirmar — $159.900';}
      else{fb.disabled=true;fb.classList.remove('hlp--fc-ready');var r2=BUNDLE_QTY-count;ft.textContent='Selecciona '+r2+' par'+(r2>1?'es':'')+' mas';}
    }
  }

  function renderAll(){renderSummary();renderFloat();}

  // ── STICKY scroll ──
  var stEl=document.getElementById('hlpStickyCTA'),bEl=document.getElementById('hlp-bundle');
  window.addEventListener('scroll',function(){
    if(!stEl||!bEl)return;
    if(Object.keys(selected).length===0&&bEl.getBoundingClientRect().top<-80)stEl.classList.add('hlp--visible');
    else stEl.classList.remove('hlp--visible');
  },{passive:true});

  // ── COLOR SWATCHES (card) ──
  document.querySelectorAll('.hlp__swatch').forEach(function(sw){
    sw.addEventListener('click',function(){
      var card=this.closest('.hlp__card'),pid=card.dataset.pid;
      card.querySelectorAll('.hlp__swatch').forEach(function(s){s.classList.remove('hlp__swatch--active');});
      this.classList.add('hlp__swatch--active');
      var val=this.dataset.value;
      var ci=card.querySelector('.hlp__color-val');if(ci)ci.value=val;
      var cl=document.getElementById('hlpColorLbl-'+pid);if(cl)cl.textContent=val;
      swapCardImage(card,val);
      if(selected[pid]){
        selected[pid].color=val;
        var v=getVariant(card);if(v){selected[pid].variantId=v.id;selected[pid].price=v.price;}
        var img=card.querySelector('.hlp__card-img');if(img)setTimeout(function(){selected[pid].img=img.src;renderAll();},300);
        else renderAll();
      }
    });
  });

  // ── SIZE BUTTONS (card) ──
  document.querySelectorAll('.hlp__size-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var card=this.closest('.hlp__card'),pid=card.dataset.pid;
      card.querySelectorAll('.hlp__size-btn').forEach(function(b){b.classList.remove('hlp__size-btn--active');});
      this.classList.add('hlp__size-btn--active');
      var val=this.dataset.value;
      var si=card.querySelector('.hlp__size-val');if(si)si.value=val;
      var sl=document.getElementById('hlpSizeLbl-'+pid);if(sl)sl.textContent=val;
      if(selected[pid]){selected[pid].size=val;var v=getVariant(card);if(v){selected[pid].variantId=v.id;selected[pid].price=v.price;}renderAll();}
    });
  });

  // ── SELECT BUTTON (card) ──
  document.querySelectorAll('.hlp__select-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var card=this.closest('.hlp__card'),pid=card.dataset.pid;
      var icon=this.querySelector('.hlp__select-btn-icon'),lbl=this.querySelector('.hlp__select-btn-lbl');
      if(card.classList.contains('hlp--selected')){
        card.classList.remove('hlp--selected');
        if(icon)icon.textContent='+';if(lbl)lbl.textContent='Seleccionar este par';
        delete selected[pid];
      }else if(Object.keys(selected).length<BUNDLE_QTY){
        var si=card.querySelector('.hlp__size-val');
        if(si&&!si.value){
          var sb=card.querySelector('.hlp__size-btns');
          if(sb){sb.classList.add('hlp--shake');setTimeout(function(){sb.classList.remove('hlp--shake');},400);}
          if(lbl){lbl.textContent='Elige tu talla primero';setTimeout(function(){lbl.textContent='Seleccionar este par';},1500);}
          return;
        }
        card.classList.add('hlp--selected');
        if(icon)icon.textContent='&#10003;';if(lbl)lbl.textContent='Seleccionado!';
        var v=getVariant(card),img=card.querySelector('.hlp__card-img'),ci=card.querySelector('.hlp__color-val'),ssi=card.querySelector('.hlp__size-val');
        selected[pid]={variantId:(v&&v.id)||card.querySelector('.hlp__vid').value,price:(v&&v.price)||0,title:card.querySelector('.hlp__card-name').textContent.trim(),img:(img&&img.src)||'',color:(ci&&ci.value)||'',size:(ssi&&ssi.value)||''};
        if(Object.keys(selected).length>=BUNDLE_QTY)setTimeout(function(){if(!adding)doAddToCart(null,document.getElementById('hlpCTAText'));},400);
      }else{if(lbl){var o=lbl.textContent;lbl.textContent='Max 2 pares';setTimeout(function(){lbl.textContent=o;},1400);}}
      renderAll();
    });
  });

  // ── CTA BUTTONS ──
  var ctaFixed=document.getElementById('hlpCTA');if(ctaFixed)ctaFixed.addEventListener('click',function(){doAddToCart(this,document.getElementById('hlpCTAText'));});
  var ctaFloat=document.getElementById('hlpFloatBtn');if(ctaFloat)ctaFloat.addEventListener('click',function(){doAddToCart(this,document.getElementById('hlpFloatBtnText'));});

  function doAddToCart(btn,textEl){
    if(Object.keys(selected).length<BUNDLE_QTY||adding)return;
    adding=true;
    var items=Object.values(selected).map(function(i){return{id:parseInt(i.variantId),quantity:1};});
    if(btn)btn.disabled=true;if(textEl)textEl.textContent='Agregando...';
    if(!window.HamsaBundle||!window.HamsaBundle.addToCart){adding=false;setTimeout(function(){doAddToCart(btn,textEl);},400);return;}
    window.HamsaBundle.addToCart(items,{
      onSuccess:function(){adding=false;if(textEl)textEl.textContent='Listo! Revisa tu carrito';if(btn){btn.style.background='#00c853';btn.style.color='#fff';}var dr=document.querySelector('cart-drawer-component');if(dr&&typeof dr.open==='function')dr.open();},
      onError:function(m){adding=false;if(textEl)textEl.textContent=m||'Error — intenta de nuevo';if(btn){btn.disabled=false;btn.style.background='';}}
    });
  }

  // ── WA ──
  var wa=document.querySelector('.hlp__wa-btn--js');
  if(wa){var ph=wa.getAttribute('data-wa-phone')||'573508258757';wa.href='https://wa.me/'+ph.replace(/[^0-9]/g,'')+'?text='+encodeURIComponent('Hola Hamsa Shoes! Quiero la OFERTA 2x1 — 2 pares por $159.900 con envio gratis y pago contra entrega. Me ayudan a elegir?');}

  // ═══════════════════════════════════════════════
  // PHOTO ZOOM MODAL — all in same scope
  // ═══════════════════════════════════════════════
  var modal     = document.getElementById('hlpModal');
  var mBackdrop = document.getElementById('hlpModalBackdrop');
  var mSheet    = document.getElementById('hlpModalSheet');
  var mClose    = document.getElementById('hlpModalClose');
  var mTitle    = document.getElementById('hlpModalTitle');
  var mTrack    = document.getElementById('hlpModalTrack');
  var mThumbs   = document.getElementById('hlpModalThumbs');
  var mDots     = document.getElementById('hlpModalDots');
  var mCounter  = document.getElementById('hlpModalCounter');
  var mPrev     = document.getElementById('hlpModalPrev');
  var mNext     = document.getElementById('hlpModalNext');
  var mColorWrap= document.getElementById('hlpModalColorWrap');
  var mColorBtns= document.getElementById('hlpModalColorBtns');
  var mColorVal = document.getElementById('hlpModalColorVal');
  var mSizeWrap = document.getElementById('hlpModalSizeWrap');
  var mSizeBtns = document.getElementById('hlpModalSizeBtns');
  var mSizeVal  = document.getElementById('hlpModalSizeVal');
  var mUrgency  = document.getElementById('hlpModalUrgency');
  var mUrgIcon  = document.getElementById('hlpModalUrgIcon');
  var mUrgTitle = document.getElementById('hlpModalUrgTitle');
  var mUrgMsg   = document.getElementById('hlpModalUrgMsg');
  var mCTA      = document.getElementById('hlpModalCTA');
  var mCTAText  = document.getElementById('hlpModalCTAText');

  if(!modal){renderAll();return;}

  var mPid='', mImages=[], mSizes=[], mColors=[], mSlide=0, mSize='', mColor='', mTx=0, mTouchX=0, mDragging=false, mDone=false;

  // ── OPEN ──
  function openModal(wrap){
    mPid   = wrap.dataset.pid;
    mDone  = false;
    mSlide = 0;
    mSize  = '';
    mColor = '';
    mColors = [];

    // Read images from script tag (safe, no attribute encoding issues)
    var card = document.querySelector('.hlp__card[data-pid="'+mPid+'"]');
    var imgsTag = card && card.querySelector('.hlp__imgs-data');
    var szTag   = card && card.querySelector('.hlp__sizes-data');
    try{mImages = imgsTag ? JSON.parse(imgsTag.textContent) : [];}catch(e){mImages=[];}
    try{mSizes  = szTag  ? JSON.parse(szTag.textContent)  : [];}catch(e){mSizes=[];}

    // Fallback: use card featured image if no images
    if(!mImages.length){
      var fi=card&&card.querySelector('.hlp__card-img');
      if(fi)mImages=[{src:fi.src,thumb:fi.src}];
    }

    mTitle.textContent = wrap.dataset.title||'';

    // Build slides
    mTrack.innerHTML='';
    mImages.forEach(function(img,i){
      var sl=document.createElement('div');
      // First slide visible by default; rest hidden via CSS
      sl.className='hlp__modal-slide'+(i===0?' hlp--active':'');
      var im=document.createElement('img');
      im.src=img.src;im.alt='foto '+(i+1);
      im.loading=i===0?'eager':'lazy';
      sl.appendChild(im);mTrack.appendChild(sl);
    });

    // Thumbnails
    mThumbs.innerHTML='';
    if(mImages.length>1){
      mImages.forEach(function(img,i){
        var t=document.createElement('div');t.className='hlp__modal-thumb'+(i===0?' hlp--active':'');
        var ti=document.createElement('img');ti.src=img.thumb||img.src;ti.loading='lazy';
        t.appendChild(ti);t.addEventListener('click',function(){goSlide(i);});
        mThumbs.appendChild(t);
      });
    }

    // Dots
    mDots.innerHTML='';
    if(mImages.length>1){
      mImages.forEach(function(_,i){
        var d=document.createElement('span');d.className='hlp__modal-dot'+(i===0?' hlp--active':'');
        d.addEventListener('click',function(){goSlide(i);});
        mDots.appendChild(d);
      });
    }

    // Size buttons
    mSizeBtns.innerHTML='';mSizeVal.textContent='';
    if(mSizes.length>0){
      mSizeWrap.style.display='block';
      var existingSize=(card&&card.querySelector('.hlp__size-val')||{}).value||'';
      mSizes.forEach(function(sz){
        var b=document.createElement('button');b.type='button';b.className='hlp__modal-size-btn';
        b.textContent=sz;b.dataset.sz=sz;
        if(sz===existingSize){b.classList.add('hlp--active');mSize=sz;mSizeVal.textContent=sz;}
        b.addEventListener('click',function(){
          mSizeBtns.querySelectorAll('.hlp__modal-size-btn').forEach(function(x){x.classList.remove('hlp--active');});
          this.classList.add('hlp--active');
          mSize=this.dataset.sz;mSizeVal.textContent=mSize;
          updateModalCTA();
        });
        mSizeBtns.appendChild(b);
      });
    }else{
      mSizeWrap.style.display='none';
      mSize='__nosizeopt__';
    }

    // ── Color buttons in modal ──
    mColorBtns.innerHTML='';
    if(mColorWrap) mColorWrap.style.display='none';
    var colorSwatches = card && card.querySelectorAll('.hlp__swatch');
    if(colorSwatches && colorSwatches.length > 0){
      // Build color list from swatches on the card
      mColors = [];
      colorSwatches.forEach(function(sw){ mColors.push({val:sw.dataset.value, bg:sw.style.background}); });
      if(mColors.length > 1){
        mColorWrap.style.display='block';
        // Current selected color on card
        var activeSw = card.querySelector('.hlp__swatch--active');
        var existingColor = activeSw ? activeSw.dataset.value : mColors[0].val;
        mColor = existingColor;
        if(mColorVal) mColorVal.textContent = mColor;

        mColors.forEach(function(c){
          var btn = document.createElement('button');
          btn.type='button';
          btn.className='hlp__modal-color-btn'+(c.val===mColor?' hlp--active':'');
          btn.dataset.colorVal=c.val;

          var swatch = document.createElement('div');
          swatch.className='hlp__modal-color-swatch';
          swatch.style.background=c.bg;
          if(c.bg==='#f5f0e8'||c.bg.toLowerCase()==='#fff'||c.bg.toLowerCase()==='white'){
            swatch.style.border='3px solid rgba(255,255,255,.35)';
          }

          var lbl = document.createElement('span');
          lbl.className='hlp__modal-color-lbl';
          lbl.textContent=c.val;

          btn.appendChild(swatch);
          btn.appendChild(lbl);

          btn.addEventListener('click',function(){
            mColorBtns.querySelectorAll('.hlp__modal-color-btn').forEach(function(x){x.classList.remove('hlp--active');});
            this.classList.add('hlp--active');
            mColor = this.dataset.colorVal;
            if(mColorVal) mColorVal.textContent=mColor;

            // Sync swatch on card
            var cardSwatches = card.querySelectorAll('.hlp__swatch');
            cardSwatches.forEach(function(sw){
              sw.classList.toggle('hlp__swatch--active', sw.dataset.value===mColor);
            });
            var ci=card.querySelector('.hlp__color-val');
            if(ci) ci.value=mColor;
            var cl=document.getElementById('hlpColorLbl-'+mPid);
            if(cl) cl.textContent=mColor;

            // Swap modal main image using variant featured_image
            swapModalImage(mColor);
          });

          mColorBtns.appendChild(btn);
        });
      }
    }

    // Already selected?
    var alreadySel=card&&card.classList.contains('hlp--selected');
    if(alreadySel){
      mDone=true;
      mCTA.className='hlp__modal-cta hlp--done';
      mCTA.disabled=false;
      mCTAText.textContent='Ya seleccionado — toca para cerrar';
      showModalUrgency();
    }else{
      mUrgency.style.display='none';
      mCTA.className='hlp__modal-cta';
      mCTA.disabled=true;
      updateModalCTA();
    }

    goSlide(0);
    document.body.style.overflow='hidden';
    modal.classList.add('hlp--open');
    mSheet.classList.remove('hlp--closing');
  }

  function updateModalCTA(){
    var ready=mSize!=='';
    mCTA.disabled=!ready;
    if(ready&&!mDone){
      mCTA.classList.add('hlp--ready');
      mCTAText.textContent='Agregar talla '+mSize+' a mi pedido';
    }else if(!ready){
      mCTA.classList.remove('hlp--ready');
      mCTAText.textContent='Elige tu talla para continuar';
    }
  }

  function showModalUrgency(){
    var count=Object.keys(selected).length,need=BUNDLE_QTY;
    mUrgency.style.display='flex';
    if(count>=need){
      mUrgIcon.textContent='&#9989;';mUrgTitle.textContent='Pedido completo!';
      mUrgMsg.textContent='Tienes '+need+' pares. Confirma tu compra abajo.';
      mUrgency.style.borderColor='rgba(0,200,83,.5)';
      mUrgency.style.background='linear-gradient(135deg,rgba(0,200,83,.12),rgba(0,200,83,.04))';
      mUrgTitle.style.color='#00c853';
    }else{
      var rem=need-count;
      mUrgIcon.textContent='&#127881;';
      mUrgTitle.textContent='Par '+count+' seleccionado!';
      mUrgMsg.textContent='Ahora elige tu '+( count===1?'2do':'otro')+' par — Oferta 2x1 activa al tener '+need+'. Pocas unidades!';
      mUrgency.style.borderColor='rgba(201,169,110,.45)';
      mUrgency.style.background='linear-gradient(135deg,rgba(201,169,110,.15),rgba(201,169,110,.05))';
      mUrgTitle.style.color='#D4527A';
    }
  }

  // ── CONFIRM from modal ──
  mCTA.addEventListener('click',function(){
    if(mDone){closeModal();return;}
    if(!mSize)return;

    var card=document.querySelector('.hlp__card[data-pid="'+mPid+'"]');
    if(!card){closeModal();return;}

    // Apply size to card
    var si=card.querySelector('.hlp__size-val');if(si)si.value=mSize;
    var sl=document.getElementById('hlpSizeLbl-'+mPid);if(sl)sl.textContent=mSize;
    card.querySelectorAll('.hlp__size-btn').forEach(function(b){b.classList.toggle('hlp__size-btn--active',b.dataset.value===mSize);});

    // Select the product if not already selected
    if(!card.classList.contains('hlp--selected')&&Object.keys(selected).length<BUNDLE_QTY){
      card.classList.add('hlp--selected');
      var icon=card.querySelector('.hlp__select-btn-icon'),lbl=card.querySelector('.hlp__select-btn-lbl');
      if(icon)icon.textContent='&#10003;';if(lbl)lbl.textContent='Seleccionado!';
      var v=getVariant(card),img=card.querySelector('.hlp__card-img'),ci=card.querySelector('.hlp__color-val');
      // Apply chosen color from modal to card before building selected
      if(mColor){
        var ci2=card.querySelector('.hlp__color-val');if(ci2)ci2.value=mColor;
        var cl2=document.getElementById('hlpColorLbl-'+mPid);if(cl2)cl2.textContent=mColor;
        card.querySelectorAll('.hlp__swatch').forEach(function(sw){sw.classList.toggle('hlp__swatch--active',sw.dataset.value===mColor);});
      }
      selected[mPid]={variantId:(v&&v.id)||card.querySelector('.hlp__vid').value,price:(v&&v.price)||0,title:card.querySelector('.hlp__card-name').textContent.trim(),img:(img&&img.src)||'',color:mColor||(ci&&ci.value)||'',size:mSize};
    }else if(selected[mPid]){
      selected[mPid].size=mSize;
      var v2=getVariant(card);if(v2){selected[mPid].variantId=v2.id;selected[mPid].price=v2.price;}
    }
    renderAll();

    // Show confirmation in modal
    mDone=true;
    mCTA.className='hlp__modal-cta hlp--done';
    mCTAText.textContent='Seleccionado — elige otro par!';
    showModalUrgency();

    // Auto-close and show toast
    setTimeout(function(){
      closeModal();
      showPageToast();
      // If complete, auto-trigger cart
      if(Object.keys(selected).length>=BUNDLE_QTY){
        setTimeout(function(){if(!adding)doAddToCart(null,document.getElementById('hlpCTAText'));},300);
      }
    },1500);
  });

  // ── PAGE TOAST ──
  function showPageToast(){
    var count=Object.keys(selected).length,need=BUNDLE_QTY,done=count>=need;
    var old=document.getElementById('hlpPageToast');if(old)old.remove();
    var t=document.createElement('div');t.id='hlpPageToast';t.className='hlp__toast';
    t.style.borderColor=done?'rgba(0,200,83,.5)':'rgba(201,169,110,.5)';
    var rem=need-count;
    t.innerHTML='<span style="font-size:26px">'+(done?'&#9989;':'&#127881;')+'</span><div>'
      +'<strong style="color:'+(done?'#00c853':'#D4527A')+'">'+(done?'Pedido completo!':'Par '+count+' seleccionado!')+'</strong>'
      +'<span>'+(done?'Confirma tu compra abajo':'Elige '+rem+' par'+(rem>1?'es':'')+' mas para el 2x1 — Quedan pocas unidades!')+'</span>'
      +'</div>';
    document.body.appendChild(t);
    setTimeout(function(){
      t.style.transition='opacity .4s';t.style.opacity='0';
      setTimeout(function(){if(t.parentNode)t.remove();},400);
      if(!done){var b=document.getElementById('hlp-bundle');if(b)b.scrollIntoView({behavior:'smooth',block:'start'});}
      else{var s=document.getElementById('hlpSummary');if(s)s.scrollIntoView({behavior:'smooth',block:'center'});}
    },2800);
  }

  // ── SLIDE NAV ──
  // ── SWAP MODAL MAIN IMAGE by color ──
  function swapModalImage(colorVal){
    var card=document.querySelector('.hlp__card[data-pid="'+mPid+'"]');
    if(!card) return;
    var raw=card.querySelector('.hlp__variants-data');
    if(!raw) return;
    var variants;
    try{variants=JSON.parse(raw.textContent);}catch(e){return;}
    // Find first variant matching this color that has a featured_image
    var v=variants.find(function(v){
      return v.options.indexOf(colorVal)>-1 && v.featured_image && v.featured_image.src;
    });
    if(!v||!v.featured_image||!v.featured_image.src) return;
    // Build a proper Shopify CDN URL at 900px width
    var rawSrc = v.featured_image.src;
    // Shopify src already has size — replace with 900x
    var src = rawSrc.split('?')[0].replace(/(_\d+x\d*|_\d*x\d+)(\.[a-z]+)$/i,'$2').replace(/(\.[a-z]+)$/i,'_900x$1');
    // Replace the FIRST slide (index 0) with this image
    var firstSlide = mTrack.querySelector('.hlp__modal-slide');
    if(!firstSlide) return;
    var img = firstSlide.querySelector('img');
    if(!img) return;
    img.style.opacity='0';
    var ni=new Image();
    ni.onload=function(){img.src=ni.src;img.style.opacity='1';};
    ni.onerror=function(){img.style.opacity='1';};
    ni.src=src;
    // Also update first thumbnail
    var firstThumb=mThumbs.querySelector('.hlp__modal-thumb img');
    if(firstThumb){
      var tsrc=rawSrc.split('?')[0].replace(/(_\d+x\d*|_\d*x\d+)(\.[a-z]+)$/i,'$2').replace(/(\.[a-z]+)$/i,'_120x$1');
      firstThumb.src=tsrc;
    }
    // Jump to first slide to show the color image
    goSlide(0);
  }

  function goSlide(n){
    var tot=mImages.length;
    mSlide=Math.max(0,Math.min(n,tot-1));
    // Show/hide slides by class - no translateX, works on any width
    mTrack.querySelectorAll('.hlp__modal-slide').forEach(function(sl,i){
      sl.classList.toggle('hlp--active',i===mSlide);
    });
    if(mCounter)mCounter.textContent=(mSlide+1)+'/'+tot;
    mDots.querySelectorAll('.hlp__modal-dot').forEach(function(d,i){d.classList.toggle('hlp--active',i===mSlide);});
    // Scroll thumb into view
    var thumbs=mThumbs.querySelectorAll('.hlp__modal-thumb');
    thumbs.forEach(function(t,i){t.classList.toggle('hlp--active',i===mSlide);});
    if(thumbs[mSlide])thumbs[mSlide].scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
    if(mPrev)mPrev.disabled=mSlide===0;
    if(mNext)mNext.disabled=mSlide===tot-1;
  }
  if(mPrev)mPrev.addEventListener('click',function(){goSlide(mSlide-1);});
  if(mNext)mNext.addEventListener('click',function(){goSlide(mSlide+1);});

  // ── TOUCH SWIPE on carousel ──
  // Touch swipe on the carousel area
  var car=document.getElementById('hlpModalCarousel');
  if(car){
    var mTouchStartX=0, mTouchStartY=0, mTouchMoved=false;
    car.addEventListener('touchstart',function(e){
      mTouchStartX=e.touches[0].clientX;
      mTouchStartY=e.touches[0].clientY;
      mTouchMoved=false;
    },{passive:true});
    car.addEventListener('touchmove',function(e){
      mTouchMoved=true;
    },{passive:true});
    car.addEventListener('touchend',function(e){
      if(!mTouchMoved)return;
      var dx=e.changedTouches[0].clientX-mTouchStartX;
      var dy=e.changedTouches[0].clientY-mTouchStartY;
      // Only swipe if horizontal movement is dominant
      if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>35){
        dx<0?goSlide(mSlide+1):goSlide(mSlide-1);
      }
      mTouchMoved=false;
    },{passive:true});
  }

  // ── CLOSE ──
  function closeModal(){
    mSheet.classList.add('hlp--closing');
    setTimeout(function(){modal.classList.remove('hlp--open');document.body.style.overflow='';},250);
  }
  if(mClose)mClose.addEventListener('click',closeModal);
  if(mBackdrop)mBackdrop.addEventListener('click',closeModal);
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&modal.classList.contains('hlp--open'))closeModal();});

  // ── BIND card image clicks ──
  document.querySelectorAll('.hlp__card-img-wrap').forEach(function(wrap){
    wrap.addEventListener('click',function(e){
      // Block if clicking overlay checkmark
      if(e.target.closest('.hlp__card-overlay'))return;
      openModal(this);
    });
  });

  renderAll();
})();
</script>

