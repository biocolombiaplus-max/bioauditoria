<section class="hhcta-section" id="HamsaCTA-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --gold: {{ section.settings.gold_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --btn-bg: {{ section.settings.btn_bg }};
  --btn-text: {{ section.settings.btn_text_color }};
  --wa: {{ section.settings.wa_color }};
">
  <div class="hhcta-inner">
    {% if section.settings.image != blank %}
      <div class="hhcta-bg">
        {{ section.settings.image | image_url: width: 600, format: 'webp' | image_tag:
          class: 'hhcta-bg-img',
          loading: 'lazy',
          widths: '360, 500, 700',
          sizes: '100vw',
          alt: section.settings.heading | default: 'CTA'
        }}
        <div class="hhcta-overlay"></div>
      </div>
    {% else %}
      <div class="hhcta-bg-solid"></div>
    {% endif %}
    <div class="hhcta-content">
      {% if section.settings.eyebrow != blank %}
        <div class="hhcta-eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="hhcta-title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="hhcta-text">{{ section.settings.text }}</p>
      {% endif %}
      <div class="hhcta-badges">
        {% if section.settings.trust1 != blank %}<span>✓ {{ section.settings.trust1 }}</span>{% endif %}
        {% if section.settings.trust2 != blank %}<span>✓ {{ section.settings.trust2 }}</span>{% endif %}
        {% if section.settings.trust3 != blank %}<span>✓ {{ section.settings.trust3 }}</span>{% endif %}
      </div>
      <div class="hhcta-actions">
        {% if section.settings.btn_text != blank %}
          <a href="{{ section.settings.btn_url }}" class="hhcta-btn hhcta-btn--primary">{{ section.settings.btn_text }}</a>
        {% endif %}
        {% if section.settings.show_wa %}
          <a href="https://wa.me/{{ section.settings.wa_country }}{{ section.settings.wa_number }}" class="hhcta-btn hhcta-btn--wa hamsa-wa-btn" target="_blank" rel="noopener" data-wa-phone="{{ section.settings.wa_country }}{{ section.settings.wa_number }}" data-wa-msg="{{ section.settings.wa_message | escape }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            {{ section.settings.wa_btn_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
#HamsaCTA-{{ section.id }} { overflow: hidden; }
#HamsaCTA-{{ section.id }} * { box-sizing: border-box; }
.hhcta-inner { position: relative; min-height: {{ section.settings.min_height }}px; display: flex; align-items: center; }
.hhcta-bg { position: absolute; inset: 0; z-index: 0; }
.hhcta-bg-img { width:100%; height:100%; object-fit:cover; display:block; }
.hhcta-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,.82) 0%, rgba(0,0,0,.55) 50%, rgba(0,0,0,.3) 100%); }
.hhcta-bg-solid { position: absolute; inset: 0; background: var(--bg); }
.hhcta-content { position: relative; z-index: 1; padding: {{ section.settings.pt }}px 40px {{ section.settings.pb }}px; max-width: 600px; color: var(--text); }
.hhcta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
.hhcta-title { font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; margin: 0 0 16px; color: #fff; }
.hhcta-text { font-size: 15px; color: rgba(255,255,255,.75); line-height: 1.7; margin: 0 0 24px; }
.hhcta-badges { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; font-size: 13px; color: rgba(255,255,255,.75); }
.hhcta-actions { display: flex; flex-wrap: wrap; gap: 12px; }
.hhcta-btn { display:inline-flex; align-items:center; gap:8px; padding:14px 28px; border-radius:8px; font-size:14px; font-weight:700; text-decoration:none; transition:opacity .2s,transform .2s; }
.hhcta-btn--primary { background: var(--btn-bg); color: var(--btn-text); }
.hhcta-btn--primary:hover { opacity:.85; transform:translateY(-2px); }
.hhcta-btn--wa { background: var(--wa); color: #fff; }
.hhcta-btn--wa:hover { opacity:.85; transform:translateY(-2px); }
@media (max-width: 749px) {
  .hhcta-content { padding: {{ section.settings.pt_mobile }}px 20px {{ section.settings.pb_mobile }}px; max-width: 100%; }
  .hhcta-overlay { background: linear-gradient(180deg, rgba(0,0,0,.75) 0%, rgba(0,0,0,.85) 100%); }
  .hhcta-actions { flex-direction: column; }
  .hhcta-btn { width: 100%; justify-content: center; }
  .hhcta-inner { min-height: {{ section.settings.min_height_mobile }}px; }
}
</style>

{% schema %}
{
  "name": "🚀 CTA Final",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagen de fondo" },
    { "type": "text", "id": "eyebrow", "label": "Texto pequeño", "default": "Hamsa Shoes" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Encuentra tus favoritas hoy" },
    { "type": "textarea", "id": "text", "label": "Descripción", "default": "Sandalias elegantes, femeninas y listas para transformar tu look. Compra rápida, segura y con envío gratis." },
    { "type": "text", "id": "trust1", "label": "Beneficio 1", "default": "Envío gratis" },
    { "type": "text", "id": "trust2", "label": "Beneficio 2", "default": "Pago contra entrega" },
    { "type": "text", "id": "trust3", "label": "Beneficio 3", "default": "Colombia y Venezuela" },
    { "type": "text", "id": "btn_text", "label": "Botón texto", "default": "Ver catálogo" },
    { "type": "url", "id": "btn_url", "label": "Botón enlace" },
    { "type": "checkbox", "id": "show_wa", "label": "Mostrar WhatsApp", "default": true },
    { "type": "text", "id": "wa_btn_text", "label": "Texto botón WhatsApp", "default": "Comprar por WhatsApp" },
    { "type": "text", "id": "wa_country", "label": "Código país", "default": "57" },
    { "type": "text", "id": "wa_number", "label": "Número WhatsApp", "default": "3508258757" },
    { "type": "text", "id": "wa_message", "label": "Mensaje WhatsApp", "default": "Hola, quiero comprar en Hamsa Shoes" },
    { "type": "color", "id": "bg_color", "label": "Fondo (si no hay imagen)", "default": "#FDFAF7" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "color", "id": "gold_color", "label": "Acento", "default": "#D4527A" },
    { "type": "color", "id": "btn_bg", "label": "Botón fondo", "default": "#D4527A" },
    { "type": "color", "id": "btn_text_color", "label": "Botón texto", "default": "#FFFFFF" },
    { "type": "color", "id": "wa_color", "label": "WhatsApp color", "default": "#25D366" },
    { "type": "range", "id": "min_height", "label": "Alto mínimo desktop", "min": 300, "max": 700, "step": 20, "default": 480 },
    { "type": "range", "id": "min_height_mobile", "label": "Alto mínimo móvil", "min": 300, "max": 600, "step": 20, "default": 420 },
    { "type": "range", "id": "pt", "label": "Padding top", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pb", "label": "Padding bottom", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pt_mobile", "label": "Padding top móvil", "min": 20, "max": 80, "step": 4, "default": 36 },
    { "type": "range", "id": "pb_mobile", "label": "Padding bottom móvil", "min": 20, "max": 80, "step": 4, "default": 36 }
  ],
  "presets": [{ "name": "🚀 CTA Final" }]
}
{% endschema %}
