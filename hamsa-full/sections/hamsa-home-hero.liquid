<div class="hh-hero" id="HamsaHero-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --gold: {{ section.settings.gold_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --btn-bg: {{ section.settings.btn_bg }};
  --btn-text: {{ section.settings.btn_text_color }};
  --wa: {{ section.settings.wa_color }};
  --radius: {{ section.settings.image_radius }}px;
  --min-h: {{ section.settings.min_height }}px;
">

  <div class="hh-hero__inner">

    <div class="hh-hero__content">

      {% if section.settings.eyebrow != blank %}
        <div class="hh-hero__eyebrow">
          <span class="hh-hero__eyebrow-line"></span>
          {{ section.settings.eyebrow }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="hh-hero__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <p class="hh-hero__sub">{{ section.settings.subtext }}</p>
      {% endif %}

      <div class="hh-hero__trust">
        {% if section.settings.badge1 != blank %}<span class="hh-hero__badge">{{ section.settings.badge1 }}</span>{% endif %}
        {% if section.settings.badge2 != blank %}<span class="hh-hero__badge">{{ section.settings.badge2 }}</span>{% endif %}
        {% if section.settings.badge3 != blank %}<span class="hh-hero__badge">{{ section.settings.badge3 }}</span>{% endif %}
      </div>

      <div class="hh-hero__actions">
        {% if section.settings.btn1_text != blank %}
          <a href="{{ section.settings.btn1_url }}" class="hh-btn hh-btn--primary">
            <span class="hh-btn__shine"></span>
            {{ section.settings.btn1_text }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
        {% if section.settings.btn2_text != blank %}
          <a href="{{ section.settings.btn2_url }}" class="hh-btn hh-btn--outline">
            <span class="hh-btn__shine"></span>
            {{ section.settings.btn2_text }}
          </a>
        {% endif %}
        {% if section.settings.show_whatsapp %}
          <a href="https://wa.me/{{ section.settings.wa_country }}{{ section.settings.wa_number }}" class="hh-btn hh-btn--wa hamsa-wa-btn" target="_blank" rel="noopener" data-wa-phone="{{ section.settings.wa_country }}{{ section.settings.wa_number }}" data-wa-msg="{{ section.settings.wa_message | escape }}">
            <span class="hh-btn__wa-ring"></span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        {% endif %}
      </div>

    </div>

    <div class="hh-hero__media">
      <div class="hh-hero__img-wrap">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 600 | image_tag:
            class: 'hh-hero__img',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '400, 600, 800, 900',
            sizes: '(max-width: 749px) 100vw, 50vw',
            alt: section.settings.image_alt | default: section.settings.heading
          }}
        {% else %}
          <div class="hh-hero__img-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <p>Agrega imagen hero</p>
          </div>
        {% endif %}

        {% if section.settings.floating_badge != blank %}
          <div class="hh-hero__float hh-hero__float--top">
            <span class="hh-hero__float-dot"></span>
            {{ section.settings.floating_badge }}
          </div>
        {% endif %}

        {% if section.settings.floating_stat != blank %}
          <div class="hh-hero__float hh-hero__float--bottom">
            <strong>{{ section.settings.floating_stat }}</strong>
          </div>
        {% endif %}
      </div>
    </div>

  </div>
</div>

<style>
/* ─── GLOBAL PREMIUM BUTTON SYSTEM ─── */
.hh-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 15px 28px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: .05em;
  text-decoration: none;
  white-space: nowrap;
  overflow: hidden;
  cursor: pointer;
  transition: transform .25s cubic-bezier(.34,1.56,.64,1), box-shadow .25s ease, opacity .2s;
}
.hh-btn__shine {
  position: absolute;
  top: 0; left: -75%;
  width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.35), transparent);
  transform: skewX(-20deg);
  animation: hh-shine 3.5s infinite;
}
@keyframes hh-shine {
  0%   { left: -75%; opacity: 0; }
  10%  { opacity: 1; }
  40%  { left: 120%; opacity: 0; }
  100% { left: 120%; opacity: 0; }
}
.hh-btn--primary {
  background: linear-gradient(135deg, #C0405F, #D4527A, #E8748A);
  color: #fff;
  box-shadow: 0 4px 20px rgba(212,82,122,.45), 0 1px 0 rgba(255,255,255,.15) inset;
}
.hh-btn--primary:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 8px 32px rgba(212,82,122,.65), 0 1px 0 rgba(255,255,255,.15) inset;
}
.hh-btn--primary:active { transform: translateY(-1px) scale(.99); }
.hh-btn--outline {
  background: transparent;
  border: 2px solid var(--gold, #D4527A);
  color: var(--gold, #D4527A);
  box-shadow: 0 0 0 0 rgba(212,82,122,.3);
}
.hh-btn--outline:hover {
  background: var(--gold, #D4527A);
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(212,82,122,.4);
}
.hh-btn--wa {
  background: linear-gradient(135deg, #128C7E, #25D366);
  color: #fff;
  box-shadow: 0 4px 20px rgba(37,211,102,.4);
}
.hh-btn--wa:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 8px 32px rgba(37,211,102,.6);
}
.hh-btn__wa-ring {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow: 0 0 0 0 rgba(37,211,102,.5);
  animation: hh-wa-pulse 2.2s cubic-bezier(.4,0,.6,1) infinite;
  pointer-events: none;
}
@keyframes hh-wa-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,.5); }
  70%  { box-shadow: 0 0 0 10px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}

/* ─── HERO ─── */
#HamsaHero-{{ section.id }} {
  background: var(--bg);
  color: var(--text);
  overflow-x: clip;
  width: 100%;
  position: relative;
  font-family: var(--font-body--family, system-ui, sans-serif);
}
#HamsaHero-{{ section.id }}::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 0% 50%, color-mix(in srgb, var(--gold) 10%, transparent), transparent),
    radial-gradient(ellipse 40% 60% at 100% 30%, color-mix(in srgb, var(--gold) 5%, transparent), transparent);
  pointer-events: none;
}
.hh-hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  max-width: 1320px;
  margin: 0 auto;
  padding: {{ section.settings.pt }}px 24px {{ section.settings.pb }}px;
  min-height: var(--min-h);
  position: relative;
  z-index: 1;
}
.hh-hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}
.hh-hero__eyebrow-line {
  width: 28px; height: 2px;
  background: var(--gold);
  border-radius: 1px;
  flex-shrink: 0;
}
.hh-hero__title {
  font-size: clamp(2.2rem, 4.5vw, 3.8rem);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin: 0 0 20px;
  color: var(--text);
}
.hh-hero__sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--muted);
  margin: 0 0 24px;
  max-width: 48ch;
}

/* ─── TRUST BADGES: single clean row ─── */
.hh-hero__trust {
  display: flex;
  flex-wrap: nowrap;
  gap: 8px;
  margin-bottom: 28px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.hh-hero__trust::-webkit-scrollbar { display: none; }
.hh-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11.5px;
  font-weight: 600;
  padding: 6px 13px;
  border-radius: 50px;
  white-space: nowrap;
  flex-shrink: 0;
  background: color-mix(in srgb, var(--gold) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--gold) 25%, transparent);
  color: var(--gold);
}

/* ─── ACTIONS ─── */
.hh-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

/* ─── MEDIA ─── */
.hh-hero__media { position: relative; }
.hh-hero__img-wrap {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  aspect-ratio: 4/5;
  box-shadow: 0 32px 80px rgba(0,0,0,.25);
}
.hh-hero__img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center center;
  display: block;
  transition: transform .5s ease;
}
.hh-hero__img-wrap:hover .hh-hero__img { transform: scale(1.03); }
.hh-hero__img-placeholder {
  width: 100%; height: 100%; min-height: 400px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px;
  background: color-mix(in srgb, var(--gold) 8%, var(--bg));
  color: var(--muted); font-size: 13px;
}

/* ─── FLOATING CARDS ─── */
.hh-hero__float {
  position: absolute;
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(212,82,122,.18);
  border-radius: 14px;
  padding: 10px 16px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 2;
  box-shadow: 0 4px 20px rgba(0,0,0,.08);
}
.hh-hero__float--top { top: 20px; left: -20px; }
.hh-hero__float--bottom { bottom: 20px; right: -16px; }
.hh-hero__float-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #25D366; flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(37,211,102,.25);
  animation: hh-pulse 1.8s infinite;
}
@keyframes hh-pulse {
  0%,100% { box-shadow: 0 0 0 3px rgba(37,211,102,.25); }
  50%      { box-shadow: 0 0 0 8px rgba(37,211,102,0); }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  .hh-hero__inner {
    grid-template-columns: 1fr;
    gap: 0;
    padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
    min-height: unset;
  }
  .hh-hero__media {
    order: -1;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
  .hh-hero__img-wrap { aspect-ratio: 4/5; max-height: 580px; border-radius: 0; }
  .hh-hero__content { padding: 20px 20px 0; }
  .hh-hero__float--top { left: 16px; top: 12px; }
  .hh-hero__float--bottom { right: 16px; bottom: 12px; }
  .hh-hero__title { font-size: clamp(1.8rem, 8vw, 2.8rem); }
  .hh-hero__sub { font-size: 15px; }
  .hh-btn { padding: 14px 22px; font-size: 13px; }
}
@media (max-width: 480px) {
  .hh-hero__actions { flex-direction: column; }
  .hh-btn { width: 100%; justify-content: center; }
  .hh-hero__img-wrap { max-height: 500px; }
}
</style>

{% schema %}
{
  "name": "🏠 Hero Principal",
  "settings": [
    { "type": "header", "content": "🖼️ Imagen" },
    { "type": "image_picker", "id": "hero_image", "label": "Imagen del hero" },
    { "type": "text", "id": "image_alt", "label": "Texto alternativo imagen" },
    { "type": "range", "id": "image_radius", "label": "Redondeo imagen (px)", "min": 0, "max": 40, "step": 2, "default": 20 },
    { "type": "header", "content": "✏️ Texto" },
    { "type": "text", "id": "eyebrow", "label": "Texto pequeño sobre título", "default": "Nueva Colección" },
    { "type": "text", "id": "heading", "label": "Título principal", "default": "Sandalias que elevan tu estilo" },
    { "type": "textarea", "id": "subtext", "label": "Subtexto", "default": "Diseños exclusivos, femeninos y elegantes. Compra fácil con pago contra entrega a todo Colombia." },
    { "type": "header", "content": "🏷️ Badges de confianza" },
    { "type": "text", "id": "badge1", "label": "Badge 1", "default": "🚚 Envío gratis" },
    { "type": "text", "id": "badge2", "label": "Badge 2", "default": "💵 Contra entrega" },
    { "type": "text", "id": "badge3", "label": "Badge 3", "default": "🔒 Compra segura" },
    { "type": "header", "content": "🔘 Botones" },
    { "type": "text", "id": "btn1_text", "label": "Botón 1 texto", "default": "Ver catálogo" },
    { "type": "url", "id": "btn1_url", "label": "Botón 1 enlace" },
    { "type": "text", "id": "btn2_text", "label": "Botón 2 texto", "default": "Ver ofertas" },
    { "type": "url", "id": "btn2_url", "label": "Botón 2 enlace" },
    { "type": "header", "content": "💬 WhatsApp" },
    { "type": "checkbox", "id": "show_whatsapp", "label": "Mostrar botón WhatsApp", "default": true },
    { "type": "text", "id": "wa_country", "label": "Código de país", "default": "57" },
    { "type": "text", "id": "wa_number", "label": "Número WhatsApp", "default": "3508258757" },
    { "type": "text", "id": "wa_message", "label": "Mensaje WhatsApp", "default": "Hola, quiero ver el catálogo de Hamsa Shoes" },
    { "type": "header", "content": "🎫 Tarjetas flotantes" },
    { "type": "text", "id": "floating_badge", "label": "Tarjeta superior (ej: Nueva colección)", "default": "✨ Nueva colección 2025" },
    { "type": "text", "id": "floating_stat", "label": "Tarjeta inferior (ej: +2.000 clientas)", "default": "+2.000 clientas felices" },
    { "type": "header", "content": "🎨 Colores" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "color", "id": "gold_color", "label": "Color dorado/acento", "default": "#D4527A" },
    { "type": "color", "id": "btn_bg", "label": "Fondo botón primario", "default": "#D4527A" },
    { "type": "color", "id": "btn_text_color", "label": "Texto botón primario", "default": "#FFFFFF" },
    { "type": "color", "id": "wa_color", "label": "Color WhatsApp", "default": "#25D366" },
    { "type": "header", "content": "📐 Espaciado" },
    { "type": "range", "id": "min_height", "label": "Alto mínimo (px)", "min": 400, "max": 900, "step": 20, "default": 620 },
    { "type": "range", "id": "pt", "label": "Padding top desktop", "min": 20, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "pb", "label": "Padding bottom desktop", "min": 20, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "pt_mobile", "label": "Padding top móvil", "min": 16, "max": 80, "step": 4, "default": 28 },
    { "type": "range", "id": "pb_mobile", "label": "Padding bottom móvil", "min": 16, "max": 80, "step": 4, "default": 32 }
  ],
  "presets": [{ "name": "🏠 Hero Principal" }]
}
{% endschema %}
