{% comment %}hamsa-product-pro v3 — Fast, Premium, Conversion-First{% endcomment %}
{% if product %}
{%- assign wa_phone = "57" | append: section.settings.wa_number -%}

<div class="hpp3" id="HamsaPro3-{{ section.id }}" style="
  --rose: {{ section.settings.gold_color }};
  --rose2: {{ section.settings.rose2 | default: '#C0405F' }};
  --bg: {{ section.settings.bg_color }};
  --card: {{ section.settings.card_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --green: #00C853;
  --red: #E53E3E;
">

  <!-- ══ URGENCIA COMPACTA ══ -->
  {% if section.settings.show_urgency %}
  <div class="hpp3__urgency">
    <span class="hpp3__urgency-dot"></span>
    <span class="hpp3__urgency-label">{{ section.settings.urgency_label | default: 'Oferta termina en' }}</span>
    <span class="hpp3__timer" id="hpp3Timer-{{ section.id }}">14:59</span>
    <span class="hpp3__urgency-live" id="hpp3Live-{{ section.id }}"></span>
  </div>
  {% endif %}

  <!-- ══ ESTRELLAS + VENTAS ══ -->
  <div class="hpp3__meta">
    <div class="hpp3__stars">
      <span>★★★★★</span>
      <span class="hpp3__reviews">({{ section.settings.reviews_count | default: 87 }} {{ section.settings.reviews_label | default: 'reseñas' }})</span>
    </div>
    <span class="hpp3__sold">🛍️ +{{ section.settings.sold_count | default: 342 }} vendidos</span>
  </div>


  <!-- ══ VISITANTES EN VIVO (neuromarketing) ══ -->
  <div class="hpp3__viewers" id="hpp3Viewers-{{ section.id }}">
    <span class="hpp3__viewers-dot"></span>
    <span id="hpp3ViewCount-{{ section.id }}">12</span> personas están viendo este producto ahora
  </div>

  <!-- ══ TRUST BADGES — 2×2 compacto ══ -->
  <div class="hpp3__trust">
    {% if section.settings.trust1 != blank %}
    <div class="hpp3__trust-item">
      <span class="hpp3__ti-icon">🚚</span>
      <div><strong>{{ section.settings.trust1 }}</strong><span>{{ section.settings.trust1_sub }}</span></div>
    </div>
    {% endif %}
    {% if section.settings.trust2 != blank %}
    <div class="hpp3__trust-item">
      <span class="hpp3__ti-icon">💵</span>
      <div><strong>{{ section.settings.trust2 }}</strong><span>{{ section.settings.trust2_sub }}</span></div>
    </div>
    {% endif %}
    {% if section.settings.trust3 != blank %}
    <div class="hpp3__trust-item">
      <span class="hpp3__ti-icon">🔒</span>
      <div><strong>{{ section.settings.trust3 }}</strong><span>{{ section.settings.trust3_sub }}</span></div>
    </div>
    {% endif %}
    {% if section.settings.trust4 != blank %}
    <div class="hpp3__trust-item">
      <span class="hpp3__ti-icon">↩️</span>
      <div><strong>{{ section.settings.trust4 }}</strong><span>{{ section.settings.trust4_sub }}</span></div>
    </div>
    {% endif %}
  </div>

  <!-- ══ BARRA DE STOCK ══ -->
  {% if section.settings.show_stock_bar %}
  <div class="hpp3__stock">
    <div class="hpp3__stock-top">
      <span class="hpp3__stock-dot"></span>
      <span class="hpp3__stock-txt">{{ section.settings.stock_label | default: '¡Pocas unidades disponibles!' }}</span>
    </div>
    <div class="hpp3__stock-bar">
      <div class="hpp3__stock-fill" style="width:{{ section.settings.stock_pct | default: 23 }}%"></div>
    </div>
    <span class="hpp3__stock-sub">{{ section.settings.stock_sub | default: 'Alta demanda — se agota rápido' }}</span>
  </div>
  {% endif %}

  <!-- ══ GUÍA DE TALLAS ══ -->
  {% if section.settings.show_wa %}
  <button class="hpp3__size-btn" id="hpp3SizeBtn-{{ section.id }}" type="button">
    📏 ¿No sabes tu talla? — Ver guía de tallas →
  </button>

  <!-- MODAL TALLAS -->
  <div id="hpp3SizeModal-{{ section.id }}" class="hpp3__modal-overlay" aria-hidden="true">
    <div class="hpp3__modal-box">
      <div class="hpp3__modal-head">
        <div>
          <div class="hpp3__modal-title">📏 Guía de Tallas — Hamsa Shoes</div>
          <div class="hpp3__modal-sub">Encuentra tu talla en 30 segundos</div>
        </div>
        <button class="hpp3__modal-close" id="hpp3SizeClose-{{ section.id }}" aria-label="Cerrar">✕</button>
      </div>
      <div class="hpp3__modal-body">
        <table class="hpp3__sizes-table">
          <thead>
            <tr><th>Talla</th><th>Pie (cm)</th><th>EUR</th><th>USA</th></tr>
          </thead>
          <tbody>
            <tr><td>35</td><td>22.0 – 22.5</td><td>35</td><td>5</td></tr>
            <tr><td>36</td><td>22.5 – 23.0</td><td>36</td><td>5.5</td></tr>
            <tr><td>37</td><td>23.0 – 23.5</td><td>37</td><td>6.5</td></tr>
            <tr><td>38</td><td>23.5 – 24.0</td><td>38</td><td>7.5</td></tr>
            <tr><td>39</td><td>24.0 – 24.5</td><td>39</td><td>8.5</td></tr>
            <tr><td>40</td><td>24.5 – 25.0</td><td>40</td><td>9</td></tr>
          </tbody>
        </table>
        <div class="hpp3__modal-tip">💡 <strong>Entre dos tallas:</strong> Pie ancho → más grande. Pie estrecho → más pequeña.</div>
        <a href="https://wa.me/{{ wa_phone }}?text={{ 'Hola! Necesito ayuda para elegir mi talla' | url_encode }}"
           target="_blank" rel="noopener" class="hpp3__modal-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Aún con dudas · Escríbenos — respondemos en menos de 1 hora
        </a>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- ══ BOTÓN WHATSAPP ══ -->
  {% if section.settings.show_wa %}
  <a href="https://wa.me/{{ wa_phone }}" class="hpp3__wa" target="_blank" rel="noopener"
     data-wa-phone="{{ wa_phone }}" data-wa-title="{{ product.title | escape }}">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <div class="hpp3__wa-text">
      <strong>{{ section.settings.wa_text | default: 'Pedir por WhatsApp' }}</strong>
      <span>{{ section.settings.wa_sub | default: 'Respuesta inmediata · Pago al recibir' }}</span>
    </div>
    <span class="hpp3__wa-arrow">→</span>
  </a>
  {% endif %}

  <!-- ══ GARANTÍA PREMIUM ══ -->
  {% if section.settings.show_guarantee %}
  <div class="hpp3__guarantee">
    <div class="hpp3__gu-head">
      <span class="hpp3__gu-shield">🛡️</span>
      <div>
        <strong>{{ section.settings.guarantee_title | default: 'Compra 100% garantizada' }}</strong>
        <span>{{ section.settings.guarantee_text | default: 'Si tu pedido no llega o no es el correcto, te lo resolvemos.' }}</span>
      </div>
    </div>
    <div class="hpp3__gu-items">
      <div class="hpp3__gu-item"><span>✅</span> Pago solo cuando llega a tu puerta</div>
      <div class="hpp3__gu-item"><span>✅</span> Cambio de talla sin costo adicional</div>
      <div class="hpp3__gu-item"><span>✅</span> Envío gratis a toda Colombia</div>
      <div class="hpp3__gu-item"><span>✅</span> Soporte WhatsApp en menos de 1 hora</div>
    </div>
  </div>
  {% endif %}

</div>

<style>
/* ── hpp3 base ── */
.hpp3 { background:var(--bg); color:var(--text); padding:0 0 8px; font-family:var(--font-body--family,system-ui,sans-serif); }
.hpp3 * { box-sizing:border-box; }

/* urgencia */
.hpp3__urgency {
  display:flex; align-items:center; gap:8px; flex-wrap:wrap;
  background:linear-gradient(135deg,#FFF0F4,#FFE4ED);
  border:1.5px solid rgba(212,82,122,.25); border-radius:12px;
  padding:10px 14px; margin:0 0 12px;
}
.hpp3__urgency-dot {
  width:8px; height:8px; border-radius:50%; background:var(--rose); flex-shrink:0;
  animation:hpp3pulse 1.8s infinite;
}
@keyframes hpp3pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.hpp3__urgency-label { font-size:12px; font-weight:600; color:var(--rose); }
.hpp3__timer { font-size:18px; font-weight:800; color:var(--rose); letter-spacing:.05em; font-variant-numeric:tabular-nums; }
.hpp3__urgency-live { font-size:11px; color:#7A6E64; margin-left:auto; }

/* meta */
.hpp3__meta { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:6px; margin:0 0 12px; }
.hpp3__stars { display:flex; align-items:center; gap:6px; }
.hpp3__stars span:first-child { color:#F59E0B; font-size:15px; letter-spacing:1px; }
.hpp3__reviews { font-size:12px; color:var(--muted); }
.hpp3__sold { font-size:11px; font-weight:700; color:var(--rose); background:rgba(212,82,122,.1); border:1px solid rgba(212,82,122,.2); padding:3px 10px; border-radius:20px; }


/* live viewers */
.hpp3__viewers {
  display:flex; align-items:center; gap:7px;
  font-size:12px; color:var(--muted);
  margin:0 0 12px;
  padding:8px 14px;
  background:rgba(74,222,128,.06);
  border:1px solid rgba(74,222,128,.2);
  border-radius:8px;
}
.hpp3__viewers-dot {
  width:7px; height:7px; border-radius:50%;
  background:#4ADE80; flex-shrink:0;
  animation:hpp3pulse 1.5s infinite;
}

/* trust */
.hpp3__trust { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin:0 0 12px; }
.hpp3__trust-item {
  display:flex; align-items:center; gap:9px;
  background:var(--card); border:1px solid rgba(0,0,0,.07);
  border-radius:10px; padding:9px 12px;
  transition:border-color .15s;
}
.hpp3__trust-item:hover { border-color:var(--rose); }
.hpp3__ti-icon { font-size:17px; flex-shrink:0; }
.hpp3__trust-item div { display:flex; flex-direction:column; gap:1px; }
.hpp3__trust-item strong { font-size:11px; font-weight:700; color:var(--text); line-height:1.2; }
.hpp3__trust-item span { font-size:10px; color:var(--muted); }

/* stock */
.hpp3__stock { background:var(--card); border:1px solid rgba(229,62,62,.2); border-radius:10px; padding:11px 14px; margin:0 0 12px; }
.hpp3__stock-top { display:flex; align-items:center; gap:6px; margin-bottom:7px; }
.hpp3__stock-dot { width:7px; height:7px; border-radius:50%; background:var(--red); flex-shrink:0; animation:hpp3pulse 1.5s infinite; }
.hpp3__stock-txt { font-size:12px; font-weight:700; color:var(--red); }
.hpp3__stock-bar { height:5px; background:rgba(0,0,0,.08); border-radius:3px; overflow:hidden; margin-bottom:5px; }
.hpp3__stock-fill { height:100%; background:linear-gradient(90deg,var(--red),#FF6B35); border-radius:3px; }
.hpp3__stock-sub { font-size:10px; color:var(--muted); }

/* size guide */
.hpp3__size-btn {
  width:100%; background:none; border:1.5px dashed var(--rose);
  color:var(--rose); font-size:13px; font-weight:600; padding:10px 16px;
  border-radius:8px; cursor:pointer; font-family:inherit;
  transition:background .15s; margin:0 0 12px; letter-spacing:.2px;
}
.hpp3__size-btn:hover { background:rgba(212,82,122,.06); }

/* modal */
.hpp3__modal-overlay {
  display:none; position:fixed; inset:0; z-index:99998;
  background:rgba(0,0,0,.6); backdrop-filter:blur(3px);
  align-items:center; justify-content:center; padding:16px;
}
.hpp3__modal-overlay.open { display:flex; }
.hpp3__modal-box {
  background:#FDFAF7; border-radius:18px; max-width:460px; width:100%;
  max-height:90vh; overflow-y:auto;
  box-shadow:0 24px 60px rgba(0,0,0,.3);
  animation:hpp3modalIn .28s cubic-bezier(.34,1.56,.64,1);
}
@keyframes hpp3modalIn { from{opacity:0;transform:scale(.9) translateY(12px)} to{opacity:1;transform:scale(1) translateY(0)} }
.hpp3__modal-head {
  background:var(--rose); padding:18px 20px;
  display:flex; align-items:flex-start; justify-content:space-between;
  border-radius:18px 18px 0 0; position:sticky; top:0; z-index:2;
}
.hpp3__modal-title { font-size:15px; font-weight:700; color:#fff; }
.hpp3__modal-sub { font-size:11px; color:rgba(255,255,255,.8); margin-top:2px; }
.hpp3__modal-close {
  background:rgba(255,255,255,.2); border:none; color:#fff; font-size:14px;
  cursor:pointer; width:28px; height:28px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; margin-left:12px;
}
.hpp3__modal-body { padding:20px; }
.hpp3__sizes-table { width:100%; border-collapse:collapse; margin-bottom:14px; border-radius:8px; overflow:hidden; border:1px solid #EDE0D8; }
.hpp3__sizes-table th { background:var(--rose); color:#fff; font-size:11px; letter-spacing:.1em; text-transform:uppercase; padding:10px 12px; text-align:left; }
.hpp3__sizes-table td { padding:10px 12px; font-size:13px; border-bottom:1px solid #F0EAD8; color:var(--text); }
.hpp3__sizes-table tbody tr:nth-child(even) { background:#FDFBF6; }
.hpp3__sizes-table td:first-child { font-size:16px; font-weight:700; }
.hpp3__modal-tip { background:#FFF0F4; border:1px solid rgba(212,82,122,.25); border-radius:8px; padding:10px 12px; font-size:12px; color:var(--text); line-height:1.5; margin-bottom:12px; }
.hpp3__modal-wa {
  display:flex; align-items:center; justify-content:center; gap:8px;
  background:#25D366; color:#fff; padding:13px; border-radius:8px;
  font-size:13px; font-weight:700; text-decoration:none;
  transition:background .15s;
}
.hpp3__modal-wa:hover { background:#1DA851; color:#fff; }

/* WA button */
.hpp3__wa { position:relative; overflow:hidden;
  display:flex; align-items:center; gap:12px; width:100%;
  padding:15px 18px; margin:0 0 10px;
  background:linear-gradient(135deg,#0d6b30,#25D366);
  color:#fff; border-radius:14px; text-decoration:none;
  box-shadow:0 4px 18px rgba(37,211,102,.3);
  transition:transform .15s, box-shadow .15s;
  position:relative; overflow:hidden;
}
.hpp3__wa:hover { transform:translateY(-3px); box-shadow:0 10px 32px rgba(37,211,102,.65); color:#fff; animation:none; }
.hpp3__wa { animation:hmsa-wa-pulse 2.2s cubic-bezier(.4,0,.6,1) infinite; }
.hpp3__wa-text { flex:1; display:flex; flex-direction:column; gap:2px; }
.hpp3__wa-text strong { font-size:14px; font-weight:800; }
.hpp3__wa-text span { font-size:11px; opacity:.85; }
.hpp3__wa-arrow { font-size:18px; font-weight:700; opacity:.8; }

/* guarantee */
.hpp3__gu-head { display:flex; gap:12px; align-items:flex-start; margin-bottom:12px; }
.hpp3__gu-shield { font-size:24px; flex-shrink:0; }
.hpp3__gu-items { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
.hpp3__gu-item { display:flex; align-items:center; gap:5px; font-size:11px; color:var(--text); }
.hpp3__gu-item span { font-size:12px; }
.hpp3__guarantee {
  display:flex; align-items:flex-start; gap:11px;
  background:linear-gradient(135deg,rgba(212,82,122,.06),rgba(212,82,122,.02));
  border:1px solid rgba(212,82,122,.2); border-radius:12px;
  padding:13px 15px; margin:0 0 4px;
}
.hpp3__gu-icon { font-size:22px; flex-shrink:0; margin-top:1px; }
.hpp3__guarantee div { display:flex; flex-direction:column; gap:3px; }
.hpp3__guarantee strong { font-size:12px; font-weight:700; color:var(--rose); }
.hpp3__guarantee span { font-size:11px; color:var(--muted); line-height:1.5; }

@keyframes hmsa-shine {
  0%   { left: -75%; opacity: 0; }
  10%  { opacity: 1; }
  40%  { left: 120%; opacity: 0; }
  100% { left: 120%; opacity: 0; }
}
@keyframes hmsa-wa-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,.5); }
  70%  { box-shadow: 0 0 0 10px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}

</style>

<script>
(function(){

  // Live viewers neuromarketing
  (function(){
    var el = document.getElementById('hpp3ViewCount-{{ section.id }}');
    if (!el) return;
    var base = Math.floor(Math.random() * 8) + 7; // 7-14
    el.textContent = base;
    setInterval(function(){
      var delta = Math.random() > 0.5 ? 1 : -1;
      base = Math.max(4, Math.min(22, base + delta));
      el.textContent = base;
    }, 8000 + Math.random() * 4000);
  })();

  var SID='{{ section.id }}';

  // ── Timer persistente ──────────────────────────────────────────────────
  var te=document.getElementById('hpp3Timer-'+SID);
  if(te){
    var key='hmsatmr_'+SID, stored=localStorage.getItem(key);
    var end = stored ? parseInt(stored) : Date.now() + {{ section.settings.timer_min | default: 14 }}*60000 + {{ section.settings.timer_sec | default: 59 }}*1000;
    if(!stored) localStorage.setItem(key, end);
    function tick(){
      var r=Math.max(0,end-Date.now());
      if(r===0){localStorage.removeItem(key);end=Date.now()+900000;localStorage.setItem(key,end);}
      var m=Math.floor(r/60000),s=Math.floor((r%60000)/1000);
      te.textContent=(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
    }
    tick(); setInterval(tick,1000);
  }

  // ── Visitantes en vivo ────────────────────────────────────────────────
  var le=document.getElementById('hpp3Live-'+SID);
  if(le){
    var names=['Valentina','Camila','Isabella','Natalia','Daniela','Laura','Sofía'];
    var cities=['Bogotá','Medellín','Cali','Barranquilla','Bucaramanga'];
    function updateLive(){
      var n=names[Math.floor(Math.random()*names.length)];
      var c=cities[Math.floor(Math.random()*cities.length)];
      le.textContent=n+' de '+c+' lo está viendo';
    }
    updateLive(); setInterval(updateLive, 8000+Math.random()*4000);
  }

  // ── Modal tallas ──────────────────────────────────────────────────────
  var btn=document.getElementById('hpp3SizeBtn-'+SID);
  var modal=document.getElementById('hpp3SizeModal-'+SID);
  var closeBtn=document.getElementById('hpp3SizeClose-'+SID);
  if(btn&&modal){
    function openM(){modal.classList.add('open');document.body.style.overflow='hidden';}
    function closeM(){modal.classList.remove('open');document.body.style.overflow='';}
    btn.addEventListener('click',openM);
    if(closeBtn)closeBtn.addEventListener('click',closeM);
    modal.addEventListener('click',function(e){if(e.target===modal)closeM();});
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeM();});
  }
})();
</script>

{% schema %}
{
  "name": "Producto Pro",
