{% if section.settings.enabled %}
<div class="hfb2" id="HamsaFloatingBadge" role="complementary" aria-label="Oferta especial 2×1">

  <!-- ══ DESKTOP: tarjeta flotante ══ -->
  <div class="hfb2__desktop">
    <button class="hfb2__close" id="hfb2Close" aria-label="Cerrar oferta">✕</button>

    <a href="{{ section.settings.badge_url | default: '/pages/oferta-2x1' }}" class="hfb2__card">
      <div class="hfb2__strip">
        <span class="hfb2__strip-dot"></span>
        <span>⏰ Oferta · Pocas unidades</span>
      </div>
      <div class="hfb2__body">
        <div class="hfb2__left">
          <div class="hfb2__tag">OFERTA EXCLUSIVA</div>
          <div class="hfb2__deal">
            <span class="hfb2__deal-main">2×1</span>
            <div class="hfb2__deal-prices">
              <span class="hfb2__price">$159.900</span>
              <span class="hfb2__old">$239.800</span>
            </div>
          </div>
          <div class="hfb2__save">🎁 Ahorras $79.900</div>
        </div>
        <div class="hfb2__right">
          <div class="hfb2__timer-label">Termina en</div>
          <div class="hfb2__timer">
            <span class="hfb2__digit" id="hfb2H">23</span>
            <span class="hfb2__colon">:</span>
            <span class="hfb2__digit" id="hfb2M">59</span>
            <span class="hfb2__colon">:</span>
            <span class="hfb2__digit" id="hfb2S">59</span>
          </div>
          <div class="hfb2__cta">
            Ver oferta
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </div>
      <div class="hfb2__trust">
        <span>🚚 Envío gratis</span>
        <span>💵 Contra entrega</span>
        <span>🔒 Seguro</span>
      </div>
    </a>

    <button class="hfb2__tab" id="hfb2Tab" aria-label="Ver oferta 2×1" style="display:none">
      🔥 2×1 $159.900
    </button>
  </div>

  <!-- ══ MOBILE: barra fija inferior ══ -->
  <a href="{{ section.settings.badge_url | default: '/pages/oferta-2x1' }}" class="hfb2__bar" id="hfb2Bar">
    <div class="hfb2__bar-left">
      <span class="hfb2__bar-dot"></span>
      <div class="hfb2__bar-deal">
        <span class="hfb2__bar-2x1">2×1</span>
        <div class="hfb2__bar-prices">
          <span class="hfb2__bar-price">$159.900</span>
          <span class="hfb2__bar-old">$239.800</span>
        </div>
      </div>
    </div>
    <div class="hfb2__bar-timer">
      <span class="hfb2__bar-tdigit" id="hfb2BM">59</span>
      <span class="hfb2__bar-tcolon">:</span>
      <span class="hfb2__bar-tdigit" id="hfb2BS">59</span>
    </div>
    <div class="hfb2__bar-cta">Ver oferta →</div>
    <button class="hfb2__bar-close" id="hfb2BarClose" aria-label="Cerrar">✕</button>
  </a>

</div>

<style>
/* ═══════════════════════════════════
   DESKTOP FLOATING CARD
═══════════════════════════════════ */
.hfb2 {
  font-family: var(--font-body--family, system-ui, sans-serif);
  z-index: 9997;
}

/* Desktop card wrapper */
.hfb2__desktop {
  position: fixed;
  {% if section.settings.position == 'left' %}left: 16px; right: auto;{% else %}right: 16px; left: auto;{% endif %}
  bottom: 88px;
  filter: drop-shadow(0 12px 40px rgba(192,64,95,.5));
}

/* Mobile bar hidden on desktop */
.hfb2__bar { display: none; }

.hfb2__card {
  display: block;
  width: 220px;
  background: linear-gradient(135deg, #C0405F 0%, #D4527A 50%, #B03050 100%);
  border-radius: 18px;
  text-decoration: none;
  color: #fff;
  overflow: hidden;
  border: 1.5px solid rgba(255,255,255,.25);
  animation: hfb2-float 3.5s ease-in-out infinite;
  transition: transform .25s cubic-bezier(.34,1.56,.64,1), filter .25s;
}
.hfb2__card:hover {
  transform: translateY(-4px) scale(1.02);
  filter: drop-shadow(0 18px 50px rgba(192,64,95,.7));
  color: #fff;
}
@keyframes hfb2-float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-7px); }
}

.hfb2__strip {
  background: rgba(0,0,0,.25);
  padding: 5px 10px;
  font-size: 10px; font-weight: 700; letter-spacing: .04em;
  text-transform: uppercase; color: rgba(255,255,255,.95);
  display: flex; align-items: center; gap: 6px;
  white-space: nowrap;
}
.hfb2__strip-dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  background: #4ADE80;
  box-shadow: 0 0 0 0 rgba(74,222,128,.5);
  animation: hfb2-dot 1.5s infinite;
}
@keyframes hfb2-dot {
  0%   { box-shadow: 0 0 0 0 rgba(74,222,128,.5); }
  70%  { box-shadow: 0 0 0 7px rgba(74,222,128,0); }
  100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
}

.hfb2__body { display: flex; align-items: center; gap: 10px; padding: 12px 12px 10px; }
.hfb2__left { flex: 1; }
.hfb2__tag { font-size: 8.5px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.75); margin-bottom: 4px; }
.hfb2__deal { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
.hfb2__deal-main { font-size: 32px; font-weight: 900; line-height: 1; letter-spacing: -.03em; color: #fff; text-shadow: 0 2px 8px rgba(0,0,0,.3); }
.hfb2__deal-prices { display: flex; flex-direction: column; gap: 1px; }
.hfb2__price { font-size: 12px; font-weight: 800; color: #FFD700; line-height: 1.2; }
.hfb2__old  { font-size: 10px; text-decoration: line-through; color: rgba(255,255,255,.55); line-height: 1.2; }
.hfb2__save { font-size: 10px; font-weight: 700; background: rgba(74,222,128,.2); border: 1px solid rgba(74,222,128,.4); color: #6EE7B7; border-radius: 6px; padding: 2px 7px; display: inline-block; }

.hfb2__right { display: flex; flex-direction: column; align-items: center; gap: 4px; flex-shrink: 0; }
.hfb2__timer-label { font-size: 8px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.65); }
.hfb2__timer { display: flex; align-items: center; gap: 2px; }
.hfb2__digit { background: rgba(0,0,0,.3); border-radius: 5px; padding: 3px 5px; font-size: 13px; font-weight: 800; min-width: 22px; text-align: center; color: #fff; line-height: 1; font-variant-numeric: tabular-nums; }
.hfb2__colon { font-size: 13px; font-weight: 800; color: rgba(255,255,255,.6); }
.hfb2__cta { display: flex; align-items: center; gap: 4px; background: #FFD700; color: #1C1208; font-size: 10px; font-weight: 800; padding: 5px 10px; border-radius: 20px; letter-spacing: .04em; white-space: nowrap; margin-top: 2px; transition: background .2s, transform .2s; }
.hfb2__card:hover .hfb2__cta { background: #fff; transform: scale(1.04); }

.hfb2__trust { display: flex; gap: 4px; padding: 0 10px 10px; flex-wrap: wrap; }
.hfb2__trust span { font-size: 9px; font-weight: 600; background: rgba(255,255,255,.15); border-radius: 20px; padding: 3px 7px; color: rgba(255,255,255,.9); white-space: nowrap; }

.hfb2__close {
  position: absolute; top: -8px; right: -8px;
  width: 22px; height: 22px; border-radius: 50%;
  background: #fff; border: 2px solid #D4527A;
  color: #D4527A; font-size: 10px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  z-index: 3; transition: background .2s, color .2s; line-height: 1; padding: 0;
}
.hfb2__close:hover { background: #D4527A; color: #fff; }

.hfb2__tab {
  background: linear-gradient(135deg, #C0405F, #D4527A);
  color: #FFD700; border: none; cursor: pointer;
  padding: 10px 16px; border-radius: 30px;
  font-size: 12px; font-weight: 800;
  box-shadow: 0 4px 20px rgba(192,64,95,.45);
  animation: hfb2-float 3.5s ease-in-out infinite;
  white-space: nowrap; font-family: inherit;
}
.hfb2__tab:hover { transform: scale(1.04); }

/* ═══════════════════════════════════
   MOBILE BOTTOM BAR
═══════════════════════════════════ */
@media (max-width: 767px) {
  /* Ocultar tarjeta desktop en móvil */
  .hfb2__desktop { display: none !important; }

  /* Barra fija inferior */
  .hfb2__bar {
    display: flex;
    align-items: center;
    position: fixed;
    left: 0; right: 0; bottom: 0;
    height: 56px;
    background: linear-gradient(135deg, #B03050 0%, #D4527A 60%, #C0405F 100%);
    color: #fff;
    text-decoration: none;
    padding: 0 12px 0 14px;
    gap: 10px;
    z-index: 9997;
    box-shadow: 0 -3px 20px rgba(192,64,95,.5);
    border-top: 1px solid rgba(255,255,255,.2);
  }

  /* Punto verde pulsante */
  .hfb2__bar-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    background: #4ADE80;
    box-shadow: 0 0 0 0 rgba(74,222,128,.5);
    animation: hfb2-dot 1.5s infinite;
  }

  /* Izquierda: 2×1 + precio */
  .hfb2__bar-left { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .hfb2__bar-deal { display: flex; align-items: center; gap: 7px; }
  .hfb2__bar-2x1 { font-size: 22px; font-weight: 900; line-height: 1; letter-spacing: -.02em; color: #fff; }
  .hfb2__bar-prices { display: flex; flex-direction: column; }
  .hfb2__bar-price { font-size: 13px; font-weight: 800; color: #FFD700; line-height: 1.2; white-space: nowrap; }
  .hfb2__bar-old { font-size: 10px; text-decoration: line-through; color: rgba(255,255,255,.55); line-height: 1.2; white-space: nowrap; }

  /* Centro: timer MM:SS */
  .hfb2__bar-timer { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
  .hfb2__bar-tdigit { background: rgba(0,0,0,.3); border-radius: 4px; padding: 3px 5px; font-size: 13px; font-weight: 800; min-width: 22px; text-align: center; color: #fff; font-variant-numeric: tabular-nums; }
  .hfb2__bar-tcolon { font-size: 13px; font-weight: 800; color: rgba(255,255,255,.7); padding: 0 1px; }

  /* CTA */
  .hfb2__bar-cta {
    flex: 1;
    text-align: right;
    font-size: 13px; font-weight: 800;
    background: #FFD700;
    color: #1C1208;
    padding: 8px 14px;
    border-radius: 24px;
    white-space: nowrap;
    letter-spacing: .01em;
  }

  /* Cerrar */
  .hfb2__bar-close {
    background: none; border: none; color: rgba(255,255,255,.7);
    font-size: 14px; cursor: pointer; padding: 4px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .hfb2__bar-close:hover { color: #fff; }
}

.hfb2--hidden { display: none !important; }
</style>

<script>
(function(){
  var KEY = 'hfb2tmr';
  var SECS = 23 * 3600 + 59 * 60 + 59;

  function loadTimer() {
    try {
      var d = JSON.parse(localStorage.getItem(KEY) || 'null');
      if (d && d.exp > Date.now()) return Math.floor((d.exp - Date.now()) / 1000);
    } catch(e) {}
    var exp = Date.now() + SECS * 1000;
    try { localStorage.setItem(KEY, JSON.stringify({exp:exp})); } catch(e) {}
    return SECS;
  }

  var remaining = loadTimer();
  function pad(n) { return n < 10 ? '0' + n : '' + n; }

  function tick() {
    if (remaining <= 0) { remaining = SECS; try { localStorage.removeItem(KEY); } catch(e) {} }
    var h = Math.floor(remaining / 3600);
    var m = Math.floor((remaining % 3600) / 60);
    var s = remaining % 60;
    /* Desktop digits */
    var dH = document.getElementById('hfb2H');
    var dM = document.getElementById('hfb2M');
    var dS = document.getElementById('hfb2S');
    if (dH) dH.textContent = pad(h);
    if (dM) dM.textContent = pad(m);
    if (dS) dS.textContent = pad(s);
    /* Mobile bar digits (MM:SS only) */
    var bM = document.getElementById('hfb2BM');
    var bS = document.getElementById('hfb2BS');
    if (bM) bM.textContent = pad(m);
    if (bS) bS.textContent = pad(s);
    remaining--;
  }
  tick();
  setInterval(tick, 1000);

  /* ── Desktop close/minimize ── */
  var closeBtn = document.getElementById('hfb2Close');
  var tab      = document.getElementById('hfb2Tab');
  var desktop  = document.querySelector('.hfb2__desktop');
  var card     = desktop ? desktop.querySelector('.hfb2__card') : null;

  if (closeBtn && card) {
    closeBtn.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      card.style.display = 'none';
      closeBtn.style.display = 'none';
      if (tab) tab.style.display = 'flex';
      try { sessionStorage.setItem('hfb2_min', '1'); } catch(err) {}
    });
  }
  if (tab && card) {
    tab.addEventListener('click', function() {
      card.style.display = 'block';
      closeBtn && (closeBtn.style.display = 'flex');
      tab.style.display = 'none';
      try { sessionStorage.removeItem('hfb2_min'); } catch(err) {}
    });
  }
  try {
    if (sessionStorage.getItem('hfb2_min') === '1' && card) {
      card.style.display = 'none';
      closeBtn && (closeBtn.style.display = 'none');
      if (tab) tab.style.display = 'flex';
    }
  } catch(err) {}

  /* ── Mobile bar close ── */
  var barClose = document.getElementById('hfb2BarClose');
  var bar      = document.getElementById('hfb2Bar');
  if (barClose && bar) {
    barClose.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      bar.style.display = 'none';
      try { sessionStorage.setItem('hfb2_bar_closed', '1'); } catch(err) {}
    });
  }
  try {
    if (sessionStorage.getItem('hfb2_bar_closed') === '1' && bar) {
      bar.style.display = 'none';
    }
  } catch(err) {}
})();
</script>
{% endif %}

{% schema %}
{
  "name": "🔥 Badge 2×1 Flotante",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Activar badge flotante", "default": true },
    { "type": "url", "id": "badge_url", "label": "URL al hacer clic", "info": "Ejemplo: /pages/oferta-2x1" },
    {
      "type": "select",
      "id": "position",
      "label": "Posición (escritorio)",
      "options": [
        { "value": "right", "label": "Derecha" },
        { "value": "left", "label": "Izquierda" }
      ],
      "default": "right"
    }
  ],
  "presets": [{ "name": "🔥 Badge 2×1 Flotante" }]
}
{% endschema %}
