  "name": "🛍️ Bundle Oferta",
  "settings": [
    { "type": "header", "content": "🏷️ Configuración del Bundle" },
    { "type": "text", "id": "title", "label": "Título", "default": "🔥 Lleva 2 Pares" },
    { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Elige modelo, talla y color para cada par" },
    { "type": "text", "id": "price_label", "label": "Etiqueta precio", "default": "Precio especial" },
    { "type": "number", "id": "bundle_price", "label": "Precio bundle (centavos COP)", "info": "$159.900 = 15990000", "default": 15990000 },
    { "type": "range", "id": "bundle_qty", "label": "Cantidad de pares", "min": 2, "max": 4, "step": 1, "default": 2 },
    { "type": "text", "id": "savings_label", "label": "Etiqueta ahorro", "default": "¡hasta 30%!" },
    { "type": "text", "id": "progress_hint", "label": "Texto bajo progreso", "default": "Selecciona tus favoritos" },
    { "type": "collection", "id": "bundle_collection", "label": "Colección de productos del bundle", "info": "Si está vacío, usa la colección del producto actual" },
    { "type": "range", "id": "max_products", "label": "Máximo de productos a mostrar", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "header", "content": "🎨 Colores" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "color", "id": "card_color", "label": "Fondo tarjetas", "default": "#FFFFFF" },
    { "type": "color", "id": "border_color", "label": "Borde", "default": "#E8D8CC" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "color", "id": "gold_color", "label": "Dorado", "default": "#D4527A" },
    { "type": "color", "id": "btn_bg", "label": "Botón fondo", "default": "#D4527A" },
    { "type": "color", "id": "btn_text_color", "label": "Botón texto", "default": "#FFFFFF" },
    { "type": "color", "id": "danger_color", "label": "Urgencia/rojo", "default": "#ff4444" }
  ],
  "presets": [{ "name": "🛍️ Bundle Oferta" }]
}
{% endschema %}
