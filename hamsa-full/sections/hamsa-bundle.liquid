{% comment %}hamsa-bundle v3 — Premium 2x1 Bundle, High Conversion{% endcomment %}
{% if product %}
{%- assign bundle_col = collections[section.settings.bundle_collection] -%}
{%- assign bundle_products = nil -%}
{%- if bundle_col != blank and bundle_col.products_count > 0 -%}
  {%- assign bundle_products = bundle_col.products -%}
{%- elsif product.collections.first != blank -%}
  {%- assign bundle_products = product.collections.first.products -%}
{%- endif -%}
{%- assign bundle_price = section.settings.bundle_price | default: 15990000 -%}
{%- assign bundle_qty   = section.settings.bundle_qty   | default: 2 -%}
{%- assign needed_qty   = bundle_qty -%}
{%- if cart.item_count >= 1 -%}{%- assign needed_qty = 1 -%}{%- endif -%}

<section class="hbv3" id="HamsaBundleV3-{{ section.id }}" style="
  --rose:#D4527A; --rose2:#C0405F; --bg:{{ section.settings.bg_color }};
  --card:#FFFFFF; --text:#1C1208; --muted:#7A6E64; --green:#00C853;
">

  <!-- ══ HEADER CON GRADIENTE LLAMATIVO ══ -->
  <div class="hbv3__head">
    <div class="hbv3__head-badge">
      <span class="hbv3__flash">⚡</span>
      <span>OFERTA ESPECIAL</span>
    </div>
    <h2 class="hbv3__head-title">{{ section.settings.title | default: '🔥 Lleva 2 Pares por Solo $159.900' }}</h2>
    <div class="hbv3__head-price">
      <span class="hbv3__price-main">{{ bundle_price | money }}</span>
      <span class="hbv3__price-compare">~~{{ section.settings.compare_price | default: '$239.800' }}~~</span>
      <span class="hbv3__savings-pill">{{ section.settings.savings_label | default: '¡Ahorras $79.900!' }}</span>
    </div>
    <div class="hbv3__head-badges">
      <span>🚚 Envío gratis</span>
      <span>💵 Contra entrega</span>
      <span>↩️ Cambio gratis</span>
    </div>
    <!-- Timer -->
    <div class="hbv3__timer-row">
      <span class="hbv3__timer-dot"></span>
      <span class="hbv3__timer-label">Oferta termina en:</span>
      <span class="hbv3__timer-count" id="hbv3Timer-{{ section.id }}">14:59</span>
    </div>
  </div>

  <!-- ══ CÓMO FUNCIONA — 3 PASOS ══ -->
  <div class="hbv3__steps">
    <div class="hbv3__step">
      <span class="hbv3__step-num">1</span>
      <span>Elige el<br><strong>2do par</strong></span>
    </div>
    <div class="hbv3__step-arrow">→</div>
    <div class="hbv3__step">
      <span class="hbv3__step-num">2</span>
      <span>Elige tu<br><strong>talla</strong></span>
    </div>
    <div class="hbv3__step-arrow">→</div>
    <div class="hbv3__step">
      <span class="hbv3__step-num">3</span>
      <span>¡Precio<br><strong>automático!</strong></span>
    </div>
  </div>

  <!-- ══ PRODUCTO ACTUAL ══ -->
  <div class="hbv3__current">
    <span class="hbv3__current-label">✅ Par 1 seleccionado:</span>
    <span class="hbv3__current-name">{{ product.title | truncate: 50 }}</span>
  </div>

  <!-- ══ GRID DE PRODUCTOS ══ -->
  {% if bundle_products %}
  <div class="hbv3__subtitle">👇 Elige tu 2do par:</div>
  <div class="hbv3__grid" id="hbv3Grid-{{ section.id }}">
    {% for bp in bundle_products limit: section.settings.limit | default: 6 %}
      {%- unless bp.id == product.id -%}
      {%- assign fv = bp.selected_or_first_available_variant -%}
      <div class="hbv3__card" data-product-id="{{ bp.id }}" data-variant-id="{{ fv.id }}" id="hbv3Card-{{ bp.id }}-{{ section.id }}">
        <div class="hbv3__card-img-wrap">
          {% if bp.featured_image %}
            <img src="{{ bp.featured_image | image_url: width: 240, format: 'webp' }}"
                 alt="{{ bp.title | escape }}" loading="lazy" width="240" height="240" decoding="async">
          {% else %}
            <div class="hbv3__card-img-empty">📷</div>
          {% endif %}
          {% if bp.available == false %}
            <div class="hbv3__card-sold">Agotado</div>
          {% endif %}
        </div>
        <div class="hbv3__card-body">
          <div class="hbv3__card-name">{{ bp.title | truncate: 30 }}</div>
          <div class="hbv3__card-price">{{ bp.price | money }}</div>
          <!-- Tallas -->
          <div class="hbv3__card-sizes">
            {% for v in bp.variants %}
              <button class="hbv3__size-opt {% unless v.available %}hbv3__size-opt--out{% endunless %}"
                      data-vid="{{ v.id }}" data-pid="{{ bp.id }}"
                      {% unless v.available %}disabled{% endunless %}
                      type="button">{{ v.title }}</button>
            {% endfor %}
          </div>
          <button class="hbv3__card-select" data-pid="{{ bp.id }}" type="button">
            Seleccionar
          </button>
        </div>
      </div>
      {%- endunless -%}
    {% endfor %}
  </div>
  {% endif %}

  <!-- ══ RESUMEN + CTA ══ -->
  <div class="hbv3__summary" id="hbv3Summary-{{ section.id }}" style="display:none">
    <div class="hbv3__summary-title">🛍️ Resumen de tu pedido</div>
    <div class="hbv3__summary-items">
      <div class="hbv3__summary-item">
        <span>Par 1: <strong>{{ product.title | truncate: 30 }}</strong></span>
        <span>{{ product.price | money }}</span>
      </div>
      <div class="hbv3__summary-item" id="hbv3SummaryPair2-{{ section.id }}">
        <span>Par 2: <strong id="hbv3P2Name-{{ section.id }}">—</strong></span>
        <span id="hbv3P2Price-{{ section.id }}">—</span>
      </div>
    </div>
    <div class="hbv3__summary-total">
      <span>Total especial 2×1:</span>
      <span class="hbv3__summary-price">{{ bundle_price | money }}</span>
    </div>
  </div>

  <button class="hbv3__cta" id="hbv3CTA-{{ section.id }}" type="button" disabled>
    🛍️ {{ section.settings.btn_text | default: 'Agregar 2×1 al carrito' }}
  </button>
  <div class="hbv3__cta-sub">{{ section.settings.btn_sub | default: '⚡ Precio especial aplicado automáticamente' }}</div>

  <!-- Sin selección -->
  <div class="hbv3__hint" id="hbv3Hint-{{ section.id }}">
    👆 Selecciona el 2do par para activar la oferta
  </div>

</section>

<style>
.hbv3 { background:var(--bg); font-family:var(--font-body--family,system-ui,sans-serif); padding:0 0 8px; }
.hbv3 * { box-sizing:border-box; }

/* HEAD */
.hbv3__head {
  background:linear-gradient(135deg,#C0405F,#D4527A,#E8748A);
  border-radius:16px; padding:20px; margin-bottom:16px; color:#fff; text-align:center;
}
.hbv3__head-badge {
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(255,255,255,.2); border-radius:20px;
  padding:4px 12px; font-size:11px; font-weight:800; letter-spacing:.1em;
  text-transform:uppercase; margin-bottom:10px;
}
.hbv3__flash { font-size:14px; animation:hbv3fl .8s infinite alternate; }
@keyframes hbv3fl { from{opacity:.6}to{opacity:1} }
.hbv3__head-title { font-size:clamp(1rem,3.5vw,1.3rem); font-weight:800; margin:0 0 10px; line-height:1.2; }
.hbv3__head-price { display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
.hbv3__price-main { font-size:clamp(1.4rem,4vw,1.8rem); font-weight:900; }
.hbv3__price-compare { font-size:13px; text-decoration:line-through; opacity:.65; }
.hbv3__savings-pill {
  background:#FFD700; color:#000; font-size:12px; font-weight:800;
  padding:3px 12px; border-radius:20px;
}
.hbv3__head-badges {
  display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:8px;
  font-size:12px; font-weight:600; margin-bottom:12px; opacity:.92;
}
.hbv3__head-badges span { background:rgba(255,255,255,.18); padding:3px 10px; border-radius:20px; }
.hbv3__timer-row { display:flex; align-items:center; justify-content:center; gap:7px; font-size:13px; }
.hbv3__timer-dot { width:7px; height:7px; border-radius:50%; background:#fff; animation:hbv3fl 1s infinite; }
.hbv3__timer-label { opacity:.85; }
.hbv3__timer-count { font-size:18px; font-weight:900; font-variant-numeric:tabular-nums; }

/* STEPS */
.hbv3__steps { display:flex; align-items:center; justify-content:center; gap:6px; margin-bottom:12px; }
.hbv3__step { display:flex; flex-direction:column; align-items:center; gap:3px; text-align:center; font-size:11px; color:var(--muted); }
.hbv3__step-num { width:26px; height:26px; border-radius:50%; background:var(--rose); color:#fff; font-size:12px; font-weight:800; display:flex; align-items:center; justify-content:center; }
.hbv3__step strong { color:var(--text); }
.hbv3__step-arrow { font-size:14px; color:var(--rose); font-weight:700; margin-bottom:8px; }

/* CURRENT */
.hbv3__current {
  display:flex; align-items:center; flex-wrap:wrap; gap:6px;
  background:#F0FFF4; border:1px solid rgba(0,200,83,.3);
  border-radius:8px; padding:9px 12px; margin-bottom:12px;
  font-size:12px;
}
.hbv3__current-label { color:var(--green); font-weight:700; flex-shrink:0; }
.hbv3__current-name { color:var(--text); font-weight:600; }

.hbv3__subtitle { font-size:13px; font-weight:700; color:var(--text); margin-bottom:10px; }

/* GRID */
.hbv3__grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin-bottom:14px; }
.hbv3__card {
  background:var(--card); border:2px solid rgba(0,0,0,.07);
  border-radius:12px; overflow:hidden; cursor:pointer;
  transition:border-color .15s, transform .15s, box-shadow .15s;
}
.hbv3__card:hover { border-color:var(--rose); transform:translateY(-2px); box-shadow:0 6px 20px rgba(212,82,122,.15); }
.hbv3__card.selected { border-color:var(--rose); box-shadow:0 0 0 3px rgba(212,82,122,.2); }
.hbv3__card-img-wrap { position:relative; aspect-ratio:1; overflow:hidden; background:#f5f5f5; }
.hbv3__card-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .3s; }
.hbv3__card:hover .hbv3__card-img-wrap img { transform:scale(1.04); }
.hbv3__card-img-empty { display:flex; align-items:center; justify-content:center; height:100%; min-height:100px; font-size:30px; color:#ccc; }
.hbv3__card-sold { position:absolute; inset:0; background:rgba(0,0,0,.5); color:#fff; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; }
.hbv3__card-body { padding:10px; }
.hbv3__card-name { font-size:11px; font-weight:700; color:var(--text); margin-bottom:4px; line-height:1.3; }
.hbv3__card-price { font-size:13px; font-weight:800; color:var(--rose); margin-bottom:8px; }
.hbv3__card-sizes { display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px; }
.hbv3__size-opt {
  padding:3px 7px; border-radius:6px; font-size:10px; font-weight:700;
  border:1.5px solid rgba(0,0,0,.12); background:#fff; cursor:pointer;
  transition:all .12s; font-family:inherit; color:var(--text);
}
.hbv3__size-opt:hover { border-color:var(--rose); color:var(--rose); }
.hbv3__size-opt.active { background:var(--rose); border-color:var(--rose); color:#fff; }
.hbv3__size-opt--out { opacity:.35; cursor:not-allowed; text-decoration:line-through; }
.hbv3__card-select {
  width:100%; padding:7px; background:transparent;
  border:1.5px solid var(--rose); color:var(--rose); border-radius:8px;
  font-size:11px; font-weight:700; cursor:pointer; transition:all .12s; font-family:inherit;
}
.hbv3__card-select:hover, .hbv3__card.selected .hbv3__card-select {
  background:var(--rose); color:#fff;
}

/* SUMMARY */
.hbv3__summary {
  background:#F0FFF4; border:1.5px solid rgba(0,200,83,.3);
  border-radius:12px; padding:14px; margin-bottom:12px;
}
.hbv3__summary-title { font-size:13px; font-weight:700; color:var(--green); margin-bottom:10px; }
.hbv3__summary-item { display:flex; justify-content:space-between; font-size:12px; color:var(--text); margin-bottom:6px; }
.hbv3__summary-total { display:flex; justify-content:space-between; font-size:14px; font-weight:800; color:var(--text); padding-top:8px; border-top:1px solid rgba(0,200,83,.3); margin-top:4px; }
.hbv3__summary-price { color:var(--rose); font-size:16px; }

/* CTA */
.hbv3__cta {
  position:relative; overflow:hidden;
  width:100%; padding:16px; border-radius:14px; border:none;
  background:linear-gradient(135deg,#C0405F,#D4527A);
  color:#fff; font-size:16px; font-weight:800; cursor:pointer;
  font-family:inherit; transition:all .15s; margin-bottom:6px;
  box-shadow:0 4px 18px rgba(212,82,122,.35);
  letter-spacing:.3px;
}
.hbv3__cta:not(:disabled)::after {
  content:''; position:absolute; top:0; left:-75%; width:50%; height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.35),transparent);
  transform:skewX(-20deg); animation:hmsa-shine 3.5s infinite;
}
.hbv3__cta:not(:disabled):hover { transform:translateY(-3px) scale(1.01); box-shadow:0 10px 36px rgba(212,82,122,.65); }
.hbv3__cta:disabled { opacity:.45; cursor:not-allowed; transform:none; box-shadow:none; }
.hbv3__cta-sub { text-align:center; font-size:11px; color:var(--muted); margin-bottom:8px; }
.hbv3__hint { text-align:center; font-size:12px; color:var(--muted); padding:6px; }

@media(max-width:400px) {
  .hbv3__grid { grid-template-columns:1fr 1fr; gap:8px; }
}

@keyframes hmsa-shine {
  0%   { left: -75%; opacity: 0; }
  10%  { opacity: 1; }
  40%  { left: 120%; opacity: 0; }
  100% { left: 120%; opacity: 0; }
}
@keyframes hmsa-wa-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,.5); }
  70%  { box-shadow: 0 0 0 10px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}

</style>

<script>
(function(){
  var SID='{{ section.id }}';
  var BUNDLE_PRICE={{ bundle_price }};
  var PRODUCT1_ID={{ product.id }};
  var PRODUCT1_VID={{ product.selected_or_first_available_variant.id }};

  // Timer
  var te=document.getElementById('hbv3Timer-'+SID);
  if(te){
    var key='hbv3tmr_'+SID, stored=localStorage.getItem(key);
    var end=stored?parseInt(stored):Date.now()+900000;
    if(!stored)localStorage.setItem(key,end);
    function tick(){
      var r=Math.max(0,end-Date.now());
      if(r===0){localStorage.removeItem(key);end=Date.now()+900000;localStorage.setItem(key,end);}
      var m=Math.floor(r/60000),s=Math.floor((r%60000)/1000);
      te.textContent=(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
    }
    tick();setInterval(tick,1000);
  }

  var selectedPID=null, selectedVID=null, selectedName=null, selectedPrice=null;

  // Talla selección
  document.querySelectorAll('#HamsaBundleV3-'+SID+' .hbv3__size-opt').forEach(function(btn){
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      var pid=btn.getAttribute('data-pid');
      // Desmarcar otras tallas del mismo producto
      document.querySelectorAll('#HamsaBundleV3-'+SID+' .hbv3__size-opt[data-pid="'+pid+'"]').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');
      // Si este producto ya estaba seleccionado, actualizar variante
      if(selectedPID==pid){
        selectedVID=btn.getAttribute('data-vid');
        updateSummary();
      }
    });
  });

  // Seleccionar producto
  document.querySelectorAll('#HamsaBundleV3-'+SID+' .hbv3__card-select').forEach(function(btn){
    btn.addEventListener('click',function(e){
      e.stopPropagation();
      var pid=btn.getAttribute('data-pid');
      var card=document.getElementById('hbv3Card-'+pid+'-'+SID);
      // Desmarcar otros
      document.querySelectorAll('#HamsaBundleV3-'+SID+' .hbv3__card').forEach(function(c){c.classList.remove('selected');});
      card.classList.add('selected');
      // Obtener talla activa
      var activeSize=card.querySelector('.hbv3__size-opt.active');
      if(!activeSize){
        // Seleccionar primera talla disponible
        activeSize=card.querySelector('.hbv3__size-opt:not(:disabled)');
        if(activeSize)activeSize.classList.add('active');
      }
      selectedPID=pid;
      selectedVID=activeSize?activeSize.getAttribute('data-vid'):card.getAttribute('data-variant-id');
      selectedName=card.querySelector('.hbv3__card-name').textContent.trim();
      selectedPrice=card.querySelector('.hbv3__card-price').textContent.trim();
      updateSummary();
    });
  });

  // Click en tarjeta también selecciona
  document.querySelectorAll('#HamsaBundleV3-'+SID+' .hbv3__card').forEach(function(card){
    card.addEventListener('click',function(){
      card.querySelector('.hbv3__card-select').click();
    });
  });

  function updateSummary(){
    var sum=document.getElementById('hbv3Summary-'+SID);
    var cta=document.getElementById('hbv3CTA-'+SID);
    var hint=document.getElementById('hbv3Hint-'+SID);
    if(!selectedVID){cta.disabled=true;if(sum)sum.style.display='none';return;}
    if(sum){
      sum.style.display='block';
      var p2name=document.getElementById('hbv3P2Name-'+SID);
      var p2price=document.getElementById('hbv3P2Price-'+SID);
      if(p2name)p2name.textContent=selectedName;
      if(p2price)p2price.textContent=selectedPrice;
    }
    if(hint)hint.style.display='none';
    cta.disabled=false;
  }

  // Add to cart
  document.getElementById('hbv3CTA-'+SID).addEventListener('click',function(){
    if(!selectedVID)return;
    var btn=this;
    btn.disabled=true;
    btn.textContent='Agregando…';
    var items=[
      {id:PRODUCT1_VID,quantity:1},
      {id:parseInt(selectedVID),quantity:1}
    ];
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body:JSON.stringify({items:items,attributes:{'Bundle':'2x1 Hamsa'}})
    })
    .then(function(r){return r.json();})
    .then(function(){
      btn.textContent='✅ ¡Agregado! Yendo al carrito…';
      btn.style.background='linear-gradient(135deg,#0d6b30,#25D366)';
      setTimeout(function(){window.location.href='/cart';},900);
    })
    .catch(function(){
      btn.disabled=false;
      btn.textContent='{{ section.settings.btn_text | default: "Agregar 2×1 al carrito" }}';
    });
  });
})();
</script>

{% schema %}
{
  "name": "Bundle 2×1",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "text", "id": "title", "label": "Título bundle", "default": "🔥 Lleva 2 Pares por Solo $159.900" },
    { "type": "text", "id": "savings_label", "label": "Texto ahorro", "default": "¡Ahorras $79.900!" },
    { "type": "text", "id": "compare_price", "label": "Precio comparación", "default": "$239.800" },
    { "type": "number", "id": "bundle_price", "label": "Precio bundle (centavos)", "default": 15990000 },
    { "type": "number", "id": "bundle_qty", "label": "Cantidad pares", "default": 2 },
    { "type": "number", "id": "limit", "label": "Máx productos", "min": 2, "max": 20, "default": 6 },
    { "type": "collection", "id": "bundle_collection", "label": "Colección del bundle" },
    { "type": "text", "id": "btn_text", "label": "Texto botón", "default": "Agregar 2×1 al carrito" },
    { "type": "text", "id": "btn_sub", "label": "Sub botón", "default": "⚡ Precio especial aplicado automáticamente" }
  ],
  "presets": [{ "name": "Bundle 2×1" }]
}
{% endschema %}
{% endif %}
