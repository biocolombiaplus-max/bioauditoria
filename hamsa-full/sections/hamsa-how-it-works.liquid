{% comment %}hamsa-how-it-works — Cómo funciona, 4 pasos premium{% endcomment %}
<section class="hhiw" id="HamsaHowItWorks-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --rose: {{ section.settings.accent_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --card: {{ section.settings.card_color }};
">
  <div class="hhiw__container">
    <div class="hhiw__head">
      {% if section.settings.eyebrow != blank %}
        <div class="hhiw__eyebrow"><span></span>{{ section.settings.eyebrow }}<span></span></div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="hhiw__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="hhiw__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
    <div class="hhiw__steps">
      {% for block in section.blocks %}
        <div class="hhiw__step" {{ block.shopify_attributes }}>
          <div class="hhiw__step-num">{{ forloop.index }}</div>
          <div class="hhiw__step-icon">{{ block.settings.icon }}</div>
          <h3 class="hhiw__step-title">{{ block.settings.title }}</h3>
          <p class="hhiw__step-text">{{ block.settings.text }}</p>
        </div>
        {% unless forloop.last %}
          <div class="hhiw__arrow">→</div>
        {% endunless %}
      {% endfor %}
    </div>
    {% if section.settings.cta_text != blank %}
    <div class="hhiw__cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="hhiw__cta">{{ section.settings.cta_text }}</a>
    </div>
    {% endif %}
  </div>
</section>

<style>
#HamsaHowItWorks-{{ section.id }} { background:var(--bg); padding:{{ section.settings.pt }}px 20px {{ section.settings.pb }}px; }
#HamsaHowItWorks-{{ section.id }} * { box-sizing:border-box; }
.hhiw__container { max-width:1100px; margin:0 auto; }
.hhiw__head { text-align:center; margin-bottom:40px; }
.hhiw__eyebrow { display:flex; align-items:center; justify-content:center; gap:10px; font-size:11px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--rose); margin-bottom:12px; }
.hhiw__eyebrow span { flex:1; max-width:60px; height:1px; background:var(--rose); opacity:.4; }
.hhiw__title { font-size:clamp(1.5rem,3vw,2.2rem); font-weight:800; color:var(--text); margin:0 0 10px; letter-spacing:-.02em; }
.hhiw__sub { font-size:15px; color:var(--muted); max-width:50ch; margin:0 auto; line-height:1.6; }
.hhiw__steps { display:flex; align-items:flex-start; justify-content:center; gap:8px; flex-wrap:wrap; }
.hhiw__step {
  flex:1; min-width:180px; max-width:220px;
  background:var(--card); border-radius:20px; padding:28px 18px;
  text-align:center; border:1px solid rgba(0,0,0,.07);
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  transition:transform .25s, box-shadow .25s;
  position:relative;
}
.hhiw__step:hover { transform:translateY(-5px); box-shadow:0 12px 40px rgba(0,0,0,.1); }
.hhiw__step-num {
  position:absolute; top:-14px; left:50%; transform:translateX(-50%);
  width:28px; height:28px; border-radius:50%;
  background:var(--rose); color:#fff; font-size:13px; font-weight:900;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 12px rgba(212,82,122,.4);
}
.hhiw__step-icon { font-size:42px; margin:8px 0 14px; display:block; }
.hhiw__step-title { font-size:16px; font-weight:800; color:var(--text); margin:0 0 8px; }
.hhiw__step-text { font-size:13px; color:var(--muted); line-height:1.6; margin:0; }
.hhiw__arrow { font-size:28px; color:var(--rose); opacity:.5; align-self:center; margin-top:14px; flex-shrink:0; }
.hhiw__cta-wrap { text-align:center; margin-top:36px; }
.hhiw__cta {
  display:inline-block; background:var(--rose); color:#fff;
  padding:14px 40px; border-radius:50px; font-size:15px; font-weight:700;
  text-decoration:none; box-shadow:0 4px 20px rgba(212,82,122,.35);
  transition:transform .2s, box-shadow .2s;
}
.hhiw__cta:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(212,82,122,.45); color:#fff; }
@media(max-width:749px) {
  .hhiw__steps { flex-direction:column; align-items:center; }
  .hhiw__arrow { transform:rotate(90deg); margin:0; }
  .hhiw__step { max-width:320px; width:100%; }
}
</style>

{% schema %}
{
  "name": "Cómo Funciona",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#F8F4F0" },
    { "type": "color", "id": "card_color", "label": "Tarjeta", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Acento", "default": "#D4527A" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tan fácil como 1, 2, 3" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Tu pedido en 3 pasos simples" },
    { "type": "text", "id": "subtext", "label": "Subtexto", "default": "Comprar en Hamsa Shoes es rápido, seguro y sin complicaciones" },
    { "type": "text", "id": "cta_text", "label": "Texto CTA", "default": "Comprar ahora →" },
    { "type": "url", "id": "cta_url", "label": "URL CTA" },
    { "type": "range", "id": "pt", "label": "Padding top", "min": 32, "max": 100, "step": 4, "default": 64 },
    { "type": "range", "id": "pb", "label": "Padding bottom", "min": 32, "max": 100, "step": 4, "default": 64 }
  ],
  "blocks": [
    {
      "name": "Paso",
      "type": "step",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji ícono", "default": "👟" },
        { "type": "text", "id": "title", "label": "Título", "default": "Elige tu sandalia" },
        { "type": "text", "id": "text", "label": "Descripción", "default": "Explora todos los modelos y elige el que más te guste" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cómo Funciona",
      "blocks": [
        { "type": "step", "settings": { "icon": "👟", "title": "Elige tu modelo", "text": "Explora nuestra colección y elige el modelo y talla perfecta para ti" } },
        { "type": "step", "settings": { "icon": "🛒", "title": "Haz tu pedido", "text": "Agrega al carrito o escríbenos por WhatsApp. Sin tarjeta de crédito requerida" } },
        { "type": "step", "settings": { "icon": "📦", "title": "Recibe en casa", "text": "Enviamos a toda Colombia. Paga cuando el paquete llega a tu puerta" } },
        { "type": "step", "settings": { "icon": "💛", "title": "Lúcelas con amor", "text": "¡Disfruta tus sandalias! Si algo no quedó perfecto, te lo resolvemos" } }
      ]
    }
  ]
}
{% endschema %}
