<section class="hhban-section" id="HamsaBanner-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --gold: {{ section.settings.gold_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
  --btn-bg: {{ section.settings.btn_bg }};
  --btn-text: {{ section.settings.btn_text_color }};
  --wa: {{ section.settings.wa_color }};
  --overlay: {{ section.settings.overlay_opacity }};
  --h: {{ section.settings.height }}px;
  --hm: {{ section.settings.height_mobile }}px;
  --radius: {{ section.settings.radius }}px;
">
  <div class="hhban-wrap">
    <div class="hhban-inner">

      <div class="hhban-img-side">
        <div class="hhban-img-box">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 700, format: 'webp' | image_tag:
              class: 'hhban-img',
              loading: 'lazy',
              widths: '360, 500, 700',
              sizes: '(max-width:749px) 100vw, 50vw',
              alt: section.settings.heading | default: 'Banner'
            }}
          {% else %}
            <div class="hhban-img-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              <p>Agrega una imagen</p>
            </div>
          {% endif %}
          {% if section.settings.floating_label != blank %}
            <div class="hhban-pill">{{ section.settings.floating_label }}</div>
          {% endif %}
        </div>
      </div>

      <div class="hhban-content-side">
        {% if section.settings.eyebrow != blank %}
          <div class="hhban-eyebrow">{{ section.settings.eyebrow }}</div>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="hhban-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="hhban-text">{{ section.settings.text }}</div>
        {% endif %}
        <div class="hhban-actions">
          {% if section.settings.btn_text != blank %}
            <a href="{{ section.settings.btn_url }}" class="hhban-btn hhban-btn--primary">{{ section.settings.btn_text }}</a>
          {% endif %}
          {% if section.settings.show_wa %}
            <a href="https://wa.me/{{ section.settings.wa_country }}{{ section.settings.wa_number }}" class="hhban-btn hhban-btn--wa hamsa-wa-btn" target="_blank" rel="noopener" data-wa-phone="{{ section.settings.wa_country }}{{ section.settings.wa_number }}" data-wa-msg="{{ section.settings.wa_message | escape }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {{ section.settings.wa_text }}
            </a>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
#HamsaBanner-{{ section.id }} {
  background: var(--bg); overflow: hidden;
  padding: {{ section.settings.pt }}px 20px {{ section.settings.pb }}px;
}
#HamsaBanner-{{ section.id }} * { box-sizing: border-box; }
.hhban-wrap { max-width: 1320px; margin: 0 auto; }
.hhban-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 56px; align-items: center;
  {% if section.settings.reverse %}flex-direction: row-reverse;{% endif %}
}
{% if section.settings.reverse %}.hhban-content-side { order: -1; }{% endif %}

.hhban-img-box {
  position: relative; border-radius: var(--radius); overflow: hidden;
  aspect-ratio: 4/5; box-shadow: 0 24px 60px rgba(0,0,0,.35);
}
.hhban-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s; }
.hhban-img-box:hover .hhban-img { transform: scale(1.03); }
.hhban-img-placeholder {
  width:100%; height:100%; min-height:300px;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:12px; background:color-mix(in srgb,var(--gold) 8%,var(--bg)); color:var(--muted); font-size:13px;
}
.hhban-pill {
  position: absolute; top: 20px; left: -10px;
  background: var(--gold); color: #000;
  font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  padding: 8px 20px 8px 24px; border-radius: 0 20px 20px 0;
  box-shadow: 0 4px 16px rgba(0,0,0,.3);
}
.hhban-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 16px;
}
.hhban-title {
  font-size: clamp(1.8rem, 3vw, 3rem); font-weight: 800; letter-spacing: -0.03em;
  line-height: 1.1; margin: 0 0 20px; color: var(--text);
}
.hhban-text { font-size: 15px; color: var(--muted); line-height: 1.7; margin: 0 0 32px; }
.hhban-actions { display: flex; flex-wrap: wrap; gap: 12px; }
.hhban-btn {
  position:relative; overflow:hidden;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 28px; border-radius: 8px;
  font-size: 14px; font-weight: 700; text-decoration: none;
  transition: opacity .2s, transform .2s;
}
.hhban-btn--primary {
  background: linear-gradient(135deg, #C0405F, #D4527A, #E8748A);
  color: #fff;
  box-shadow: 0 4px 20px rgba(212,82,122,.45);
}
.hhban-btn--primary::after {
  content:''; position:absolute; top:0; left:-75%; width:50%; height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.35),transparent);
  transform:skewX(-20deg); animation:hmsa-shine 3.5s infinite;
}
.hhban-btn--primary:hover { transform:translateY(-3px) scale(1.02); box-shadow:0 8px 32px rgba(212,82,122,.65); }
.hhban-btn--wa {
  background: linear-gradient(135deg, #128C7E, #25D366);
  color: #fff;
  box-shadow: 0 4px 20px rgba(37,211,102,.4);
  animation: hmsa-wa-pulse 2.2s cubic-bezier(.4,0,.6,1) infinite;
}
.hhban-btn--wa:hover { transform:translateY(-3px) scale(1.02); box-shadow:0 8px 32px rgba(37,211,102,.6); animation:none; }
@media (max-width: 900px) {
  .hhban-inner { grid-template-columns: 1fr; gap: 28px; }
  .hhban-img-box { aspect-ratio: 4/5; max-height: 480px; }
  #HamsaBanner-{{ section.id }} { padding: {{ section.settings.pt_mobile }}px 16px {{ section.settings.pb_mobile }}px; }
  {% if section.settings.reverse %}.hhban-content-side { order: 0; }{% endif %}
}
@media (max-width: 480px) {
  .hhban-title { font-size: 1.7rem; }
  .hhban-actions { flex-direction: column; }
  .hhban-btn { width: 100%; justify-content: center; }
}

@keyframes hmsa-shine {
  0%   { left: -75%; opacity: 0; }
  10%  { opacity: 1; }
  40%  { left: 120%; opacity: 0; }
  100% { left: 120%; opacity: 0; }
}
@keyframes hmsa-wa-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,.5); }
  70%  { box-shadow: 0 0 0 10px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}

</style>

{% schema %}
{
  "name": "🖼️ Banner Editorial",
  "settings": [
    { "type": "header", "content": "🖼️ Imagen" },
    { "type": "image_picker", "id": "image", "label": "Imagen del banner" },
    { "type": "text", "id": "floating_label", "label": "Etiqueta sobre imagen", "default": "✨ Nueva temporada" },
    { "type": "checkbox", "id": "reverse", "label": "Imagen a la derecha", "default": false },
    { "type": "range", "id": "radius", "label": "Redondeo imagen (px)", "min": 0, "max": 40, "step": 2, "default": 20 },
    { "type": "header", "content": "✏️ Contenido" },
    { "type": "text", "id": "eyebrow", "label": "Texto pequeño", "default": "Editorial Hamsa" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Sandalias que transforman tu look" },
    { "type": "richtext", "id": "text", "label": "Descripción" },
    { "type": "text", "id": "btn_text", "label": "Botón texto", "default": "Ver colección" },
    { "type": "url", "id": "btn_url", "label": "Botón enlace" },
    { "type": "header", "content": "💬 WhatsApp" },
    { "type": "checkbox", "id": "show_wa", "label": "Mostrar WhatsApp", "default": true },
    { "type": "text", "id": "wa_text", "label": "Texto botón WhatsApp", "default": "Comprar por WhatsApp" },
    { "type": "text", "id": "wa_country", "label": "Código país", "default": "57" },
    { "type": "text", "id": "wa_number", "label": "Número", "default": "3508258757" },
    { "type": "text", "id": "wa_message", "label": "Mensaje", "default": "Hola, quiero comprar" },
    { "type": "header", "content": "🎨 Colores" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "color", "id": "gold_color", "label": "Acento", "default": "#D4527A" },
    { "type": "color", "id": "btn_bg", "label": "Botón fondo", "default": "#D4527A" },
    { "type": "color", "id": "btn_text_color", "label": "Botón texto", "default": "#FFFFFF" },
    { "type": "color", "id": "wa_color", "label": "WhatsApp color", "default": "#25D366" },
    { "type": "range", "id": "overlay_opacity", "label": "Opacidad overlay", "min": 0, "max": 80, "step": 5, "default": 0 },
    { "type": "header", "content": "📐 Espaciado" },
    { "type": "range", "id": "pt", "label": "Padding top desktop", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pb", "label": "Padding bottom desktop", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pt_mobile", "label": "Padding top móvil", "min": 16, "max": 80, "step": 4, "default": 36 },
    { "type": "range", "id": "pb_mobile", "label": "Padding bottom móvil", "min": 16, "max": 80, "step": 4, "default": 36 },
    { "type": "range", "id": "height", "label": "Alto banner desktop", "min": 300, "max": 700, "step": 20, "default": 520 },
    { "type": "range", "id": "height_mobile", "label": "Alto banner móvil", "min": 200, "max": 500, "step": 20, "default": 380 }
  ],
  "presets": [{ "name": "🖼️ Banner Editorial" }]
}
{% endschema %}
