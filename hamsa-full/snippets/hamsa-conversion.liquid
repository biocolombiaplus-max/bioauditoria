.hcv4__prod img{width:76px;height:76px;object-fit:cover;border-radius:8px;display:block;margin:0 auto 5px}
.hcv4__prod span:nth-child(2){display:block;font-size:10px;font-weight:600;color:#1C1208;margin-bottom:2px;line-height:1.3}
