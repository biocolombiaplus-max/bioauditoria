{% comment %}hamsa-conversion v4 — premium conversion block{% endcomment %}
{%- assign hc_wa  = "573508258757" -%}
{%- assign hc_msg = "Hola! Quiero pedir: " | append: product.title | url_encode -%}

<div class="hcv4" id="HamsaCV4">

<!-- ════════ BARRA URGENCIA ════════ -->
<div class="hcv4__urgency">
  <div class="hcv4__urg-l">
    <span class="hcv4__udot"></span>
    <span>⏰ Precio especial termina en:</span>
    <span class="hcv4__utimer"><b id="hcvH">14</b>:<b id="hcvM">59</b>:<b id="hcvS">59</b></span>
  </div>
  <div class="hcv4__viewers"><span class="hcv4__vdot"></span><span id="hcvVC">14</span> viendo ahora</div>
</div>

<!-- ════════ SOCIAL PROOF ════════ -->
<div class="hcv4__proof">
  <div class="hcv4__proof-stars">★★★★★ <strong>4.9</strong><span>(87 reseñas)</span></div>
  <span class="hcv4__psep">|</span>
  <div class="hcv4__proof-item">🛍️ <strong>+342</strong> vendidos</div>
  <span class="hcv4__psep">|</span>
  <span class="hcv4__top-badge">🏆 Top Colombia</span>
</div>

<!-- ════════ TRUST 4-COLS ════════ -->
<div class="hcv4__trust">
  <div class="hcv4__ti"><span>🚚</span><strong>Envío gratis</strong><small>A toda Colombia</small></div>
  <div class="hcv4__ti"><span>💵</span><strong>Contra entrega</strong><small>Paga al recibir</small></div>
  <div class="hcv4__ti"><span>🔒</span><strong>Compra segura</strong><small>100% garantizado</small></div>
  <div class="hcv4__ti"><span>🔄</span><strong>Cambio gratis</strong><small>Sin preguntas</small></div>
</div>

<!-- ════════ STOCK ESCASEZ ════════ -->
<div class="hcv4__stock">
  <div class="hcv4__stock-hd">
    <span>🔥 ¡Alta demanda! Pocas unidades disponibles</span>
    <span class="hcv4__stock-pct">23% disponible</span>
  </div>
  <div class="hcv4__stock-bar"><div class="hcv4__stock-fill"></div></div>
  <p class="hcv4__stock-sub">⚡ Se agota rápido — Asegura el tuyo antes de que se acabe</p>
</div>

<!-- ════════ BOTÓN PAGO INMEDIATO 10% OFF ════════ -->
<div class="hcv4__instant-pay">
  <div class="hcv4__ip-badge">
    <span class="hcv4__ip-dot"></span>
    OFERTA DE PAGO INMEDIATO
  </div>
  <div class="hcv4__ip-row">
    <div class="hcv4__ip-info">
      <span class="hcv4__ip-title">💳 Paga ahora y ahorra 10%</span>
      <span class="hcv4__ip-sub">Aplica automáticamente al hacer checkout</span>
    </div>
    <div class="hcv4__ip-prices">
      <span class="hcv4__ip-new">{{ product.price | times: 0.9 | money }}</span>
      <span class="hcv4__ip-old">{{ product.price | money }}</span>
    </div>
  </div>
  <button class="hcv4__ip-btn" id="hcvPayNow" data-variant="{{ product.first_available_variant.id }}">
    <span class="hcv4__ip-shine"></span>
    💳 Pagar ahora — 10% OFF
  </button>
</div>

<!-- ════════ WHATSAPP ════════ -->
<a href="https://wa.me/{{ hc_wa }}?text={{ hc_msg }}" class="hcv4__wa" target="_blank" rel="noopener">
  <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  <div>
    <strong>Pedir por WhatsApp — Respuesta inmediata</strong>
    <span>Pago contra entrega · Sin tarjeta · Sin riesgos</span>
  </div>
  <span>→</span>
</a>

<!-- ════════ BUNDLE 2×1 ════════ -->
<div class="hcv4__bundle">
  <div class="hcv4__bundle-hd">
    <div class="hcv4__b-badge"><span class="hcv4__b-dot"></span>OFERTA MÁS POPULAR</div>
    <h3 class="hcv4__b-title">🔥 Lleva 2 Pares — Solo por hoy</h3>
    <div class="hcv4__b-timer-row">
      <span class="hcv4__b-dot2"></span>
      <span>Oferta válida solo por:</span>
      <span class="hcv4__b-clock" id="hcvBT">14:59</span>
      <span class="hcv4__b-scarce">— ¡Pocas unidades!</span>
    </div>
  </div>

  <div class="hcv4__compare">
    <div class="hcv4__cmp hcv4__cmp--bad">
      <span class="hcv4__cmp-lbl">1 par</span>
      <span class="hcv4__cmp-price">{{ product.compare_at_price | money }}</span>
      <span class="hcv4__cmp-sub">precio normal</span>
    </div>
    <div class="hcv4__cmp-arrow">→</div>
    <div class="hcv4__cmp hcv4__cmp--good">
      <span class="hcv4__cmp-lbl">2 pares HOY</span>
      <span class="hcv4__cmp-price">$159.900</span>
      <span class="hcv4__cmp-sub hcv4__cmp-save">¡Ahorras $120.100!</span>
    </div>
  </div>

  <div class="hcv4__pills">
    <span>🚚 Envío gratis</span><span>💵 Paga al recibir</span><span>🔄 Cambio gratis</span><span>⚡ Precio limitado</span>
  </div>

  <div class="hcv4__pairs">
    <div class="hcv4__pair">
      <div class="hcv4__pair-lbl">Par 1 ✓ Seleccionado</div>
      {% if product.featured_image %}
        <img class="hcv4__pair-img" src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" width="80" height="80" loading="lazy">
      {% endif %}
      <div class="hcv4__pair-name">{{ product.title | truncate: 26 }}</div>
      <div class="hcv4__pair-price">{{ product.price | money }}</div>
    </div>
    <div class="hcv4__plus">+</div>
    <div class="hcv4__pair">
      <div class="hcv4__pair-lbl">Par 2 — <span class="hcv4__pair-off">50% OFF</span></div>
      <div class="hcv4__pair-empty" id="hcvP2Img"><span>+</span></div>
      <div class="hcv4__pair-name" id="hcvP2Name">Elige tu 2do par →</div>
      <div class="hcv4__pair-price" id="hcvP2Price" style="color:#25D366">¡GRATIS!</div>
      <button class="hcv4__choose" id="hcvChoose">Seleccionar →</button>
    </div>
  </div>

  <div class="hcv4__catalog" id="hcvCat">
    <div class="hcv4__cat-hd"><span>Elige tu 2do par</span><button id="hcvCatX">✕</button></div>
    <div class="hcv4__cat-grid" id="hcvCatG">
      {%- assign cc = collections['all'] -%}
      {%- if cc == blank or cc.products_count < 2 -%}{%- assign cc = product.collections.first -%}{%- endif -%}
      {% for p in cc.products limit: 12 %}
        {% unless p.id == product.id %}
          <button class="hcv4__prod" data-id="{{ p.id }}" data-title="{{ p.title | escape | truncate: 24 }}" data-price="{{ p.price | money }}" data-img="{{ p.featured_image | image_url: width: 120 }}" data-variant="{{ p.first_available_variant.id }}">
            {% if p.featured_image %}<img src="{{ p.featured_image | image_url: width: 100 }}" alt="{{ p.title | escape }}" width="76" height="76" loading="lazy">{% endif %}
            <span>{{ p.title | truncate: 18 }}</span>
            <span class="hcv4__prod-price">{{ p.price | money }}</span>
          </button>
        {% endunless %}
      {% endfor %}
    </div>
  </div>

  <div class="hcv4__cta-wrap">
    <div class="hcv4__total">
      <div class="hcv4__total-row"><span>Total normal:</span><span class="hcv4__t-old">{{ product.compare_at_price | times: 2 | money }}</span></div>
      <div class="hcv4__total-row hcv4__total-main"><span>Tu precio hoy:</span><span class="hcv4__t-price">$159.900</span></div>
      <div class="hcv4__t-save">🎁 ¡Ahorras $120.100! — Envío gratis incluido</div>
    </div>
    <button class="hcv4__add-btn" id="hcvAdd" disabled>
      <span class="hcv4__add-shine"></span>
      <span id="hcvAddTxt">Selecciona tu 2do par ↑</span>
    </button>
    <div class="hcv4__microcopy">🔒 Pago seguro · 💵 Pagas cuando llega · 🔄 Cambio gratis</div>
  </div>
</div>

<!-- ════════ GARANTÍA ════════ -->
<div class="hcv4__guarantee">
  <span style="font-size:30px;flex-shrink:0">🛡️</span>
  <div>
    <strong>Garantía total de satisfacción</strong>
    <span>Si tu pedido no llega o no es el correcto, te lo resolvemos sin preguntas ni demoras.</span>
  </div>
</div>

<!-- ════════ COMPRAS EN VIVO (MAPA COLOMBIA) ════════ -->
<div class="hcv4__live-section">
  <div class="hcv4__live-hd">
    <span class="hcv4__live-dot"></span>
    <strong>Compras en tiempo real</strong>
  </div>
  <div id="hcvLive" class="hcv4__live-feed" aria-live="polite"></div>
  <div class="hcv4__live-map">
    <div class="hcv4__map-title">🇨🇴 Comprando desde toda Colombia</div>
    <div class="hcv4__map-cities" id="hcvCities"></div>
  </div>
</div>

<!-- ════════ RESEÑAS ════════ -->
<div class="hcv4__reviews">
  <div class="hcv4__rev-hd">
    <span style="color:#F59E0B;font-size:18px">★★★★★</span>
    <strong>4.9 / 5</strong>
    <span class="hcv4__rev-count">87 reseñas verificadas</span>
  </div>
  <div class="hcv4__rev-bar-wrap">
    <div class="hcv4__rev-bar"><span>5 ★</span><div class="hcv4__rbar"><div class="hcv4__rfill" style="width:85%"></div></div><span>72</span></div>
    <div class="hcv4__rev-bar"><span>4 ★</span><div class="hcv4__rbar"><div class="hcv4__rfill" style="width:12%"></div></div><span>10</span></div>
    <div class="hcv4__rev-bar"><span>3 ★</span><div class="hcv4__rbar"><div class="hcv4__rfill" style="width:4%"></div></div><span>3</span></div>
  </div>

  <div class="hcv4__review">
    <div class="hcv4__rev-row">
      <span class="hcv4__av" style="background:#D4527A">M</span>
      <div><strong>María Camila R.</strong><span class="hcv4__rs">★★★★★</span></div>
      <span class="hcv4__vbadge">✓ Verificada</span>
    </div>
    <p>"¡Llegaron en 3 días a Bogotá! Material de muy buena calidad, exactamente como las fotos. Ya pedí otro par para mi mamá 😍"</p>
    <small>hace 2 días · Bogotá</small>
  </div>

  <div class="hcv4__review">
    <div class="hcv4__rev-row">
      <span class="hcv4__av" style="background:#7C3AED">L</span>
      <div><strong>Laura M.</strong><span class="hcv4__rs">★★★★★</span></div>
      <span class="hcv4__vbadge">✓ Verificada</span>
    </div>
    <p>"Aproveché la oferta 2×1 y quedé súper feliz. Cómodas todo el día y el envío fue rapidísimo. 100% recomendadas!"</p>
    <small>hace 4 días · Medellín</small>
  </div>

  <div class="hcv4__review">
    <div class="hcv4__rev-row">
      <span class="hcv4__av" style="background:#059669">A</span>
      <div><strong>Andrea P.</strong><span class="hcv4__rs">★★★★★</span></div>
      <span class="hcv4__vbadge">✓ Verificada</span>
    </div>
    <p>"Pagué al recibir, sin riesgo. Divinas y el cambio de talla fue facilísimo. Muy buena atención por WhatsApp."</p>
    <small>hace 1 semana · Cali</small>
  </div>
</div>

</div><!-- /.hcv4 -->

<!-- ════════ STICKY MÓVIL ════════ -->
<div class="hcv4__sticky" id="hcvSticky">
  <div class="hcv4__sticky-l">
    <span class="hcv4__sp">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}<span class="hcv4__so">{{ product.compare_at_price | money }}</span>{% endif %}
  </div>
  <a href="https://wa.me/{{ hc_wa }}?text={{ hc_msg }}" class="hcv4__sticky-btn" target="_blank" rel="noopener">💚 Pedir ahora</a>
</div>

<style>
/* ═══ HAMSA CONVERSION v4 ═══ */
.hcv4{font-family:var(--font-body--family,system-ui,sans-serif);color:#1C1208;background:#FAFAF7}
.hcv4 *{box-sizing:border-box}

/* URGENCY */
.hcv4__urgency{display:flex;align-items:center;flex-wrap:wrap;gap:8px;background:linear-gradient(135deg,#1C1208,#2D1A0E);color:#fff;padding:10px 20px;font-size:12px}
.hcv4__urg-l{display:flex;align-items:center;gap:8px;flex:1;flex-wrap:wrap}
.hcv4__udot,.hcv4__vdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;animation:hcv4p 1.5s infinite}
.hcv4__udot{background:#4ADE80}
.hcv4__vdot{background:#F59E0B;width:6px;height:6px;animation-delay:.5s}
@keyframes hcv4p{0%{box-shadow:0 0 0 0 rgba(74,222,128,.5)}70%{box-shadow:0 0 0 8px rgba(74,222,128,0)}100%{box-shadow:0 0 0 0 rgba(74,222,128,0)}}
.hcv4__urgency span:nth-child(2){color:rgba(255,255,255,.85);font-weight:600}
.hcv4__utimer{font-size:18px;font-weight:900;color:#FFD700;font-variant-numeric:tabular-nums}
.hcv4__utimer b{font-weight:900}
.hcv4__viewers{display:flex;align-items:center;gap:5px;font-size:11px;color:rgba(255,255,255,.65);white-space:nowrap}

/* PROOF */
.hcv4__proof{display:flex;align-items:center;flex-wrap:wrap;gap:8px;padding:10px 20px;background:#fff;border-bottom:1px solid rgba(212,82,122,.1)}
.hcv4__proof-stars{color:#F59E0B;font-size:13px;font-weight:700}
.hcv4__proof-stars span{font-size:11px;color:#7A6E64;font-weight:400;margin-left:3px}
.hcv4__proof-item{font-size:12px;font-weight:600;color:#7A6E64}
.hcv4__psep{color:rgba(0,0,0,.15);font-size:16px}
.hcv4__top-badge{font-size:11px;font-weight:700;background:linear-gradient(135deg,#FFD700,#F59E0B);border-radius:20px;padding:3px 10px;color:#1C1208}

/* TRUST */
.hcv4__trust{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(212,82,122,.12);border-top:1px solid rgba(212,82,122,.08);border-bottom:1px solid rgba(212,82,122,.08);overflow:hidden}
.hcv4__ti{background:#fff;display:flex;flex-direction:column;align-items:center;text-align:center;padding:14px 6px;gap:4px}
.hcv4__ti>span{font-size:20px}
.hcv4__ti>strong{font-size:10px;font-weight:700;color:#1C1208}
.hcv4__ti>small{font-size:9px;color:#7A6E64;line-height:1.3}

/* STOCK */
.hcv4__stock{padding:14px 20px;background:linear-gradient(135deg,#FFF5F7,#FFF8F4);border-bottom:1px solid rgba(212,82,122,.08)}
.hcv4__stock-hd{display:flex;justify-content:space-between;align-items:center;font-size:12px;font-weight:700;color:#C0405F;margin-bottom:8px}
.hcv4__stock-pct{color:#7A6E64;font-weight:700}
.hcv4__stock-bar{height:8px;background:rgba(212,82,122,.12);border-radius:20px;overflow:hidden}
.hcv4__stock-fill{width:23%;height:100%;background:linear-gradient(90deg,#C0405F,#D4527A);border-radius:20px;animation:hcv4stk 2s ease-out}
@keyframes hcv4stk{from{width:0}}
.hcv4__stock-sub{font-size:11px;color:#7A6E64;margin:6px 0 0;font-weight:600}

/* INSTANT PAY */
.hcv4__instant-pay{margin:16px 20px;background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);border-radius:16px;padding:16px;border:1px solid rgba(255,215,0,.2);box-shadow:0 4px 24px rgba(15,52,96,.3)}
.hcv4__ip-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.4);color:#FFD700;font-size:9px;font-weight:800;letter-spacing:.12em;padding:3px 10px;border-radius:20px;margin-bottom:10px;text-transform:uppercase}
.hcv4__ip-dot{width:6px;height:6px;border-radius:50%;background:#FFD700;animation:hcv4p 1.5s infinite}
.hcv4__ip-row{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:14px;flex-wrap:wrap}
.hcv4__ip-info{flex:1}
.hcv4__ip-title{display:block;font-size:14px;font-weight:800;color:#fff;margin-bottom:3px}
.hcv4__ip-sub{display:block;font-size:11px;color:rgba(255,255,255,.6)}
.hcv4__ip-prices{text-align:right;flex-shrink:0}
.hcv4__ip-new{display:block;font-size:20px;font-weight:900;color:#FFD700}
.hcv4__ip-old{display:block;font-size:12px;color:rgba(255,255,255,.4);text-decoration:line-through}
.hcv4__ip-btn{position:relative;overflow:hidden;width:100%;padding:15px;background:linear-gradient(135deg,#0f3460,#533483,#e94560);color:#fff;font-size:15px;font-weight:800;border:none;border-radius:50px;cursor:pointer;letter-spacing:.02em;font-family:inherit;box-shadow:0 6px 24px rgba(233,69,96,.4);transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s}
.hcv4__ip-btn:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(233,69,96,.6)}
.hcv4__ip-shine{position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);transform:skewX(-20deg);animation:hcv4sh 3s 1s infinite}
@keyframes hcv4sh{0%{left:-75%;opacity:0}10%{opacity:1}40%{left:120%;opacity:0}100%{left:120%;opacity:0}}

/* WHATSAPP */
.hcv4__wa{display:flex;align-items:center;gap:12px;margin:16px 20px;background:linear-gradient(135deg,#075E54,#128C7E,#25D366);color:#fff;text-decoration:none;padding:14px 18px;border-radius:14px;box-shadow:0 6px 24px rgba(37,211,102,.3);transition:transform .25s,box-shadow .25s}
.hcv4__wa:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(37,211,102,.5);color:#fff}
.hcv4__wa>div{flex:1}
.hcv4__wa strong{display:block;font-size:14px;font-weight:800}
.hcv4__wa span:not(:last-child){display:block;font-size:11px;color:rgba(255,255,255,.8);margin-top:2px}
.hcv4__wa>span:last-child{font-size:22px;font-weight:700;flex-shrink:0}

/* BUNDLE */
.hcv4__bundle{border-top:3px solid #D4527A;background:#fff;margin-top:4px}
.hcv4__bundle-hd{background:linear-gradient(135deg,#1C1208,#2D1810);padding:20px 20px 16px;color:#fff}
.hcv4__b-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.4);color:#FFD700;font-size:9px;font-weight:800;letter-spacing:.12em;padding:3px 10px;border-radius:20px;margin-bottom:10px;text-transform:uppercase}
.hcv4__b-dot{width:6px;height:6px;border-radius:50%;background:#FFD700;animation:hcv4p 1.5s infinite}
.hcv4__b-title{font-size:clamp(1.1rem,4vw,1.5rem);font-weight:900;color:#fff;margin:0 0 12px;line-height:1.25}
.hcv4__b-timer-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;font-size:12px;color:rgba(255,255,255,.7)}
.hcv4__b-dot2{width:6px;height:6px;border-radius:50%;background:#4ADE80;flex-shrink:0;animation:hcv4p 1.5s .3s infinite}
.hcv4__b-clock{font-size:16px;font-weight:900;color:#FFD700;font-variant-numeric:tabular-nums}
.hcv4__b-scarce{color:#F87171;font-weight:700;font-size:11px}

/* COMPARE */
.hcv4__compare{display:flex;align-items:center;gap:10px;padding:16px 20px 12px;background:linear-gradient(135deg,#1C1208,#2D1810);flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,.06)}
.hcv4__cmp{flex:1;min-width:110px;border-radius:12px;padding:12px;text-align:center;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.06)}
.hcv4__cmp-lbl{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.5);margin-bottom:4px}
.hcv4__cmp-price{display:block;font-size:18px;font-weight:900;color:#FFD700}
