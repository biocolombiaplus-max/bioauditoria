{% comment %}hamsa-conversion v5 — máquina de ventas{% endcomment %}
{%- assign hc_wa  = "573508258757" -%}
{%- assign hc_msg = "Hola! Quiero pedir: " | append: product.title | url_encode -%}

<!-- ═══════════════════════════════════════════
     CSS GLOBAL: centrar botón Realised ODS
═══════════════════════════════════════════ -->
<style>
/* Centrar botón Pagar Contra Entrega (Realised ODS) */
realised-ods-button,
.realised-ods-button,
[class*="realised"],
.realised-button,
.realised-cod-btn,
buy-buttons > * { display:block; width:100% !important; text-align:center !important; }
realised-ods-button button,
.realised-ods-button button,
[class*="realised"] button { width:100% !important; max-width:100% !important; }
</style>

<div class="hcv5" id="HamsaCV5">

<!-- ══ 1. URGENCY BAR ══ -->
<div class="hcv5__urgency">
  <div class="hcv5__urg-l">
    <span class="hcv5__dot hcv5__dot--green"></span>
    <span class="hcv5__urg-label">⏰ Precio especial termina en</span>
    <span class="hcv5__timer"><b id="hcvH">00</b>:<b id="hcvM">14</b>:<b id="hcvS">59</b></span>
  </div>
  <div class="hcv5__viewers">
    <span class="hcv5__dot hcv5__dot--amber"></span>
    <span id="hcvVC">14</span> viendo ahora
  </div>
</div>

<!-- ══ 2. SOCIAL PROOF ══ -->
<div class="hcv5__proof">
  <span class="hcv5__stars">★★★★★</span>
  <strong>4.9</strong>
  <span class="hcv5__proof-txt">(87 reseñas)</span>
  <span class="hcv5__psep">·</span>
  <span class="hcv5__proof-txt">🛍️ <strong>+342</strong> vendidos</span>
  <span class="hcv5__psep">·</span>
  <span class="hcv5__top-pill">🏆 Top Colombia</span>
</div>

<!-- ══ 3. TRUST 4-COL ══ -->
<div class="hcv5__trust">
  <div class="hcv5__ti"><span>🚚</span><strong>Envío gratis</strong><small>A toda Colombia</small></div>
  <div class="hcv5__ti"><span>💵</span><strong>Contra entrega</strong><small>Paga al recibir</small></div>
  <div class="hcv5__ti"><span>🔒</span><strong>100% seguro</strong><small>Sin fraudes</small></div>
  <div class="hcv5__ti"><span>🔄</span><strong>Cambio gratis</strong><small>Sin preguntas</small></div>
</div>

<!-- ══ 4. STOCK ESCASEZ ══ -->
<div class="hcv5__stock">
  <div class="hcv5__stock-row">
    <span>🔥 ¡Alta demanda! Solo quedan pocas unidades</span>
    <span class="hcv5__stock-n">23%</span>
  </div>
  <div class="hcv5__stock-bar"><div class="hcv5__stock-fill"></div></div>
  <p class="hcv5__stock-sub">⚡ Se agota rápido — Asegura el tuyo ahora mismo</p>
</div>

<!-- ══ 5. OPCIONES DE PAGO — CLARAS Y GUIADAS ══ -->
<div class="hcv5__pay-block">
  <div class="hcv5__pay-title">Elige cómo pagar:</div>

  <!-- Opción 1: Contra entrega (principal) -->
  <div class="hcv5__pay-opt hcv5__pay-opt--main">
    <div class="hcv5__pay-opt-badge">✅ MÁS POPULAR</div>
    <div class="hcv5__pay-opt-row">
      <span class="hcv5__pay-icon">📦</span>
      <div class="hcv5__pay-info">
        <strong>Pago Contra Entrega</strong>
        <span>Pagas cuando recibes el paquete · Sin tarjeta · Sin riesgo</span>
      </div>
    </div>
    <!-- El botón de Realised ODS aparece aquí automáticamente -->
    <div class="hcv5__realised-slot" id="hcvRealisedSlot">
      <!-- Realised ODS inyecta su botón dentro del form del producto arriba.
           Este botón alternativo funciona si la app no está activa -->
      <a href="https://wa.me/{{ hc_wa }}?text={{ hc_msg }}" class="hcv5__cod-btn" target="_blank" rel="noopener">
        🛒 Pagar Contra Entrega — Paga al recibir
      </a>
    </div>
  </div>

  <!-- Opción 2: 5% descuento pago inmediato -->
  <div class="hcv5__pay-opt hcv5__pay-opt--discount">
    <div class="hcv5__pay-opt-badge hcv5__pay-opt-badge--gold">💰 AHORRA 5% EXTRA</div>
    <div class="hcv5__pay-opt-row">
      <span class="hcv5__pay-icon">💳</span>
      <div class="hcv5__pay-info">
        <strong>Paga ahora — 5% OFF</strong>
        <span>Precio con descuento: <b class="hcv5__disc-price">{{ product.price | times: 0.95 | money }}</b> <s>{{ product.price | money }}</s></span>
      </div>
    </div>
    <button class="hcv5__disc-btn" id="hcvPayNow" data-variant="{{ product.first_available_variant.id }}">
      <span class="hcv5__shine"></span>
      💳 Pagar ahora con 5% de descuento
    </button>
  </div>

  <!-- Opción 3: WhatsApp -->
  <a href="https://wa.me/{{ hc_wa }}?text={{ hc_msg }}" class="hcv5__wa" target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <div>
      <strong>Pedir por WhatsApp</strong>
      <span>Respuesta inmediata · Asesoría personalizada</span>
    </div>
    <span class="hcv5__wa-arr">→</span>
  </a>
</div>

<!-- ══ 6. BUNDLE 2×1 ══ -->
<div class="hcv5__bundle">
  <div class="hcv5__bundle-hd">
    <div class="hcv5__b-badge"><span class="hcv5__dot hcv5__dot--gold"></span>OFERTA MÁS POPULAR HOY</div>
    <h3 class="hcv5__b-title">🔥 Lleva 2 Pares — Solo por hoy</h3>
    <div class="hcv5__b-timer">
      <span class="hcv5__dot hcv5__dot--green"></span>
      Oferta válida solo por: <span class="hcv5__b-clock" id="hcvBT">14:59</span>
      <span class="hcv5__b-scarce">— ¡Pocas unidades!</span>
    </div>
  </div>

  <!-- Comparación precios -->
  <div class="hcv5__compare">
    <div class="hcv5__cmp hcv5__cmp--bad">
      <span class="hcv5__cmp-lbl">1 par solo</span>
      <span class="hcv5__cmp-price">{{ product.compare_at_price | money }}</span>
      <span class="hcv5__cmp-sub">precio normal</span>
    </div>
    <div class="hcv5__cmp-arr">→</div>
    <div class="hcv5__cmp hcv5__cmp--good">
      <span class="hcv5__cmp-lbl">2 pares HOY</span>
      <span class="hcv5__cmp-price">$159.900</span>
      <span class="hcv5__cmp-sub" style="color:#4ADE80;font-weight:700">¡Ahorras $120.100!</span>
    </div>
  </div>
  <div class="hcv5__pills">
    <span>🚚 Envío gratis</span><span>💵 Paga al recibir</span><span>🔄 Cambio gratis</span><span>⏰ Solo hoy</span>
  </div>

  <!-- PAR 1 + PAR 2 -->
  <div class="hcv5__pairs">
    <div class="hcv5__pair">
      <div class="hcv5__pair-lbl">Par 1 ✓</div>
      {% if product.featured_image %}
        <img class="hcv5__pair-img" src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" width="80" height="80" loading="lazy">
      {% endif %}
      <div class="hcv5__pair-name">{{ product.title | truncate: 24 }}</div>
      <div class="hcv5__pair-price">{{ product.price | money }}</div>
      <!-- Talla del par 1 se selecciona arriba con el picker nativo del tema -->
      <div class="hcv5__pair-hint">↑ Elige talla arriba</div>
    </div>
    <div class="hcv5__plus">+</div>
    <div class="hcv5__pair">
      <div class="hcv5__pair-lbl">Par 2 <span class="hcv5__pair-off">50% OFF</span></div>
      <div class="hcv5__pair-empty" id="hcvP2Img"><span>+</span></div>
      <div class="hcv5__pair-name" id="hcvP2Name">Elige tu 2do par →</div>
      <div class="hcv5__pair-price" id="hcvP2Price" style="color:#25D366">¡GRATIS!</div>
      <button class="hcv5__choose-btn" id="hcvChoose">Seleccionar →</button>
    </div>
  </div>

  <!-- SELECTOR TALLA/COLOR PAR 2 (aparece tras elegir producto) -->
  <div class="hcv5__variant-picker" id="hcvVarPicker" style="display:none">
    <div class="hcv5__vp-title" id="hcvVpTitle">Elige talla y color del Par 2:</div>
    <div class="hcv5__vp-opts" id="hcvVpOpts"></div>
  </div>

  <!-- CATÁLOGO -->
  <div class="hcv5__catalog" id="hcvCat">
    <div class="hcv5__cat-hd">
      <span>Elige tu 2do par</span>
      <button class="hcv5__cat-x" id="hcvCatX">✕</button>
    </div>
    <div class="hcv5__cat-grid" id="hcvCatG">
      {%- assign cc = collections['all'] -%}
      {%- if cc == blank or cc.products_count < 2 -%}{%- assign cc = product.collections.first -%}{%- endif -%}
      {% for p in cc.products limit: 12 %}
        {% unless p.id == product.id %}
          <button class="hcv5__prod"
            data-id="{{ p.id }}"
            data-handle="{{ p.handle }}"
            data-title="{{ p.title | escape | truncate: 24 }}"
            data-price="{{ p.price | money }}"
            data-img="{{ p.featured_image | image_url: width: 120 }}"
            data-variant="{{ p.first_available_variant.id }}">
            {% if p.featured_image %}<img src="{{ p.featured_image | image_url: width: 100 }}" alt="{{ p.title | escape }}" width="76" height="76" loading="lazy">{% endif %}
            <span>{{ p.title | truncate: 18 }}</span>
            <span class="hcv5__prod-price">{{ p.price | money }}</span>
          </button>
        {% endunless %}
      {% endfor %}
    </div>
  </div>

  <!-- CTA BUNDLE -->
  <div class="hcv5__cta-wrap">
    <div class="hcv5__total">
      <div class="hcv5__total-row"><span>Total normal:</span><span class="hcv5__t-old">{{ product.compare_at_price | times: 2 | money }}</span></div>
      <div class="hcv5__total-row hcv5__total-main"><span>Tu precio hoy:</span><span class="hcv5__t-price">$159.900</span></div>
      <div class="hcv5__t-save">🎁 ¡Ahorras $120.100! · Envío gratis incluido</div>
    </div>
    <button class="hcv5__add-btn" id="hcvAdd" disabled>
      <span class="hcv5__shine"></span>
      <span id="hcvAddTxt">① Elige tu 2do par ↑</span>
    </button>
    <div class="hcv5__microcopy">🔒 Pago seguro · 💵 Pagas cuando llega · 🔄 Cambio gratis</div>
  </div>
</div>

<!-- ══ 7. GARANTÍA ══ -->
<div class="hcv5__guarantee">
  <span style="font-size:28px;flex-shrink:0">🛡️</span>
  <div>
    <strong>Garantía 100% de satisfacción</strong>
    <span>Si tu pedido no llega o no es correcto, te lo resolvemos de inmediato. Sin preguntas.</span>
  </div>
</div>

<!-- ══ 8. COMPRAS EN VIVO ══ -->
<div class="hcv5__live-box">
  <div class="hcv5__live-hd"><span class="hcv5__dot hcv5__dot--green"></span><strong>Comprando ahora mismo en Colombia</strong></div>
  <div id="hcvFeed" class="hcv5__feed" aria-live="polite"></div>
  <div class="hcv5__cities" id="hcvCities"></div>
</div>

<!-- ══ 9. RESEÑAS ══ -->
<div class="hcv5__reviews">
  <div class="hcv5__rev-hd">
    <span style="color:#F59E0B;font-size:18px">★★★★★</span>
    <strong>4.9 / 5</strong>
    <span style="font-size:12px;color:#7A6E64">· 87 reseñas verificadas</span>
  </div>
  <div class="hcv5__bars">
    <div class="hcv5__bar-row"><span>5 ★</span><div class="hcv5__bbar"><div class="hcv5__bfill" style="width:85%"></div></div><span>72</span></div>
    <div class="hcv5__bar-row"><span>4 ★</span><div class="hcv5__bbar"><div class="hcv5__bfill" style="width:12%"></div></div><span>10</span></div>
    <div class="hcv5__bar-row"><span>3 ★</span><div class="hcv5__bbar"><div class="hcv5__bfill" style="width:4%"></div></div><span>3</span></div>
  </div>
  <div class="hcv5__review">
    <div class="hcv5__rrow"><span class="hcv5__av" style="background:#D4527A">M</span><div><strong>María Camila R.</strong><span class="hcv5__rs">★★★★★</span></div><span class="hcv5__vbadge">✓ Verificada</span></div>
    <p>"¡Llegaron en 3 días a Bogotá! Material de muy buena calidad, exactamente como en las fotos. Ya pedí otro par para mi mamá 😍"</p>
    <small>hace 2 días · Bogotá</small>
  </div>
  <div class="hcv5__review">
    <div class="hcv5__rrow"><span class="hcv5__av" style="background:#7C3AED">L</span><div><strong>Laura M.</strong><span class="hcv5__rs">★★★★★</span></div><span class="hcv5__vbadge">✓ Verificada</span></div>
    <p>"Aproveché el 2×1 y llegaron rapidísimo. Comodísimas todo el día. 100% recomendadas!"</p>
    <small>hace 4 días · Medellín</small>
  </div>
  <div class="hcv5__review">
    <div class="hcv5__rrow"><span class="hcv5__av" style="background:#059669">A</span><div><strong>Andrea P.</strong><span class="hcv5__rs">★★★★★</span></div><span class="hcv5__vbadge">✓ Verificada</span></div>
    <p>"Pagué al recibir, sin ningún riesgo. Divinas y el cambio de talla fue facilísimo."</p>
    <small>hace 1 semana · Cali</small>
  </div>
</div>

</div><!-- /.hcv5 -->

<!-- ══ STICKY MÓVIL ══ -->
<div class="hcv5__sticky" id="hcvSticky">
  <div>
    <span class="hcv5__sp">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}<span class="hcv5__so">{{ product.compare_at_price | money }}</span>{% endif %}
  </div>
  <a href="https://wa.me/{{ hc_wa }}?text={{ hc_msg }}" class="hcv5__sticky-btn" target="_blank" rel="noopener">💚 Pedir ahora</a>
</div>

<style>
/* ═══ HAMSA CONVERSION v5 ═══ */
.hcv5{font-family:var(--font-body--family,system-ui,sans-serif);color:#1C1208;background:#FAFAF7}
.hcv5 *{box-sizing:border-box}

/* DOTS */
.hcv5__dot{display:inline-block;width:8px;height:8px;border-radius:50%;flex-shrink:0;animation:hcv5p 1.5s infinite}
.hcv5__dot--green{background:#4ADE80}
.hcv5__dot--amber{background:#F59E0B;animation-delay:.5s}
.hcv5__dot--gold{background:#FFD700}
@keyframes hcv5p{0%{box-shadow:0 0 0 0 rgba(74,222,128,.5)}70%{box-shadow:0 0 0 8px rgba(74,222,128,0)}100%{box-shadow:0 0 0 0 rgba(74,222,128,0)}}

/* URGENCY */
.hcv5__urgency{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;background:linear-gradient(135deg,#1C1208,#2D1A0E);color:#fff;padding:10px 20px;font-size:12px}
.hcv5__urg-l{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.hcv5__urg-label{color:rgba(255,255,255,.85);font-weight:600}
.hcv5__timer{font-size:20px;font-weight:900;color:#FFD700;font-variant-numeric:tabular-nums;letter-spacing:.02em}
.hcv5__timer b{font-weight:900}
.hcv5__viewers{display:flex;align-items:center;gap:5px;font-size:11px;color:rgba(255,255,255,.65);white-space:nowrap}

/* PROOF */
.hcv5__proof{display:flex;align-items:center;flex-wrap:wrap;gap:8px;padding:9px 20px;background:#fff;border-bottom:1px solid rgba(212,82,122,.1)}
.hcv5__stars{color:#F59E0B;font-size:13px;letter-spacing:1px}
.hcv5__proof strong{font-size:13px;font-weight:800;color:#1C1208}
.hcv5__proof-txt{font-size:12px;color:#7A6E64}
.hcv5__psep{color:rgba(0,0,0,.15);font-size:16px}
.hcv5__top-pill{font-size:11px;font-weight:700;background:linear-gradient(135deg,#FFD700,#F59E0B);border-radius:20px;padding:2px 10px;color:#1C1208}

/* TRUST */
.hcv5__trust{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(212,82,122,.1);border-top:1px solid rgba(212,82,122,.06);border-bottom:1px solid rgba(212,82,122,.06);overflow:hidden}
.hcv5__ti{background:#fff;display:flex;flex-direction:column;align-items:center;text-align:center;padding:13px 6px;gap:3px}
.hcv5__ti>span{font-size:20px}
.hcv5__ti>strong{font-size:10px;font-weight:700;color:#1C1208}
.hcv5__ti>small{font-size:9px;color:#7A6E64;line-height:1.3}

/* STOCK */
.hcv5__stock{padding:13px 20px;background:linear-gradient(135deg,#FFF5F7,#FFF8F4);border-bottom:1px solid rgba(212,82,122,.06)}
.hcv5__stock-row{display:flex;justify-content:space-between;align-items:center;font-size:12px;font-weight:700;color:#C0405F;margin-bottom:7px}
.hcv5__stock-n{color:#7A6E64}
.hcv5__stock-bar{height:7px;background:rgba(212,82,122,.12);border-radius:20px;overflow:hidden}
.hcv5__stock-fill{width:23%;height:100%;background:linear-gradient(90deg,#C0405F,#D4527A);border-radius:20px;animation:hcv5stk 2s ease-out}
@keyframes hcv5stk{from{width:0}}
.hcv5__stock-sub{font-size:11px;color:#7A6E64;margin:5px 0 0;font-weight:600}

/* PAY BLOCK */
.hcv5__pay-block{margin:16px 20px;display:flex;flex-direction:column;gap:10px}
.hcv5__pay-title{font-size:13px;font-weight:800;color:#1C1208;margin-bottom:2px}

.hcv5__pay-opt{border-radius:14px;padding:14px;position:relative;overflow:hidden}
.hcv5__pay-opt--main{background:#fff;border:2px solid #25D366;box-shadow:0 4px 16px rgba(37,211,102,.15)}
.hcv5__pay-opt--discount{background:linear-gradient(135deg,#1a1a2e,#0f3460);border:1px solid rgba(255,215,0,.25)}

.hcv5__pay-opt-badge{display:inline-flex;align-items:center;gap:5px;font-size:9px;font-weight:800;letter-spacing:.1em;padding:3px 10px;border-radius:20px;margin-bottom:10px;text-transform:uppercase}
.hcv5__pay-opt--main .hcv5__pay-opt-badge{background:rgba(37,211,102,.15);color:#059669;border:1px solid rgba(37,211,102,.3)}
.hcv5__pay-opt-badge--gold{background:rgba(255,215,0,.15);color:#FFD700;border:1px solid rgba(255,215,0,.3)!important}

.hcv5__pay-opt-row{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.hcv5__pay-icon{font-size:26px;flex-shrink:0}
.hcv5__pay-info{flex:1}
.hcv5__pay-opt--main .hcv5__pay-info strong{display:block;font-size:14px;font-weight:800;color:#1C1208;margin-bottom:3px}
.hcv5__pay-opt--main .hcv5__pay-info span{font-size:11px;color:#7A6E64}
.hcv5__pay-opt--discount .hcv5__pay-info strong{display:block;font-size:14px;font-weight:800;color:#fff;margin-bottom:3px}
.hcv5__pay-opt--discount .hcv5__pay-info span{font-size:11px;color:rgba(255,255,255,.6)}
.hcv5__pay-opt--discount .hcv5__pay-info span b{color:#FFD700;font-size:15px}
.hcv5__pay-opt--discount .hcv5__pay-info span s{color:rgba(255,255,255,.35)}

/* COD button placeholder */
.hcv5__cod-btn{display:block;width:100%;padding:14px;background:linear-gradient(135deg,#059669,#10B981,#34D399);color:#fff;font-size:15px;font-weight:800;border:none;border-radius:50px;cursor:pointer;text-align:center;text-decoration:none;box-shadow:0 6px 20px rgba(5,150,105,.35);transition:transform .2s,box-shadow .2s;font-family:inherit}
.hcv5__cod-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(5,150,105,.5);color:#fff}

/* Discount button */
.hcv5__disc-btn{position:relative;overflow:hidden;display:block;width:100%;padding:14px;background:linear-gradient(135deg,#e94560,#533483,#0f3460);color:#fff;font-size:15px;font-weight:800;border:none;border-radius:50px;cursor:pointer;letter-spacing:.02em;font-family:inherit;box-shadow:0 6px 20px rgba(233,69,96,.35);transition:transform .2s,box-shadow .2s}
.hcv5__disc-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(233,69,96,.5)}
.hcv5__disc-price{color:#FFD700}

/* Shine */
.hcv5__shine{position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);transform:skewX(-20deg);animation:hcv5sh 3s 1s infinite}
@keyframes hcv5sh{0%{left:-75%;opacity:0}10%{opacity:1}40%{left:120%;opacity:0}100%{left:120%;opacity:0}}

/* WHATSAPP */
.hcv5__wa{display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,#075E54,#128C7E,#25D366);color:#fff;text-decoration:none;padding:14px 16px;border-radius:14px;box-shadow:0 5px 20px rgba(37,211,102,.25);transition:transform .2s,box-shadow .2s}
.hcv5__wa:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(37,211,102,.45);color:#fff}
.hcv5__wa>div{flex:1}
.hcv5__wa strong{display:block;font-size:13px;font-weight:800}
.hcv5__wa span{display:block;font-size:11px;color:rgba(255,255,255,.8);margin-top:2px}
.hcv5__wa-arr{font-size:20px;font-weight:700;flex-shrink:0}

/* BUNDLE */
.hcv5__bundle{border-top:3px solid #D4527A;background:#fff;margin-top:8px}
.hcv5__bundle-hd{background:linear-gradient(135deg,#1C1208,#2D1810);padding:20px;color:#fff}
.hcv5__b-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.35);color:#FFD700;font-size:9px;font-weight:800;letter-spacing:.12em;padding:3px 10px;border-radius:20px;margin-bottom:10px;text-transform:uppercase}
.hcv5__b-title{font-size:clamp(1.1rem,4vw,1.45rem);font-weight:900;color:#fff;margin:0 0 10px;line-height:1.25}
.hcv5__b-timer{display:flex;align-items:center;gap:6px;flex-wrap:wrap;font-size:12px;color:rgba(255,255,255,.7)}
.hcv5__b-clock{font-size:15px;font-weight:900;color:#FFD700;font-variant-numeric:tabular-nums}
.hcv5__b-scarce{color:#F87171;font-weight:700;font-size:11px}

/* COMPARE */
.hcv5__compare{display:flex;align-items:center;gap:10px;padding:16px 20px 12px;background:linear-gradient(135deg,#1C1208,#2D1810);flex-wrap:wrap}
.hcv5__cmp{flex:1;min-width:110px;border-radius:12px;padding:12px;text-align:center;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.06)}
.hcv5__cmp--good{background:rgba(212,82,122,.25);border-color:rgba(212,82,122,.5);box-shadow:0 0 18px rgba(212,82,122,.2)}
.hcv5__cmp-lbl{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.5);margin-bottom:4px}
.hcv5__cmp-price{display:block;font-size:18px;font-weight:900;color:#FFD700}
.hcv5__cmp--bad .hcv5__cmp-price{color:rgba(255,255,255,.35);text-decoration:line-through;font-size:15px}
.hcv5__cmp-sub{display:block;font-size:11px;color:rgba(255,255,255,.5);margin-top:3px}
.hcv5__cmp-arr{color:#D4527A;font-size:22px;font-weight:900;flex-shrink:0}

/* PILLS */
.hcv5__pills{display:flex;gap:6px;flex-wrap:wrap;padding:10px 20px 14px;background:linear-gradient(135deg,#1C1208,#2D1810)}
.hcv5__pills span{font-size:10px;font-weight:600;background:rgba(255,255,255,.1);border-radius:20px;padding:3px 10px;color:rgba(255,255,255,.8);white-space:nowrap}

/* PAIRS */
.hcv5__pairs{display:flex;align-items:flex-start;gap:10px;padding:18px 20px;background:#fff;border-bottom:1px solid rgba(212,82,122,.08)}
.hcv5__pair{flex:1;text-align:center}
.hcv5__pair-lbl{font-size:10px;font-weight:800;color:#D4527A;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.hcv5__pair-off{background:#D4527A;color:#fff;font-size:9px;padding:1px 6px;border-radius:20px}
.hcv5__pair-img{width:80px;height:80px;object-fit:cover;border-radius:12px;border:2px solid rgba(212,82,122,.2);display:block;margin:0 auto 8px}
.hcv5__pair-empty{width:80px;height:80px;border-radius:12px;border:2px dashed rgba(212,82,122,.4);background:linear-gradient(135deg,#FFF0F4,#F5E6FF);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:28px;color:rgba(212,82,122,.4);cursor:pointer}
.hcv5__pair-name{font-size:11px;font-weight:700;color:#1C1208;line-height:1.3;margin-bottom:3px}
.hcv5__pair-price{font-size:13px;font-weight:800;color:#D4527A;margin-bottom:3px}
.hcv5__pair-hint{font-size:10px;color:#7A6E64;font-style:italic}
.hcv5__choose-btn{margin-top:6px;font-size:11px;font-weight:700;color:#D4527A;background:rgba(212,82,122,.1);border:1.5px solid rgba(212,82,122,.3);border-radius:20px;padding:5px 12px;cursor:pointer;font-family:inherit;transition:background .2s}
.hcv5__choose-btn:hover{background:rgba(212,82,122,.2)}
.hcv5__plus{font-size:26px;font-weight:900;color:#D4527A;flex-shrink:0;padding-top:40px}

/* VARIANT PICKER */
.hcv5__variant-picker{padding:14px 20px;background:#FFF5F7;border-bottom:1px solid rgba(212,82,122,.1)}
.hcv5__vp-title{font-size:12px;font-weight:700;color:#1C1208;margin-bottom:10px}
.hcv5__vp-opts{display:flex;flex-wrap:wrap;gap:8px}
.hcv5__vp-opt{font-size:12px;font-weight:600;padding:7px 14px;border:2px solid rgba(212,82,122,.25);border-radius:8px;background:#fff;cursor:pointer;color:#1C1208;font-family:inherit;transition:all .15s}
.hcv5__vp-opt:hover{border-color:#D4527A;background:rgba(212,82,122,.05)}
.hcv5__vp-opt.selected{border-color:#D4527A;background:rgba(212,82,122,.1);color:#D4527A}
.hcv5__vp-opt:disabled{opacity:.4;cursor:not-allowed;text-decoration:line-through}

/* CATALOG */
.hcv5__catalog{max-height:0;overflow:hidden;transition:max-height .4s ease;background:#fff;border-top:1px solid rgba(212,82,122,.06)}
.hcv5__catalog.open{max-height:340px;overflow-y:auto}
.hcv5__cat-hd{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;font-weight:700;font-size:13px;border-bottom:1px solid rgba(212,82,122,.06);position:sticky;top:0;background:#fff;z-index:1}
.hcv5__cat-x{background:none;border:none;cursor:pointer;font-size:16px;color:#7A6E64;padding:4px}
.hcv5__cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:14px}
.hcv5__prod{background:none;border:2px solid rgba(212,82,122,.15);border-radius:12px;padding:8px;cursor:pointer;text-align:center;font-family:inherit;transition:all .15s}
.hcv5__prod:hover,.hcv5__prod.selected{border-color:#D4527A;background:rgba(212,82,122,.08);transform:translateY(-2px)}
.hcv5__prod img{width:76px;height:76px;object-fit:cover;border-radius:8px;display:block;margin:0 auto 5px}
.hcv5__prod span:nth-child(2){display:block;font-size:10px;font-weight:600;color:#1C1208;margin-bottom:2px;line-height:1.3}
.hcv5__prod-price{display:block;font-size:11px;font-weight:800;color:#D4527A}

/* BUNDLE CTA */
.hcv5__cta-wrap{padding:16px 20px 20px}
.hcv5__total{background:linear-gradient(135deg,#FFF0F4,#FDFAF7);border-radius:12px;padding:14px;margin-bottom:14px;border:1px solid rgba(212,82,122,.1)}
.hcv5__total-row{display:flex;justify-content:space-between;align-items:center;font-size:13px;margin-bottom:6px}
.hcv5__total-main{font-size:15px;font-weight:800}
.hcv5__t-old{text-decoration:line-through;color:#9CA3AF}
.hcv5__t-price{color:#D4527A;font-size:22px;font-weight:900}
.hcv5__t-save{font-size:12px;font-weight:700;color:#059669;background:rgba(5,150,105,.08);border-radius:8px;padding:6px 10px;text-align:center}
.hcv5__add-btn{position:relative;overflow:hidden;width:100%;padding:17px;background:linear-gradient(135deg,#C0405F,#D4527A,#E0607A);color:#fff;font-size:16px;font-weight:800;border:none;border-radius:50px;cursor:pointer;letter-spacing:.02em;font-family:inherit;box-shadow:0 6px 24px rgba(192,64,95,.4);transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s,opacity .2s;margin-bottom:12px}
.hcv5__add-btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}
.hcv5__add-btn:not(:disabled):hover{transform:translateY(-3px);box-shadow:0 10px 32px rgba(192,64,95,.6)}
.hcv5__microcopy{text-align:center;font-size:11px;color:#9CA3AF}

/* GUARANTEE */
.hcv5__guarantee{display:flex;align-items:flex-start;gap:12px;margin:16px 20px;background:#fff;border:1.5px solid rgba(212,82,122,.15);border-radius:14px;padding:14px}
.hcv5__guarantee strong{display:block;font-size:13px;font-weight:800;color:#1C1208;margin-bottom:3px}
.hcv5__guarantee span{font-size:12px;color:#7A6E64;line-height:1.5}

/* LIVE BOX */
.hcv5__live-box{margin:0 20px 16px;background:#fff;border:1px solid rgba(212,82,122,.1);border-radius:14px;overflow:hidden}
.hcv5__live-hd{display:flex;align-items:center;gap:8px;padding:10px 14px;background:linear-gradient(135deg,#FFF5F7,#fff);border-bottom:1px solid rgba(212,82,122,.06);font-size:12px;font-weight:700;color:#1C1208}
.hcv5__feed{min-height:0;padding:0 14px}
.hcv5__toast{display:flex;align-items:center;gap:9px;padding:9px 0;font-size:12px;color:#1C1208;border-bottom:1px solid rgba(212,82,122,.05);animation:hcv5in .4s ease}
.hcv5__toast strong{color:#D4527A}
@keyframes hcv5in{from{opacity:0;transform:translateX(-6px)}to{opacity:1;transform:translateX(0)}}
.hcv5__cities{display:flex;flex-wrap:wrap;gap:5px;padding:10px 14px}
.hcv5__cpill{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;background:rgba(212,82,122,.07);border:1px solid rgba(212,82,122,.15);border-radius:20px;padding:3px 9px;color:#D4527A;animation:hcv5in .4s ease}

/* REVIEWS */
.hcv5__reviews{padding:20px;border-top:1px solid rgba(212,82,122,.08)}
.hcv5__rev-hd{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.hcv5__rev-hd strong{font-size:16px;font-weight:800}
.hcv5__bars{margin-bottom:16px}
.hcv5__bar-row{display:flex;align-items:center;gap:8px;font-size:11px;color:#7A6E64;margin-bottom:4px}
.hcv5__bar-row span:first-child{width:28px;text-align:right;flex-shrink:0}
.hcv5__bbar{flex:1;height:6px;background:rgba(212,82,122,.1);border-radius:20px;overflow:hidden}
.hcv5__bfill{height:100%;background:linear-gradient(90deg,#D4527A,#F59E0B);border-radius:20px;animation:hcv5stk 2s ease-out}
.hcv5__bar-row span:last-child{width:22px;flex-shrink:0}
.hcv5__review{background:#fff;border:1px solid rgba(212,82,122,.1);border-radius:12px;padding:13px;margin-bottom:10px}
.hcv5__rrow{display:flex;align-items:center;gap:10px;margin-bottom:7px;flex-wrap:wrap}
.hcv5__av{width:34px;height:34px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;font-weight:800}
.hcv5__rrow>div{flex:1}
.hcv5__rrow strong{display:block;font-size:12px;font-weight:700}
.hcv5__rs{color:#F59E0B;font-size:11px;display:block}
.hcv5__vbadge{font-size:10px;color:#059669;font-weight:600;background:rgba(5,150,105,.08);padding:2px 7px;border-radius:20px;white-space:nowrap}
.hcv5__review p{font-size:12px;color:#7A6E64;line-height:1.6;margin:0 0 5px}
.hcv5__review small{font-size:10px;color:rgba(0,0,0,.3)}

/* STICKY */
.hcv5__sticky{display:none;position:fixed;bottom:56px;left:0;right:0;z-index:9996;background:#fff;border-top:2px solid rgba(212,82,122,.15);padding:10px 16px;align-items:center;gap:12px;box-shadow:0 -4px 20px rgba(0,0,0,.08)}
.hcv5__sp{font-size:18px;font-weight:900;color:#D4527A;display:block}
.hcv5__so{font-size:11px;text-decoration:line-through;color:#9CA3AF}
.hcv5__sticky-btn{background:linear-gradient(135deg,#128C7E,#25D366);color:#fff;font-size:14px;font-weight:800;padding:11px 20px;border-radius:50px;text-decoration:none;white-space:nowrap;box-shadow:0 4px 14px rgba(37,211,102,.4)}

/* RESPONSIVE */
@media(max-width:767px){
  .hcv5__sticky{display:flex}
  .hcv5__trust{grid-template-columns:repeat(2,1fr)}
  .hcv5__urgency,.hcv5__stock,.hcv5__proof{padding-left:14px;padding-right:14px}
  .hcv5__pay-block,.hcv5__guarantee{margin-left:14px;margin-right:14px}
  .hcv5__live-box{margin-left:14px;margin-right:14px}
  .hcv5__reviews{padding:16px 14px}
  .hcv5__cat-grid{grid-template-columns:repeat(2,1fr)}
  body{padding-bottom:56px!important}
}
</style>

<script>
(function(){
  /* TIMER */
  var S=14*60+59,K='hcv5t';
  function lT(){try{var d=JSON.parse(localStorage.getItem(K)||'null');if(d&&d.exp>Date.now())return Math.floor((d.exp-Date.now())/1e3);}catch(e){}var x=Date.now()+S*1e3;try{localStorage.setItem(K,JSON.stringify({exp:x}));}catch(e){}return S;}
  var r=lT();function p(n){return n<10?'0'+n:''+n;}
  function tick(){if(r<=0){r=S;try{localStorage.removeItem(K);}catch(e){}}var h=Math.floor(r/3600),m=Math.floor((r%3600)/60),s=r%60;['hcvH','hcvM','hcvS'].forEach(function(id,i){var e=document.getElementById(id);if(e)e.textContent=p([h,m,s][i]);});r--;}
  tick();setInterval(tick,1e3);

  /* BUNDLE TIMER */
  var br=14*60+59,bt=document.getElementById('hcvBT');
  function btick(){if(br<=0)br=14*60+59;var m=Math.floor(br/60),s=br%60;if(bt)bt.textContent=p(m)+':'+p(s);br--;}
  btick();setInterval(btick,1e3);

  /* VIEWERS */
  var ve=document.getElementById('hcvVC');var vc=Math.floor(Math.random()*14)+8;if(ve)ve.textContent=vc;
  setInterval(function(){vc=Math.max(6,Math.min(28,vc+(Math.random()<.5?1:-1)));if(ve)ve.textContent=vc;},7e3);

  /* LIVE + CIUDADES */
  var cities=[['Bogotá','🟢'],['Medellín','🟢'],['Cali','🟢'],['Barranquilla','🟡'],['Bucaramanga','🟡'],['Pereira','🟡'],['Cartagena','🟠'],['Santa Marta','🟠'],['Manizales','🟡'],['Cúcuta','🟡']];
  var names=['María','Laura','Andrea','Valentina','Camila','Daniela','Sofía','Paula','Isabella','Natalia','Alejandra','Diana'];
  var feed=document.getElementById('hcvFeed');var citiesEl=document.getElementById('hcvCities');
  var activeCities={};var tt=null;

  function addCity(c){
    if(activeCities[c])return;activeCities[c]=true;
    if(!citiesEl)return;
    var pill=document.createElement('div');pill.className='hcv5__cpill';
    pill.innerHTML='<span style="width:6px;height:6px;border-radius:50%;background:#D4527A;flex-shrink:0;animation:hcv5p 1.5s infinite"></span>'+c;
    citiesEl.appendChild(pill);
    if(Object.keys(activeCities).length>6){var f=citiesEl.firstChild;if(f){delete activeCities[f.textContent.trim()];citiesEl.removeChild(f);}}
  }
  function showToast(){
    if(!feed)return;
    var ci=cities[Math.floor(Math.random()*cities.length)];
    var n=names[Math.floor(Math.random()*names.length)];
    var mn=Math.floor(Math.random()*18)+1;
    var msgs=['<strong>'+n+'</strong> de <strong>'+ci[0]+'</strong> acaba de comprar 🛍️','<strong>'+n+'</strong> de '+ci[0]+' aprovechó el 2×1 🎉','¡Vendido! <strong>'+n+'</strong> en '+ci[0]+' aseguró su par ✓','<strong>'+n+'</strong> de '+ci[0]+' compró hace '+mn+' min'];
    var t=document.createElement('div');t.className='hcv5__toast';
    t.innerHTML='<span style="font-size:18px">🛍️</span><span>'+msgs[Math.floor(Math.random()*msgs.length)]+'</span>';
    if(feed.children.length>=2)feed.removeChild(feed.firstChild);
    feed.appendChild(t);addCity(ci[0]);
    clearTimeout(tt);tt=setTimeout(function(){if(feed&&feed.firstChild)feed.removeChild(feed.firstChild);},9e3);
  }
  ['Bogotá','Medellín','Cali','Barranquilla'].forEach(addCity);
  setTimeout(function(){showToast();setInterval(showToast,Math.random()*12e3+8e3);},1500);

  /* PAGO 5% */
  var payBtn=document.getElementById('hcvPayNow');
  if(payBtn){payBtn.addEventListener('click',function(){
    var vid=payBtn.dataset.variant;if(!vid)return;
    payBtn.textContent='Procesando...';payBtn.disabled=true;
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})})
    .then(function(){window.location.href='/checkout?discount=PAGA5';})
    .catch(function(){payBtn.disabled=false;payBtn.innerHTML='<span class="hcv5__shine"></span>💳 Pagar ahora con 5% de descuento';});
  });}

  /* BUNDLE LÓGICA */
  var chooseBtn=document.getElementById('hcvChoose');
  var cat=document.getElementById('hcvCat');
  var catX=document.getElementById('hcvCatX');
  var catG=document.getElementById('hcvCatG');
  var p2img=document.getElementById('hcvP2Img');
  var p2name=document.getElementById('hcvP2Name');
  var p2price=document.getElementById('hcvP2Price');
  var varPicker=document.getElementById('hcvVarPicker');
  var varOpts=document.getElementById('hcvVpOpts');
  var varTitle=document.getElementById('hcvVpTitle');
  var addBtn=document.getElementById('hcvAdd');
  var addTxt=document.getElementById('hcvAddTxt');
  var sv=null;

  if(chooseBtn)chooseBtn.addEventListener('click',function(){if(cat)cat.classList.add('open');});
  if(catX)catX.addEventListener('click',function(){if(cat)cat.classList.remove('open');});

  function showVariants(handle,defaultVariant){
    if(!varPicker||!varOpts)return;
    varOpts.innerHTML='<span style="font-size:12px;color:#7A6E64">Cargando opciones...</span>';
    varPicker.style.display='block';
    sv=defaultVariant;
    fetch('/products/'+handle+'.js')
    .then(function(r){return r.json();})
    .then(function(prod){
      if(!prod.variants||prod.variants.length<=1){varPicker.style.display='none';sv=defaultVariant;if(addBtn)addBtn.disabled=false;if(addTxt)addTxt.textContent='🛒 Agregar los 2 pares al carrito';return;}
      if(varTitle)varTitle.textContent='Elige talla/color del Par 2 ('+prod.title+'):';
      varOpts.innerHTML='';
      prod.variants.forEach(function(v){
        var btn=document.createElement('button');
        btn.className='hcv5__vp-opt';
        btn.textContent=v.title;
        btn.dataset.vid=v.id;
        if(!v.available)btn.disabled=true;
        if(v.id===parseInt(defaultVariant)){btn.classList.add('selected');sv=v.id;}
        btn.addEventListener('click',function(){
          varOpts.querySelectorAll('.hcv5__vp-opt').forEach(function(b){b.classList.remove('selected');});
          btn.classList.add('selected');sv=v.id;
          if(addBtn)addBtn.disabled=false;
          if(addTxt)addTxt.textContent='🛒 Agregar los 2 pares al carrito';
        });
        varOpts.appendChild(btn);
      });
    })
    .catch(function(){varPicker.style.display='none';sv=defaultVariant;if(addBtn)addBtn.disabled=false;if(addTxt)addTxt.textContent='🛒 Agregar los 2 pares al carrito';});
  }

  if(catG){catG.addEventListener('click',function(e){
    var btn=e.target.closest('.hcv5__prod');if(!btn)return;
    catG.querySelectorAll('.hcv5__prod').forEach(function(b){b.classList.remove('selected');});
    btn.classList.add('selected');
    if(p2img)p2img.innerHTML='<img src="'+btn.dataset.img+'" alt="'+btn.dataset.title+'" width="80" height="80" style="width:80px;height:80px;object-fit:cover;border-radius:12px;border:2px solid rgba(212,82,122,.3)">';
    if(p2name)p2name.textContent=btn.dataset.title;
    if(p2price){p2price.textContent='¡GRATIS con la oferta!';p2price.style.color='#25D366';}
    if(chooseBtn)chooseBtn.textContent='✓ Cambiarlo';
    if(cat)cat.classList.remove('open');
    showVariants(btn.dataset.handle,btn.dataset.variant);
  });}

  if(addBtn){addBtn.addEventListener('click',function(){
    if(!sv||addBtn.disabled)return;
    addBtn.disabled=true;if(addTxt)addTxt.textContent='Agregando...';
    var vA={{ product.first_available_variant.id | json }};
    /* Leer variante del producto principal del selector nativo del tema */
    var nativeForm=document.querySelector('form[action="/cart/add"]');
    if(nativeForm){var nativeVariant=nativeForm.querySelector('[name="id"]');if(nativeVariant&&nativeVariant.value)vA=parseInt(nativeVariant.value);}
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:vA,quantity:1},{id:parseInt(sv),quantity:1}]})})
    .then(function(r){return r.json();})
    .then(function(){if(addTxt)addTxt.textContent='✓ ¡Agregados!';addBtn.style.background='linear-gradient(135deg,#059669,#10B981)';setTimeout(function(){window.location.href='/cart';},1200);})
    .catch(function(){addBtn.disabled=false;if(addTxt)addTxt.textContent='Error — Intenta de nuevo';});
  });}
})();
</script>
