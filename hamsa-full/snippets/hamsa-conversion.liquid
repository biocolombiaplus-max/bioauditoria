.hcv4__pair-empty{width:80px;height:80px;border-radius:12px;border:2px dashed rgba(212,82,122,.4);background:linear-gradient(135deg,#FFF0F4,#F5E6FF);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:28px;color:rgba(212,82,122,.4);cursor:pointer}
