.hcv4__t-price{color:#D4527A;font-size:22px;font-weight:900}
.hcv4__t-save{font-size:12px;font-weight:700;color:#059669;background:rgba(5,150,105,.08);border-radius:8px;padding:6px 10px;text-align:center}
.hcv4__add-btn{position:relative;overflow:hidden;width:100%;padding:17px;background:linear-gradient(135deg,#C0405F,#D4527A,#E0607A);color:#fff;font-size:16px;font-weight:800;border:none;border-radius:50px;cursor:pointer;letter-spacing:.02em;font-family:inherit;box-shadow:0 6px 24px rgba(192,64,95,.45);transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s,opacity .2s;margin-bottom:12px}
.hcv4__add-btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}
.hcv4__add-btn:not(:disabled):hover{transform:translateY(-3px);box-shadow:0 10px 32px rgba(192,64,95,.6)}
.hcv4__add-shine{position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);transform:skewX(-20deg);animation:hcv4sh 3s infinite}
.hcv4__microcopy{text-align:center;font-size:11px;color:#9CA3AF}

/* GUARANTEE */
.hcv4__guarantee{display:flex;align-items:flex-start;gap:14px;margin:16px 20px;background:#fff;border:1.5px solid rgba(212,82,122,.15);border-radius:14px;padding:16px}
.hcv4__guarantee strong{display:block;font-size:13px;font-weight:800;color:#1C1208;margin-bottom:4px}
.hcv4__guarantee span{font-size:12px;color:#7A6E64;line-height:1.5}

/* LIVE SECTION */
.hcv4__live-section{margin:0 20px 16px;background:#fff;border:1px solid rgba(212,82,122,.1);border-radius:14px;overflow:hidden}
.hcv4__live-hd{display:flex;align-items:center;gap:8px;padding:12px 14px;background:linear-gradient(135deg,#FFF5F7,#FFF);border-bottom:1px solid rgba(212,82,122,.08);font-size:13px;font-weight:700;color:#1C1208}
.hcv4__live-dot{width:8px;height:8px;border-radius:50%;background:#4ADE80;flex-shrink:0;animation:hcv4p 1.5s infinite}
.hcv4__live-feed{min-height:0;padding:0 14px}
.hcv4__toast{display:flex;align-items:center;gap:10px;padding:10px 0;font-size:12px;color:#1C1208;border-bottom:1px solid rgba(212,82,122,.06);animation:hcv4in .4s ease}
@keyframes hcv4in{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
.hcv4__toast-icon{font-size:18px;flex-shrink:0}
.hcv4__toast strong{color:#D4527A}
.hcv4__live-map{padding:12px 14px}
.hcv4__map-title{font-size:11px;font-weight:700;color:#7A6E64;margin-bottom:8px}
.hcv4__map-cities{display:flex;flex-wrap:wrap;gap:6px}
.hcv4__city-pill{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:600;background:rgba(212,82,122,.08);border:1px solid rgba(212,82,122,.15);border-radius:20px;padding:3px 10px;color:#D4527A;animation:hcv4in .4s ease}
.hcv4__city-pulse{width:6px;height:6px;border-radius:50%;background:#D4527A;flex-shrink:0;animation:hcv4p 1.5s infinite}

/* REVIEWS */
.hcv4__reviews{padding:20px;border-top:1px solid rgba(212,82,122,.08)}
.hcv4__rev-hd{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.hcv4__rev-hd strong{font-size:16px;font-weight:800}
.hcv4__rev-count{font-size:12px;color:#7A6E64}
.hcv4__rev-bar-wrap{margin-bottom:16px;display:flex;flex-direction:column;gap:4px}
.hcv4__rev-bar{display:flex;align-items:center;gap:8px;font-size:11px;color:#7A6E64}
.hcv4__rev-bar span:first-child{width:28px;text-align:right;flex-shrink:0}
.hcv4__rbar{flex:1;height:6px;background:rgba(212,82,122,.1);border-radius:20px;overflow:hidden}
.hcv4__rfill{height:100%;background:linear-gradient(90deg,#D4527A,#F59E0B);border-radius:20px;animation:hcv4stk 2s ease-out}
.hcv4__rev-bar span:last-child{width:22px;flex-shrink:0}
.hcv4__review{background:#fff;border:1px solid rgba(212,82,122,.1);border-radius:12px;padding:14px;margin-bottom:12px}
.hcv4__rev-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.hcv4__av{width:36px;height:36px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;font-weight:800}
.hcv4__rev-row>div{flex:1}
.hcv4__rev-row strong{display:block;font-size:13px;font-weight:700}
.hcv4__rs{color:#F59E0B;font-size:11px;display:block}
.hcv4__vbadge{font-size:10px;color:#059669;font-weight:600;background:rgba(5,150,105,.08);padding:2px 8px;border-radius:20px;white-space:nowrap}
.hcv4__review p{font-size:13px;color:#7A6E64;line-height:1.6;margin:0 0 6px}
.hcv4__review small{font-size:11px;color:rgba(0,0,0,.3)}

/* STICKY */
.hcv4__sticky{display:none;position:fixed;bottom:56px;left:0;right:0;z-index:9996;background:#fff;border-top:2px solid rgba(212,82,122,.2);padding:10px 16px;align-items:center;gap:12px;box-shadow:0 -4px 20px rgba(0,0,0,.1)}
.hcv4__sticky-l{flex:1}
.hcv4__sp{font-size:18px;font-weight:900;color:#D4527A;display:block}
.hcv4__so{font-size:12px;text-decoration:line-through;color:#9CA3AF}
.hcv4__sticky-btn{background:linear-gradient(135deg,#128C7E,#25D366);color:#fff;font-size:14px;font-weight:800;padding:12px 22px;border-radius:50px;text-decoration:none;white-space:nowrap;box-shadow:0 4px 16px rgba(37,211,102,.4)}

/* RESPONSIVE */
@media(max-width:767px){
  .hcv4__sticky{display:flex}
  .hcv4__trust{grid-template-columns:repeat(2,1fr)}
  .hcv4__urgency,.hcv4__stock,.hcv4__proof{padding-left:14px;padding-right:14px}
  .hcv4__wa{margin:12px 14px;padding:12px 14px}
  .hcv4__instant-pay{margin:12px 14px}
  .hcv4__guarantee{margin:12px 14px}
  .hcv4__live-section{margin-left:14px;margin-right:14px}
  .hcv4__reviews{padding:16px 14px}
  .hcv4__cat-grid{grid-template-columns:repeat(2,1fr)}
  body{padding-bottom:56px!important}
}
</style>

<script>
(function(){
  /* TIMER */
  var S=14*60+59,K='hcv4t';
  function lT(){try{var d=JSON.parse(localStorage.getItem(K)||'null');if(d&&d.exp>Date.now())return Math.floor((d.exp-Date.now())/1e3);}catch(e){}var x=Date.now()+S*1e3;try{localStorage.setItem(K,JSON.stringify({exp:x}));}catch(e){}return S;}
  var r=lT();
  function p(n){return n<10?'0'+n:''+n;}
  function tick(){
    if(r<=0){r=S;try{localStorage.removeItem(K);}catch(e){}}
    var h=Math.floor(r/3600),m=Math.floor((r%3600)/60),s=r%60;
    ['hcvH','hcvM','hcvS'].forEach(function(id,i){var e=document.getElementById(id);if(e)e.textContent=p([h,m,s][i]);});r--;
  }
  tick();setInterval(tick,1e3);

  /* BUNDLE TIMER */
  var br=14*60+59,bt=document.getElementById('hcvBT');
  function btick(){if(br<=0)br=14*60+59;var m=Math.floor(br/60),s=br%60;if(bt)bt.textContent=p(m)+':'+p(s);br--;}
  btick();setInterval(btick,1e3);

  /* VIEWERS */
  var ve=document.getElementById('hcvVC');
  var vc=Math.floor(Math.random()*14)+8;
  if(ve)ve.textContent=vc;
  setInterval(function(){vc=Math.max(6,Math.min(28,vc+(Math.random()<.5?1:-1)));if(ve)ve.textContent=vc;},7e3);

  /* LIVE FOMO + MAP */
  var cities=[['Bogotá','BOG'],['Medellín','MED'],['Cali','CAL'],['Barranquilla','BAQ'],['Bucaramanga','BGA'],['Pereira','PEI'],['Cartagena','CTG'],['Santa Marta','SMR'],['Manizales','MNZ'],['Cúcuta','CUC']];
  var names=['María','Laura','Andrea','Valentina','Camila','Daniela','Sofía','Paula','Isabella','Natalia','Alejandra','Diana'];
  var feed=document.getElementById('hcvLive');
  var citiesEl=document.getElementById('hcvCities');
  var activeCities={};
  var tt=null;

  function addCity(city){
    if(activeCities[city])return;
    activeCities[city]=true;
    if(!citiesEl)return;
    var pill=document.createElement('div');pill.className='hcv4__city-pill';
    pill.innerHTML='<span class="hcv4__city-pulse"></span>'+city;
    citiesEl.appendChild(pill);
    if(Object.keys(activeCities).length>6){var first=citiesEl.firstChild;if(first){delete activeCities[first.textContent.trim()];citiesEl.removeChild(first);}}
  }

  function showToast(){
    if(!feed)return;
    var ci=cities[Math.floor(Math.random()*cities.length)];
    var n=names[Math.floor(Math.random()*names.length)];
    var mn=Math.floor(Math.random()*20)+1;
    var msgs=[
      '<strong>'+n+'</strong> de <strong>'+ci[0]+'</strong> acaba de comprar 🛍️',
      '<strong>'+n+'</strong> de '+ci[0]+' aprovechó la oferta 2×1 🎉',
      '¡Vendido! <strong>'+n+'</strong> en '+ci[0]+' aseguró su par ✓',
      '<strong>'+n+'</strong> de '+ci[0]+' pidió hace '+mn+' min'
    ];
    var t=document.createElement('div');t.className='hcv4__toast';
    t.innerHTML='<span class="hcv4__toast-icon">🛍️</span><span>'+msgs[Math.floor(Math.random()*msgs.length)]+'</span>';
    if(feed.children.length>=2)feed.removeChild(feed.firstChild);
    feed.appendChild(t);
    addCity(ci[0]);
    clearTimeout(tt);tt=setTimeout(function(){if(feed&&feed.firstChild)feed.removeChild(feed.firstChild);},8e3);
  }

  /* Ciudades iniciales */
  ['Bogotá','Medellín','Cali'].forEach(addCity);
  setTimeout(function(){showToast();setInterval(showToast,Math.random()*12e3+10e3);},2e3);

  /* PAGO INMEDIATO 10% */
  var payBtn=document.getElementById('hcvPayNow');
  if(payBtn){
    payBtn.addEventListener('click',function(){
      var vid=payBtn.dataset.variant;
      if(!vid)return;
      payBtn.textContent='Procesando...';payBtn.disabled=true;
      fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(vid),quantity:1})})
      .then(function(){window.location.href='/checkout?discount=PAGA10';})
      .catch(function(){payBtn.disabled=false;payBtn.textContent='💳 Pagar ahora — 10% OFF';});
    });
  }

  /* BUNDLE */
  var chooseBtn=document.getElementById('hcvChoose');
  var cat=document.getElementById('hcvCat');
  var catX=document.getElementById('hcvCatX');
  var catG=document.getElementById('hcvCatG');
  var p2img=document.getElementById('hcvP2Img');
  var p2name=document.getElementById('hcvP2Name');
  var p2price=document.getElementById('hcvP2Price');
  var addBtn=document.getElementById('hcvAdd');
  var addTxt=document.getElementById('hcvAddTxt');
  var sv=null;

  if(chooseBtn)chooseBtn.addEventListener('click',function(){if(cat)cat.classList.add('open');});
  if(catX)catX.addEventListener('click',function(){if(cat)cat.classList.remove('open');});

  if(catG){catG.addEventListener('click',function(e){
    var btn=e.target.closest('.hcv4__prod');if(!btn)return;
    catG.querySelectorAll('.hcv4__prod').forEach(function(b){b.classList.remove('selected');});
    btn.classList.add('selected');sv=btn.dataset.variant;
    if(p2img)p2img.innerHTML='<img src="'+btn.dataset.img+'" alt="'+btn.dataset.title+'" width="80" height="80" style="width:80px;height:80px;object-fit:cover;border-radius:12px;border:2px solid rgba(212,82,122,.3)">';
    if(p2name)p2name.textContent=btn.dataset.title;
    if(p2price){p2price.textContent='¡GRATIS con la oferta!';p2price.style.color='#25D366';}
    if(chooseBtn)chooseBtn.textContent='✓ Cambiarlo';
    if(addBtn)addBtn.disabled=false;
    if(addTxt)addTxt.textContent='🛒 Agregar los 2 pares al carrito';
    if(cat)cat.classList.remove('open');
  });}

  if(addBtn){addBtn.addEventListener('click',function(){
    if(!sv||addBtn.disabled)return;
    addBtn.disabled=true;if(addTxt)addTxt.textContent='Agregando...';
    var vA={{ product.first_available_variant.id | json }};
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:vA,quantity:1},{id:parseInt(sv),quantity:1}]})})
    .then(function(r){return r.json();})
    .then(function(){if(addTxt)addTxt.textContent='✓ ¡Agregados!';addBtn.style.background='linear-gradient(135deg,#059669,#10B981)';setTimeout(function(){window.location.href='/cart';},1200);})
    .catch(function(){addBtn.disabled=false;if(addTxt)addTxt.textContent='Error — Intenta de nuevo';});
  });}
})();
</script>
