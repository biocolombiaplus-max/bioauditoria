{% comment %}hamsa-cart-upsell-banner — motivador simple, sin friccion{% endcomment %}
{%- if cart.item_count > 0 and cart.item_count < 2 -%}

<div class="hcub">
  <div class="hcub__inner">
    <div class="hcub__left">
      <span class="hcub__fire">🔥</span>
      <div class="hcub__text">
        <p class="hcub__title">¡Agrega 1 par más y paga solo <strong>$159.900</strong> los dos!</p>
        <p class="hcub__sub">Ahorras $79.900 &bull; Envio gratis &bull; Pago al recibir</p>
      </div>
    </div>
    <a href="/pages/oferta-2x1" class="hcub__btn">
      🔥 ¡Ver oferta 2x1!
    </a>
  </div>
</div>

<style>
.hcub{
  margin:0;
  border-top:2px solid rgba(201,169,110,.25);
  background:linear-gradient(135deg,rgba(201,169,110,.1),rgba(201,169,110,.03));
  padding:14px;
}
.hcub__inner{
  display:flex;align-items:center;
  justify-content:space-between;gap:12px;
  flex-wrap:wrap;
}
.hcub__left{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
.hcub__fire{font-size:22px;flex-shrink:0;animation:hcub-fire 1.3s infinite alternate}
@keyframes hcub-fire{from{transform:scale(1) rotate(-5deg)}to{transform:scale(1.15) rotate(5deg)}}
.hcub__text{flex:1;min-width:0}
.hcub__title{font-size:13px;font-weight:700;color:#f0f0f0;line-height:1.3;margin-bottom:2px}
.hcub__title strong{color:#c9a96e}
.hcub__sub{font-size:10px;color:#888}
.hcub__btn{
  flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center;gap:6px;
  padding:14px 20px;
  background:linear-gradient(135deg,#ff6b00,#ff1744);
  color:#fff;
  font-size:13px;font-weight:900;
  border-radius:12px;text-decoration:none;
  white-space:nowrap;
  box-shadow:0 4px 18px rgba(255,107,0,.5);
  transition:transform .15s,box-shadow .15s;
  position:relative;overflow:hidden;
  animation:hcub-pulse 2s ease-in-out infinite;
}
@keyframes hcub-pulse{
  0%,100%{box-shadow:0 4px 18px rgba(255,107,0,.5);}
  50%{box-shadow:0 6px 28px rgba(255,107,0,.8),0 0 0 4px rgba(255,107,0,.15);}
}
.hcub__btn::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);
  transform:translateX(-100%);
  animation:hcub-shine 2.2s infinite;
}
@keyframes hcub-shine{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.hcub__btn:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(255,107,0,.7);color:#fff}
.hcub__btn:active{transform:scale(.96)}
</style>

{%- elsif cart.item_count >= 2 -%}

<div class="hcub hcub--ok">
  <div class="hcub__ok-inner">
    <span class="hcub__ok-icon">✅</span>
    <div>
      <p class="hcub__ok-title">¡Tienes la oferta 2x1 activa!</p>
      <p class="hcub__ok-sub">El descuento se aplica automaticamente en el total</p>
    </div>
  </div>
</div>

<style>
.hcub--ok{
  margin:0;
  border-top:2px solid rgba(0,200,83,.25);
  background:rgba(0,200,83,.06);
  padding:12px 14px;
}
.hcub__ok-inner{display:flex;align-items:center;gap:10px}
.hcub__ok-icon{font-size:20px;flex-shrink:0}
.hcub__ok-title{font-size:13px;font-weight:700;color:#00c853;margin-bottom:2px}
.hcub__ok-sub{font-size:10px;color:#888}
</style>

{%- endif -%}
