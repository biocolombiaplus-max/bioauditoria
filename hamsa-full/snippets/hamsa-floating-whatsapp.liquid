{% liquid
  assign brand_name = settings.hamsa_brand_name | default: shop.name
  assign wa_country_code = settings.hamsa_whatsapp_country_code | default: '57'
  assign wa_number_raw = settings.hamsa_whatsapp_number | strip | replace: ' ', '' | replace: '+', '' | replace: '-', '' | replace: '(', '' | replace: ')', ''
  if wa_number_raw != blank and wa_number_raw.size == 10 and wa_country_code != blank
    assign wa_number_raw = wa_country_code | append: wa_number_raw
  endif
%}

{% if settings.hamsa_show_floating_whatsapp and wa_number_raw != blank %}
  <a
    href="https://wa.me/{{ wa_number_raw }}"
    class="hamsa-floating-wa hamsa-wa-btn"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escribir a {{ brand_name }} por WhatsApp"
    data-wa-phone="{{ wa_number_raw }}"
    data-wa-msg="{{ settings.hamsa_whatsapp_message | default: 'Hola, quiero informacion sobre Hamsa Shoes' | escape }}"
  >
    <span class="hamsa-floating-wa__icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" focusable="false">
        <path fill="currentColor" d="M19.11 17.23c-.27-.14-1.61-.79-1.86-.88-.25-.09-.43-.14-.61.14-.18.27-.7.88-.86 1.06-.16.18-.32.2-.59.07-.27-.14-1.13-.42-2.15-1.35-.79-.7-1.32-1.57-1.48-1.84-.16-.27-.02-.41.12-.54.12-.12.27-.32.41-.47.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.47-.07-.14-.61-1.48-.84-2.03-.22-.53-.45-.45-.61-.46h-.52c-.18 0-.47.07-.72.34-.25.27-.95.93-.95 2.27s.97 2.63 1.11 2.81c.14.18 1.9 2.89 4.61 4.05.65.28 1.16.45 1.56.58.66.21 1.25.18 1.72.11.52-.08 1.61-.66 1.84-1.29.23-.63.23-1.18.16-1.29-.07-.11-.25-.18-.52-.32Z"/>
        <path fill="currentColor" d="M16.02 3.2c-7.08 0-12.8 5.7-12.8 12.73 0 2.25.59 4.44 1.72 6.37L3.12 28.8l6.67-1.75a12.9 12.9 0 0 0 6.23 1.6h.01c7.07 0 12.8-5.7 12.8-12.73 0-3.4-1.33-6.6-3.75-9A12.82 12.82 0 0 0 16.02 3.2Zm0 23.28h-.01a10.7 10.7 0 0 1-5.44-1.49l-.39-.23-3.96 1.04 1.06-3.86-.25-.4a10.53 10.53 0 0 1-1.63-5.62c0-5.84 4.79-10.59 10.67-10.59 2.85 0 5.53 1.1 7.54 3.1a10.46 10.46 0 0 1 3.13 7.48c0 5.84-4.79 10.59-10.72 10.59Z"/>
      </svg>
    </span>
    <span class="hamsa-floating-wa__text">{{ settings.hamsa_floating_whatsapp_label | default: 'Compra por WhatsApp' }}</span>
  </a>

  <style>
    .hamsa-floating-wa {
      position: fixed;
      right: 18px;
      bottom: max(18px, calc(env(safe-area-inset-bottom) + 12px));
      z-index: 70;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-height: 56px;
      padding: 12px 18px;
      border-radius: 999px;
      background: #25D366;
      color: #04110a;
      text-decoration: none;
      font-weight: 700;
      letter-spacing: .01em;
      box-shadow: 0 18px 40px rgba(0,0,0,.22);
      border: 1px solid rgba(255,255,255,.28);
      transition: transform .22s ease, box-shadow .22s ease;
    }
    .hamsa-floating-wa:hover {
      transform: translateY(-2px);
      box-shadow: 0 24px 48px rgba(0,0,0,.28);
    }
    .hamsa-floating-wa__icon {
      width: 28px; height: 28px;
      display: inline-flex; align-items: center; justify-content: center;
    }
    .hamsa-floating-wa__icon svg { width: 100%; height: 100%; display: block; }
    .hamsa-floating-wa__text { font-size: 14px; line-height: 1; white-space: nowrap; }
    @media (max-width: 749px) {
      .hamsa-floating-wa { right: 12px; left: auto; min-height: 52px; padding: 12px 14px; }
      .hamsa-floating-wa__text { display: none; }
    }
  </style>
{% endif %}
