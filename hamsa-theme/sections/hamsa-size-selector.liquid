{% comment %}
  hamsa-size-selector.liquid
  Guía visual de tallas para reducir fricción de compra.
  Ubicar en home o en la página de colección.
{% endcomment %}

<section class="hss-section" id="HamsaSizes-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --card: {{ section.settings.card_color }};
  --accent: {{ section.settings.accent_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
">
  <div class="hss-container">
    <div class="hss-head">
      {% if section.settings.heading != blank %}
        <h2 class="hss-title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="hss-sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
    <div class="hss-grid">
      {% assign sizes = "35,36,37,38,39,40" | split: "," %}
      {% assign cms = "22.0,22.5,23.0,23.5,24.0,24.5" | split: "," %}
      {% assign eur = "35,36,37,38,39,40" | split: "," %}
      {% assign usa = "5,5.5,6.5,7.5,8.5,9" | split: "," %}
      {% for size in sizes %}
        {% assign i = forloop.index0 %}
        <div class="hss-card">
          <div class="hss-size">{{ size }}</div>
          <div class="hss-cm">{{ cms[i] }} cm</div>
          <div class="hss-badges">
            <span>EUR {{ eur[i] }}</span>
            <span>USA {{ usa[i] }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.tip != blank %}
    <div class="hss-tip">
      <span>💡</span>
      <span>{{ section.settings.tip }}</span>
    </div>
    {% endif %}
    {% if section.settings.wa_number != blank %}
    <div class="hss-cta">
      <a href="https://wa.me/{{ section.settings.wa_country }}{{ section.settings.wa_number }}?text={{ section.settings.wa_message | url_encode }}" 
         class="hss-wa-btn" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        ¿Dudas con tu talla? Escríbenos al WhatsApp
      </a>
    </div>
    {% endif %}
  </div>
</section>

<style>
#HamsaSizes-{{ section.id }} {
  background: var(--bg);
  padding: {{ section.settings.pt }}px 20px {{ section.settings.pb }}px;
}
#HamsaSizes-{{ section.id }} * { box-sizing: border-box; }
.hss-container { max-width: 900px; margin: 0 auto; }
.hss-head { text-align: center; margin-bottom: 28px; }
.hss-title { font-size: clamp(1.3rem, 2.5vw, 1.8rem); font-weight: 800; color: var(--text); margin: 0 0 8px; letter-spacing: -0.02em; }
.hss-sub { font-size: 14px; color: var(--muted); margin: 0; }
.hss-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 16px; }
.hss-card {
  background: var(--card);
  border: 1px solid rgba(0,0,0,.08);
  border-radius: 12px;
  padding: 16px 8px;
  text-align: center;
  transition: border-color .2s, transform .2s, box-shadow .2s;
  cursor: default;
}
.hss-card:hover {
  border-color: var(--accent);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0,0,0,.1);
}
.hss-size { font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 4px; }
.hss-cm { font-size: 12px; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
.hss-badges { display: flex; flex-direction: column; gap: 3px; }
.hss-badges span { font-size: 10px; color: var(--muted); background: rgba(0,0,0,.04); border-radius: 4px; padding: 2px 4px; }
.hss-tip {
  display: flex; align-items: flex-start; gap: 8px;
  background: color-mix(in srgb, var(--accent) 8%, white);
  border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
  border-radius: 10px;
  padding: 12px 14px;
  font-size: 13px; color: var(--text); line-height: 1.5; margin-bottom: 16px;
}
.hss-cta { text-align: center; }
.hss-wa-btn {
  display: inline-flex; align-items: center; gap: 8px;
  background: #25D366; color: #fff;
  padding: 12px 24px; border-radius: 30px;
  font-size: 14px; font-weight: 700; text-decoration: none;
  transition: background .2s, transform .2s;
}
.hss-wa-btn:hover { background: #1DA851; transform: translateY(-2px); color: #fff; }
@media (max-width: 600px) {
  .hss-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>

{% schema %}
{
  "name": "Guía de Tallas",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "color", "id": "card_color", "label": "Tarjeta", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Acento", "default": "#D4527A" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Encuentra tu talla perfecta" },
    { "type": "text", "id": "subtext", "label": "Subtítulo", "default": "Medidas exactas para que tu sandalia quede perfecta" },
    { "type": "textarea", "id": "tip", "label": "Consejo", "default": "¿Entre dos tallas? Si tienes pie ancho elige la más grande. Si es estrecho, la más pequeña. El primer cambio de talla es GRATIS." },
    { "type": "header", "content": "WhatsApp" },
    { "type": "text", "id": "wa_country", "label": "Código país", "default": "57" },
    { "type": "text", "id": "wa_number", "label": "Número", "default": "3508258757" },
    { "type": "text", "id": "wa_message", "label": "Mensaje", "default": "Hola! Necesito ayuda para elegir mi talla en Hamsa Shoes" },
    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "pt", "label": "Padding top", "min": 20, "max": 100, "step": 4, "default": 48 },
    { "type": "range", "id": "pb", "label": "Padding bottom", "min": 20, "max": 100, "step": 4, "default": 48 }
  ],
  "presets": [
    { "name": "Guía de Tallas" }
  ]
}
{% endschema %}
