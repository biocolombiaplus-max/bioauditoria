<!-- ═══════════════════════════════════════════
     BENEFITS SECTION
═══════════════════════════════════════════ -->
<section class="hhb-section" id="HamsaBenefits-{{ section.id }}" style="
  --bg: {{ section.settings.bg_color }};
  --card: {{ section.settings.card_color }};
  --gold: {{ section.settings.gold_color }};
  --text: {{ section.settings.text_color }};
  --muted: {{ section.settings.muted_color }};
">
  <div class="hhb-container">
    {% if section.settings.heading != blank %}
      <h2 class="hhb-title">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="hhb-grid">
      {% for block in section.blocks %}
        <div class="hhb-card" {{ block.shopify_attributes }}>
          <div class="hhb-icon">
            {% case block.settings.icon %}
              {% when 'truck' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'payment' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              {% when 'shield' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {% when 'refresh' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              {% when 'star' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {% when 'whatsapp' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {% else %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            {% endcase %}
          </div>
          <h3 class="hhb-card__title">{{ block.settings.title }}</h3>
          {% if block.settings.text != blank %}
            <p class="hhb-card__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
#HamsaBenefits-{{ section.id }} {
  background: var(--bg); padding: {{ section.settings.pt }}px 0 {{ section.settings.pb }}px;
  overflow: hidden;
}
#HamsaBenefits-{{ section.id }} * { box-sizing: border-box; }
#HamsaBenefits-{{ section.id }} .hhb-container { max-width: 1320px; margin: 0 auto; padding: 0 20px; }
#HamsaBenefits-{{ section.id }} .hhb-title {
  text-align: center; font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 700;
  color: var(--text); margin: 0 0 36px; letter-spacing: -0.02em;
}
#HamsaBenefits-{{ section.id }} .hhb-grid {
  display: grid; grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr); gap: 16px;
}
#HamsaBenefits-{{ section.id }} .hhb-card {
  background: var(--card); border-radius: 16px; padding: 28px 22px;
  border: 1px solid rgba(0,0,0,.08); text-align: center;
  transition: transform .25s, border-color .25s;
}
#HamsaBenefits-{{ section.id }} .hhb-card:hover {
  transform: translateY(-4px);
  border-color: color-mix(in srgb, var(--gold) 35%, transparent);
}
#HamsaBenefits-{{ section.id }} .hhb-icon {
  width: 56px; height: 56px; border-radius: 14px;
  background: color-mix(in srgb, var(--gold) 15%, transparent);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 16px; color: var(--gold);
}
#HamsaBenefits-{{ section.id }} .hhb-card__title {
  font-size: 15px; font-weight: 700; color: var(--text); margin: 0 0 8px;
}
#HamsaBenefits-{{ section.id }} .hhb-card__text {
  font-size: 13px; color: var(--muted); line-height: 1.6; margin: 0;
}
@media (max-width: 900px) {
  #HamsaBenefits-{{ section.id }} { padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px; }
  #HamsaBenefits-{{ section.id }} .hhb-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  #HamsaBenefits-{{ section.id }} .hhb-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
  #HamsaBenefits-{{ section.id }} .hhb-card { padding: 20px 14px; }
  #HamsaBenefits-{{ section.id }} .hhb-icon { width: 44px; height: 44px; }
}
</style>

{% schema %}
{
  "name": "✅ Beneficios",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        { "type": "select", "id": "icon", "label": "Ícono", "default": "truck",
          "options": [
            { "value": "truck", "label": "Camión (envío)" },
            { "value": "payment", "label": "Tarjeta (pago)" },
            { "value": "shield", "label": "Escudo (seguridad)" },
            { "value": "refresh", "label": "Flecha (cambios)" },
            { "value": "star", "label": "Estrella" },
            { "value": "whatsapp", "label": "WhatsApp" }
          ]
        },
        { "type": "text", "id": "title", "label": "Título", "default": "Envío gratis a Colombia" },
        { "type": "textarea", "id": "text", "label": "Descripción", "default": "Recibe tu pedido sin costo adicional." }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Título de la sección", "default": "Por qué comprarnos" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#FDFAF7" },
    { "type": "color", "id": "card_color", "label": "Fondo tarjeta", "default": "#F7F3EF" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#1C1208" },
    { "type": "color", "id": "muted_color", "label": "Texto suave", "default": "#7A6E64" },
    { "type": "color", "id": "gold_color", "label": "Color acento", "default": "#D4527A" },
    { "type": "range", "id": "pt", "label": "Padding top desktop", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pb", "label": "Padding bottom desktop", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "pt_mobile", "label": "Padding top móvil", "min": 20, "max": 80, "step": 4, "default": 36 },
    { "type": "range", "id": "pb_mobile", "label": "Padding bottom móvil", "min": 20, "max": 80, "step": 4, "default": 36 }
  ],
  "presets": [
    {
      "name": "✅ Beneficios",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "truck", "title": "Envío gratis", "text": "A todo Colombia sin costo adicional." } },
        { "type": "benefit", "settings": { "icon": "payment", "title": "Pago contra entrega", "text": "Paga cuando recibas tu pedido." } },
        { "type": "benefit", "settings": { "icon": "shield", "title": "Compra segura", "text": "Tus datos protegidos siempre." } },
        { "type": "benefit", "settings": { "icon": "whatsapp", "title": "Atención por WhatsApp", "text": "Respondemos rápido y con gusto." } }
      ]
    }
  ]
}
{% endschema %}
