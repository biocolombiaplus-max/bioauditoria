rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }
    function perfil() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    function esDeEsteLab(tenantId) {
      return autenticado() && perfil().tenantId == tenantId;
    }
    function esSuperadmin() {
      return autenticado() && perfil().rol == "superadmin";
    }

    // Cada usuario autenticado solo puede leer SU PROPIO perfil (para saber a
    // qué laboratorio pertenece). Solo se crea una vez, al aprovisionar la
    // cuenta (el propio usuario recién creado escribe su documento).
    match /userProfiles/{uid} {
      allow read: if autenticado() && request.auth.uid == uid;
      allow create: if autenticado() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // CRM interno (leads y clientes de BIOsoft) — leer, editar y borrar solo
    // lo puede hacer el superadmin real. Crear también lo puede hacer
    // cualquier visitante SIN sesión desde el formulario público de
    // activación (activar.html): el cliente aún no tiene cuenta, así que se
    // valida que el documento nazca en estado "nuevo" y con la forma mínima
    // esperada, para evitar que se inyecten leads ya "activos" o corruptos.
    match /crmClientes/{clienteId} {
      allow read, update, delete: if esSuperadmin();
      allow create: if esSuperadmin() || (
        request.resource.data.estado == "nuevo" &&
        request.resource.data.origen == "formulario_publico" &&
        request.resource.data.laboratorio is map &&
        request.resource.data.contacto is map &&
        request.resource.data.contacto.nombre is string &&
        request.resource.data.contacto.nombre.size() > 0
      );
    }

    // Plantillas de mensajes de WhatsApp reutilizables del CRM — de uso
    // exclusivo del superadmin.
    match /crmPlantillas/{plantillaId} {
      allow read, write: if esSuperadmin();
    }

    match /tenants/{tenantId} {
      allow read, update: if esDeEsteLab(tenantId);
      // La creación ocurre en el mismo flujo de aprovisionamiento, por el
      // usuario recién autenticado que se convertirá en su administrador.
      allow create: if autenticado();
      allow delete: if false;

      match /users/{userId} {
        allow read, write: if esDeEsteLab(tenantId);
      }
      match /patients/{patientId} {
        allow read, write: if esDeEsteLab(tenantId);
      }
      match /orders/{orderId} {
        allow read, write: if esDeEsteLab(tenantId);
      }
      match /auditLog/{logId} {
        allow read, create: if esDeEsteLab(tenantId);
        allow update, delete: if false;
      }
      match /qcControles/{controlId} {
        allow read, write: if esDeEsteLab(tenantId);
      }
      match /qcLecturas/{lecturaId} {
        allow read, write: if esDeEsteLab(tenantId);
      }
    }
  }
}
